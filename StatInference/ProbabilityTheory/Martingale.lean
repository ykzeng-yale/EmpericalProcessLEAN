  refine ⟨k, ?_⟩
  intro n
  have hk_abs : |Ainf ω| < (k : ℝ) :=
    lt_of_le_of_lt (le_max_right (1 : ℝ) |Ainf ω|) hk
  have hk_one : (1 : ℝ) < (k : ℝ) :=
    lt_of_le_of_lt (le_max_left (1 : ℝ) |Ainf ω|) hk
