    (P := P) (X := X)
    (Y := fun n : ℕ => durrett2019_theorem_2_5_8_truncated X A n)
    (durrett2019_theorem_2_5_8_tsum_mismatch_ne_top_of_tsum_tail_ne_top
      (P := P) (X := X) (A := A) htail)

