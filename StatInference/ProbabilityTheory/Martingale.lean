theorem durrett2019_theorem_4_5_3_reciprocal_comp_normalizer_increment_nonneg
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©}
    {A : ‚Ąē -> ő© -> ‚ĄĚ} {f : ‚ĄĚ -> ‚ĄĚ}
    (hA_mono_step : ‚ąÄ k : ‚Ąē, ‚ąÄ ŌČ : ő©, A k ŌČ ‚Č§ A (k + 1) ŌČ)
    (hf_mono :
      ‚ąÄ k : ‚Ąē, ‚ąÄ ŌČ : ő©,
        MonotoneOn f (Set.Icc (A k ŌČ) (A (k + 1) ŌČ))) :
    ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÄ k : ‚Ąē, 0 ‚Č§ f (A (k + 2) ŌČ) - f (A (k + 1) ŌČ) := by
  refine ae_of_all P fun ŌČ k => ?_
  have hleft :
      A (k + 1) ŌČ ‚ąą Set.Icc (A (k + 1) ŌČ) (A (k + 2) ŌČ) :=
    ‚ü®le_rfl, hA_mono_step (k + 1) ŌČ‚ü©
  have hright :
      A (k + 2) ŌČ ‚ąą Set.Icc (A (k + 1) ŌČ) (A (k + 2) ŌČ) :=
    ‚ü®hA_mono_step (k + 1) ŌČ, le_rfl‚ü©
  exact
    sub_nonneg.mpr
      (hf_mono (k + 1) ŌČ hleft hright (hA_mono_step (k + 1) ŌČ))

/--
Durrett 2019, Theorem 4.5.3 interval lower-bound support.

A global lower bound on the deterministic normalizer discharges every
