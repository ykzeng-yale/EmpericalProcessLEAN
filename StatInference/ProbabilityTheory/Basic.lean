theorem durrett2019_theorem_2_5_8_tsum_tail_ne_top_of_oneBased
    {Ω : Type u} [MeasurableSpace Ω] {P : Measure Ω} [IsFiniteMeasure P]
    {X : ℕ -> Ω -> ℝ} {A : ℝ}
