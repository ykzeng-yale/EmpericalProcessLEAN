        μsign
  Urandom :
    ∀ M n, VdVWMeasurableCover (μsign.prod (vdVWProductMeasure P n))
      (fun z : Ωsign × SampleAt Observation n => ENNReal.ofReal
        (vdVWWeightedClassSupremum indexClass
          (vdVWTruncatedClassFun classFun envelope M)
