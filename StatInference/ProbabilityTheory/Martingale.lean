              (N.trim (‚ĄĪ.le n)).rnDeriv ((M + N).trim (‚ĄĪ.le n)) x :=
    ae_eq_of_ae_eq_trim (hm := ‚ĄĪ.le n) hratio_trim
  filter_upwards [hderiv, hratio] with x hx_deriv hx_ratio
  rw [‚Üź hx_deriv, hx_ratio]

