    {A X : ‚Ąē -> ő© -> ‚ĄĚ} {f : ‚ĄĚ -> ‚ĄĚ}
    (hA_predictable : IsStronglyPredictable ‚ĄĪ A)
    (hf_cont : Continuous f)
    (hf_one_le : ‚ąÄ n : ‚Ąē, ‚ąÄ ŌČ : ő©, 1 ‚Č§ f (A n ŌČ))
