/--
A product-space measurable-cover transfer for integrated `Phi(x)=x`
comparisons.

If a real comparison is already integrated over the random-sign and sample
spaces, a supplied VdV&W measurable cover of the product target upgrades it to
the corresponding nonnegative outer-expectation bound.  This is the valid
replacement for an over-strong fixed-sample pointwise `hphi_id` assertion.
-/
theorem VdVWOuterExpectation_prod_hphi_id_of_integral_integral_le
    {╬й : Type u} [MeasurableSpace ╬й] {╬╝ : Measure ╬й}
    {Sample : Type v} [MeasurableSpace Sample] {╬╜ : Measure Sample}
    [SFinite ╬╜] {A : тДЭ} {R : ╬й -> Sample -> тДЭ}
    (U : VdVWMeasurableCover (╬╝.prod ╬╜)
      (fun z : ╬й ├Ч Sample => ENNReal.ofReal (R z.1 z.2)))
    (hsectionIntegrable : тИА ╧Й : ╬й, Integrable (R ╧Й) ╬╜)
    (hsectionNonneg : тИА ╧Й : ╬й, 0 тЙдс╡Р[╬╜] R ╧Й)
    (hiterIntegrable :
      Integrable (fun ╧Й : ╬й => тИл sample : Sample, R ╧Й sample тИВ╬╜) ╬╝)
    (hiterNonneg :
      0 тЙдс╡Р[╬╝] fun ╧Й : ╬й => тИл sample : Sample, R ╧Й sample тИВ╬╜)
    (hcomparison :
      A тЙд 2 * тИл ╧Й : ╬й, тИл sample : Sample, R ╧Й sample тИВ╬╜ тИВ╬╝) :
    ENNReal.ofReal A тЙд
      (2 : тДЭтЙе0тИЮ) *
        VdVWOuterExpectation (╬╝.prod ╬╜)
          (fun z : ╬й ├Ч Sample => ENNReal.ofReal (R z.1 z.2)) := by
  have hcomparison_ofReal :
      ENNReal.ofReal A тЙд
        ENNReal.ofReal
          (2 * тИл ╧Й : ╬й, тИл sample : Sample, R ╧Й sample тИВ╬╜ тИВ╬╝) :=
    ENNReal.ofReal_le_ofReal hcomparison
  have hiter_ofReal :
      ENNReal.ofReal
          (тИл ╧Й : ╬й, тИл sample : Sample, R ╧Й sample тИВ╬╜ тИВ╬╝) =
        тИлтБ╗ ╧Й : ╬й,
          ENNReal.ofReal (тИл sample : Sample, R ╧Й sample тИВ╬╜) тИВ╬╝ :=
    MeasureTheory.ofReal_integral_eq_lintegral_ofReal
      hiterIntegrable hiterNonneg
  have hsection_ofReal :
      тИА ╧Й : ╬й,
        ENNReal.ofReal (тИл sample : Sample, R ╧Й sample тИВ╬╜) =
          тИлтБ╗ sample : Sample, ENNReal.ofReal (R ╧Й sample) тИВ╬╜ := by
    intro ╧Й
    exact
      MeasureTheory.ofReal_integral_eq_lintegral_ofReal
        (hsectionIntegrable ╧Й) (hsectionNonneg ╧Й)
  have hscaled_integral :
      ENNReal.ofReal
          (2 * тИл ╧Й : ╬й, тИл sample : Sample, R ╧Й sample тИВ╬╜ тИВ╬╝) =
        (2 : тДЭтЙе0тИЮ) *
          тИлтБ╗ ╧Й : ╬й, тИлтБ╗ sample : Sample,
            ENNReal.ofReal (R ╧Й sample) тИВ╬╜ тИВ╬╝ := by
    calc
      ENNReal.ofReal
          (2 * тИл ╧Й : ╬й, тИл sample : Sample, R ╧Й sample тИВ╬╜ тИВ╬╝)
          =
            ENNReal.ofReal (2 : тДЭ) *
              ENNReal.ofReal
                (тИл ╧Й : ╬й, тИл sample : Sample, R ╧Й sample тИВ╬╜ тИВ╬╝) := by
            rw [ENNReal.ofReal_mul (by norm_num : (0 : тДЭ) тЙд 2)]
      _ =
            (2 : тДЭтЙе0тИЮ) *
              тИлтБ╗ ╧Й : ╬й,
                ENNReal.ofReal (тИл sample : Sample, R ╧Й sample тИВ╬╜) тИВ╬╝ := by
            rw [hiter_ofReal]
            norm_num
      _ =
            (2 : тДЭтЙе0тИЮ) *
              тИлтБ╗ ╧Й : ╬й, тИлтБ╗ sample : Sample,
                ENNReal.ofReal (R ╧Й sample) тИВ╬╜ тИВ╬╝ := by
            congr 1
            simp_rw [hsection_ofReal]
  have htarget_le_cover_iter :
      (тИлтБ╗ ╧Й : ╬й, тИлтБ╗ sample : Sample,
          ENNReal.ofReal (R ╧Й sample) тИВ╬╜ тИВ╬╝) тЙд
        тИлтБ╗ ╧Й : ╬й, тИлтБ╗ sample : Sample, U (╧Й, sample) тИВ╬╜ тИВ╬╝ := by
    refine lintegral_mono ?_
    intro ╧Й
    exact lintegral_mono fun sample => U.majorizes (╧Й, sample)
  have hcover_prod :
      тИлтБ╗ z : ╬й ├Ч Sample, U z тИВ(╬╝.prod ╬╜) =
        тИлтБ╗ ╧Й : ╬й, тИлтБ╗ sample : Sample, U (╧Й, sample) тИВ╬╜ тИВ╬╝ := by
    exact
      MeasureTheory.lintegral_prod
        (fun z : ╬й ├Ч Sample => U z) U.measurable_toFun.aemeasurable
  have htarget_le_outer :
      (тИлтБ╗ ╧Й : ╬й, тИлтБ╗ sample : Sample,
          ENNReal.ofReal (R ╧Й sample) тИВ╬╜ тИВ╬╝) тЙд
        VdVWOuterExpectation (╬╝.prod ╬╜)
          (fun z : ╬й ├Ч Sample => ENNReal.ofReal (R z.1 z.2)) := by
    calc
      (тИлтБ╗ ╧Й : ╬й, тИлтБ╗ sample : Sample,
          ENNReal.ofReal (R ╧Й sample) тИВ╬╜ тИВ╬╝)
          тЙд тИлтБ╗ ╧Й : ╬й, тИлтБ╗ sample : Sample, U (╧Й, sample) тИВ╬╜ тИВ╬╝ :=
            htarget_le_cover_iter
      _ = тИлтБ╗ z : ╬й ├Ч Sample, U z тИВ(╬╝.prod ╬╜) := hcover_prod.symm
      _ =
          VdVWOuterExpectation (╬╝.prod ╬╜)
            (fun z : ╬й ├Ч Sample => ENNReal.ofReal (R z.1 z.2)) :=
            (VdVWOuterExpectation_eq_lintegral_cover U).symm
  calc
    ENNReal.ofReal A
        тЙд ENNReal.ofReal
            (2 * тИл ╧Й : ╬й, тИл sample : Sample, R ╧Й sample тИВ╬╜ тИВ╬╝) :=
          hcomparison_ofReal
    _ =
        (2 : тДЭтЙе0тИЮ) *
          тИлтБ╗ ╧Й : ╬й, тИлтБ╗ sample : Sample,
            ENNReal.ofReal (R ╧Й sample) тИВ╬╜ тИВ╬╝ :=
          hscaled_integral
    _ тЙд
        (2 : тДЭтЙе0тИЮ) *
          VdVWOuterExpectation (╬╝.prod ╬╜)
            (fun z : ╬й ├Ч Sample => ENNReal.ofReal (R z.1 z.2)) := by
          simpa [mul_comm] using
            (mul_le_mul_right htarget_le_outer (2 : тДЭтЙе0тИЮ))

/--
The integrated random-sign symmetrization comparison as a product-space
