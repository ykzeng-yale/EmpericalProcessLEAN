        (Real.sqrt_lt' ha_pos).1 hsqrt
      have hevent :
          {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} =
            {ŌČ : ő© | b < Ainf ŌČ} := by
        ext ŌČ
        simp [hba2]
      change
        P {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} /
            (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě) =
          (Set.Ioi (Real.sqrt b)).indicator
            (fun a : ‚ĄĚ => C / (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě)) a
      have ha_mem : a ‚ąą Set.Ioi (Real.sqrt b) := hsqrt
