    {third : WithLp 2 (E₁ × E₂) -> WithLp 2 (E₁ × E₂) ->
      WithLp 2 (E₁ × E₂) -> ℝ}
    {selector : E₁ -> E₂} {invHyy : E₁ -> E₂ →L[ℝ] E₂}
    {x y : E₁} {M nu : ℝ}
