theorem durrett2019_theorem_2_5_13_weighted_baseAbsAnnulusIntegral_le_mass_weight
    {Ω : Type u} [MeasurableSpace Ω] {P : Measure Ω} [IsFiniteMeasure P]
    {X0 : Ω -> ℝ} {a : ℕ -> ℝ}
