    exact hA0_le
  obtain ‚ü®k, hk‚ü© := Nat.exists_eq_add_one_of_ne_zero hzero
  have hnot :
      (fun n ŌČ => A (n + 1) ŌČ) k ŌČ ‚ąČ Set.Ioi (a ^ 2) := by
    have hk_lt : (k : ‚Ąē‚ąě) < ŌĄ ŌČ := by
      suffices (k : ‚Ąē‚ąě) < min (n : ‚Ąē‚ąě) (ŌĄ ŌČ) from
        this.trans_le (min_le_right _ _)
      have h_top : min (n : ‚Ąē‚ąě) (ŌĄ ŌČ) ‚Č† ‚ä§ :=
        ne_top_of_le_ne_top (by simp) (min_le_left _ _)
      have hk_nat : k < (min (n : ‚Ąē‚ąě) (ŌĄ ŌČ)).untopA := by
        change k < p
        rw [hk]
        exact Nat.lt_succ_self k
      exact (WithTop.lt_untopA_iff h_top).1 hk_nat
    exact
      notMem_of_lt_hittingAfter
        (u := fun n ŌČ => A (n + 1) ŌČ) (s := Set.Ioi (a ^ 2)) (n := 0)
        (ŌČ := ŌČ) hk_lt (Nat.zero_le k)
