  have hden_pos : 0 < 1 - M * r := by nlinarith
  have hupper_nonneg : 0 ≤ ((1 - M * r)⁻¹) ^ (2 : ℕ) := sq_nonneg _
  have hbase :=
    dualLocalNorm_le_sqrt_mul_dualLocalNorm_of_inverseHessianQuadraticUpper
      (invHess := invHess) (x := x) (y := y)
