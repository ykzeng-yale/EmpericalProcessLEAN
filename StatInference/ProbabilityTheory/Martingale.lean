    ¬∑ have hnot_ba2 : ¬¨ b < a ^ 2 := by
        intro hba2
        exact hsqrt ((Real.sqrt_lt' ha_pos).2 hba2)
      have hevent :
          {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} = ‚ąÖ := by
        ext ŌČ
        simp [hnot_ba2]
      change
        P {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} /
            (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě) =
          (Set.Ioi (Real.sqrt b)).indicator
            (fun a : ‚ĄĚ => C / (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě)) a
      have ha_not_mem : a ‚ąČ Set.Ioi (Real.sqrt b) := hsqrt
      rw [Set.indicator_of_notMem ha_not_mem, hevent, measure_empty]
      simp
  calc
    (‚ąę‚ĀĽ a in Set.Ioi (0 : ‚ĄĚ),
        P {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} /
          (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě) ‚ąāvolume)
        = ‚ąę‚ĀĽ a in Set.Ioi (0 : ‚ĄĚ),
            (Set.Ioi (Real.sqrt b)).indicator
              (fun a : ‚ĄĚ => C / (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě)) a
              ‚ąāvolume := by
          exact setLIntegral_congr_fun measurableSet_Ioi hpoint
    _ = ‚ąę‚ĀĽ a in Set.Ioi (Real.sqrt b),
          C / (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě) ‚ąāvolume :=
        durrett2019_theorem_4_5_7_lintegral_Ioi_zero_indicator_Ioi_sqrt
          hb (fun a : ‚ĄĚ => C / (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě))
    _ = C * ENNReal.ofReal (b ^ (((1 : ‚ĄĚ) / 2) - 1)) :=
        durrett2019_theorem_4_5_7_const_div_lintegral_Ioi_sqrt_toNNReal_sq
          hb C hC_ne_top

