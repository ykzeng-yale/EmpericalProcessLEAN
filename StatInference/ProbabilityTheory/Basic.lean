        ∑ k ∈ Finset.range N, major k := hsum_major
    _ = (a m) ^ 2 * ∑ n ∈ Finset.Ico m (N + 1), b n := hmajor_reindex
    _ ≤ (a m) ^ 2 * (2 * (m : ℝ) / ((a m) ^ 2)) := by
          exact mul_le_mul_of_nonneg_left htail (sq_nonneg _)
    _ = 2 * (m : ℝ) := by
          field_simp [ne_of_gt ham_pos]

