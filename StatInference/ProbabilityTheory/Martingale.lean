-/
theorem durrett2019_theorem_4_3_8_sqrtDiff_sq_add_two_mul_eq_add
    {a b : ‚ĄĚ‚Č•0‚ąě} (ha : a ‚Č† ‚ąě) (hb : b ‚Č† ‚ąě) :
