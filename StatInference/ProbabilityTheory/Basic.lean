  have hn_ne : (n : ℝ) ≠ 0 := hn_pos.ne'
  have ha_le : a n ≤ C * (n : ℝ) := by
    calc
      a n = (a n / (n : ℝ)) * (n : ℝ) := by field_simp [hn_ne]
      _ ≤ C * (n : ℝ) :=
        mul_le_mul_of_nonneg_right (hbound n hn) hn_pos.le
  exact measureReal_mono fun ω hω => ha_le.trans hω

/--
