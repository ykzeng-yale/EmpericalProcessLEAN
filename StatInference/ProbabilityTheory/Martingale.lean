/--
Durrett 2019, Theorem 4.5.5 source support: the textbook tail integrand
`(max t 1)^{-2}` is integrable on `[0,‚ąě)`.
-/
theorem durrett2019_theorem_4_5_5_max_one_inv_sq_integrableOn_Ici :
    IntegrableOn (fun t : ‚ĄĚ => (max t (1 : ‚ĄĚ))‚ĀĽ¬Ļ ^ 2) (Set.Ici 0) volume := by
  have hsplit : Set.Ici (0 : ‚ĄĚ) = Set.Icc 0 1 ‚ą™ Set.Ioi 1 := by
    exact (Set.Icc_union_Ioi_eq_Ici (show (0 : ‚ĄĚ) ‚Č§ 1 by norm_num)).symm
  rw [hsplit, integrableOn_union]
  constructor
  ¬∑ exact
      ((continuous_id.max continuous_const).inv‚āÄ
        (by
          intro x
          exact (zero_lt_one.trans_le (le_max_right x (1 : ‚ĄĚ))).ne')).pow 2 |>.integrableOn_Icc
  ¬∑ refine
      (integrableOn_Ioi_rpow_of_lt
        (a := (-2 : ‚ĄĚ)) (c := (1 : ‚ĄĚ)) (by norm_num) (by norm_num)).congr_fun
        ?_ measurableSet_Ioi
    intro x hx
    have hx1 : 1 ‚Č§ x := le_of_lt hx
    change x ^ (-2 : ‚ĄĚ) = (max x (1 : ‚ĄĚ))‚ĀĽ¬Ļ ^ 2
    rw [max_eq_left hx1]
    rw [‚Üź Real.rpow_natCast]
    rw [‚Üź Real.rpow_neg_one x]
    rw [‚Üź Real.rpow_mul]
    ¬∑ norm_num
    ¬∑ exact le_trans (by norm_num : (0 : ‚ĄĚ) ‚Č§ 1) hx1

/--
Durrett 2019, Theorem 4.5.5 source support: the textbook tail integral
`‚ąę_0^‚ąě (max t 1)^{-2} dt` has exact value `2`.
-/
theorem durrett2019_theorem_4_5_5_integral_max_one_inv_sq_Ici :
    ‚ąę t in Set.Ici (0 : ‚ĄĚ), (max t (1 : ‚ĄĚ))‚ĀĽ¬Ļ ^ 2 ‚ąāvolume = 2 := by
  let g : ‚ĄĚ -> ‚ĄĚ := fun t => (max t (1 : ‚ĄĚ))‚ĀĽ¬Ļ ^ 2
  have hIcc_int : IntegrableOn g (Set.Icc (0 : ‚ĄĚ) 1) volume := by
    exact
      ((continuous_id.max continuous_const).inv‚āÄ
        (by
          intro x
          exact (zero_lt_one.trans_le (le_max_right x (1 : ‚ĄĚ))).ne')).pow 2 |>.integrableOn_Icc
  have hIoi_int : IntegrableOn g (Set.Ioi (1 : ‚ĄĚ)) volume := by
    refine
      (integrableOn_Ioi_rpow_of_lt
        (a := (-2 : ‚ĄĚ)) (c := (1 : ‚ĄĚ)) (by norm_num) (by norm_num)).congr_fun
        ?_ measurableSet_Ioi
    intro x hx
    have hx1 : 1 ‚Č§ x := le_of_lt hx
    change x ^ (-2 : ‚ĄĚ) = (max x (1 : ‚ĄĚ))‚ĀĽ¬Ļ ^ 2
    rw [max_eq_left hx1]
    rw [‚Üź Real.rpow_natCast]
    rw [‚Üź Real.rpow_neg_one x]
    rw [‚Üź Real.rpow_mul]
    ¬∑ norm_num
    ¬∑ exact le_trans (by norm_num : (0 : ‚ĄĚ) ‚Č§ 1) hx1
  have hdisj : Disjoint (Set.Icc (0 : ‚ĄĚ) 1) (Set.Ioi (1 : ‚ĄĚ)) := by
    rw [Set.disjoint_left]
    intro x hx hx'
    exact (not_lt_of_ge hx.2) hx'
  rw [‚Üź Set.Icc_union_Ioi_eq_Ici (show (0 : ‚ĄĚ) ‚Č§ 1 by norm_num)]
  rw [MeasureTheory.setIntegral_union hdisj measurableSet_Ioi hIcc_int hIoi_int]
  have hIcc_eq : ‚ąę t in Set.Icc (0 : ‚ĄĚ) 1, g t ‚ąāvolume = 1 := by
    rw [MeasureTheory.setIntegral_congr_ae
      (s := Set.Icc (0 : ‚ĄĚ) 1) (g := fun _ => (1 : ‚ĄĚ)) measurableSet_Icc]
    ¬∑ rw [setIntegral_const]
      simp [measureReal_def, Real.volume_Icc]
    ¬∑ filter_upwards with t ht
      have ht1 : t ‚Č§ 1 := ht.2
      simp [g, max_eq_right ht1]
  have hIoi_eq : ‚ąę t in Set.Ioi (1 : ‚ĄĚ), g t ‚ąāvolume = 1 := by
    have hcongr :
        ‚ąÄŠĶź t : ‚ĄĚ ‚ąāvolume, t ‚ąą Set.Ioi (1 : ‚ĄĚ) -> g t = t ^ (-2 : ‚ĄĚ) := by
      filter_upwards with t ht
      have ht1 : 1 ‚Č§ t := le_of_lt ht
      change (max t (1 : ‚ĄĚ))‚ĀĽ¬Ļ ^ 2 = t ^ (-2 : ‚ĄĚ)
      rw [max_eq_left ht1]
      rw [‚Üź Real.rpow_natCast]
      rw [‚Üź Real.rpow_neg_one t]
      rw [‚Üź Real.rpow_mul]
      ¬∑ norm_num
      ¬∑ exact le_trans (by norm_num : (0 : ‚ĄĚ) ‚Č§ 1) ht1
    rw [MeasureTheory.setIntegral_congr_ae
      (s := Set.Ioi (1 : ‚ĄĚ)) (g := fun t : ‚ĄĚ => t ^ (-2 : ‚ĄĚ)) measurableSet_Ioi hcongr]
    rw [integral_Ioi_rpow_of_lt (a := (-2 : ‚ĄĚ)) (c := (1 : ‚ĄĚ))]
    ¬∑ norm_num
    ¬∑ norm_num
    ¬∑ norm_num
  rw [hIcc_eq, hIoi_eq]
  norm_num

