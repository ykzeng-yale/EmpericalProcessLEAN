    (htrunc : TendstoInMeasure P
      (fun n ω =>
        (durrett2019_theorem_2_2_11_truncatedRowSum X b n ω -
          durrett2019_theorem_2_2_11_truncatedMeanRowSum P X b n) / b n)
      atTop (fun _ => 0)) :
