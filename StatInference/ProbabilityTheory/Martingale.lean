          durrett2019_theorem_4_3_8_cylinderLikelihood (Finset.range n) q :=
    durrett2019_theorem_4_3_8_cylinderLikelihood_ae_eq_trimmedPrefix_rnDeriv
      (őľ := őľ) (őĹ := őĹ) (q := q) hq hőľ n
  have hratio_trim :
      (fun x =>
        (M.trim (‚ĄĪ.le n)).rnDeriv (N.trim (‚ĄĪ.le n)) x)
        =ŠĶź[N.trim (‚ĄĪ.le n)]
