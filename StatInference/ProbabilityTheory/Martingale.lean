/--
Durrett 2019, Theorem 4.5.2 integral bridge: a stopped increasing process
bounded by `C`, together with the stopped square/increasing-process identity,
gives the stopped terminal second-moment bound.
-/
theorem durrett2019_theorem_4_5_2_stopped_square_integral_le_of_stopped_increasing_le
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] [IsProbabilityMeasure P]
    {‚ĄĪ : Filtration ‚Ąē mő©} {X A : ‚Ąē -> ő© -> ‚ĄĚ} {N : ő© -> ‚Ąē‚ąě} {C : ‚ĄĚ}
    (hN : IsStoppingTime ‚ĄĪ N)
    (hA_int : ‚ąÄ n, Integrable (A n) P)
    (hSquare_eq_A :
      ‚ąÄ n,
        (‚ąę ŌČ, stoppedProcess X N n ŌČ ^ 2 ‚ąāP) =
          ‚ąę ŌČ, stoppedProcess A N n ŌČ ‚ąāP)
    (hA_le : ‚ąÄ n, stoppedProcess A N n ‚Č§ŠĶź[P] fun _ => C) :
    ‚ąÄ n, (‚ąę ŌČ, stoppedProcess X N n ŌČ ^ 2 ‚ąāP) ‚Č§ C := by
  intro n
  have hA_stopped_int : Integrable (stoppedProcess A N n) P :=
    integrable_stoppedProcess (őĻ := ‚Ąē) hN hA_int n
  have hconst_int : Integrable (fun _ : ő© => C) P := integrable_const C
  have hA_integral_le :
      (‚ąę ŌČ, stoppedProcess A N n ŌČ ‚ąāP) ‚Č§ ‚ąę _ : ő©, C ‚ąāP :=
    integral_mono_ae hA_stopped_int hconst_int (hA_le n)
  calc
    (‚ąę ŌČ, stoppedProcess X N n ŌČ ^ 2 ‚ąāP)
        = ‚ąę ŌČ, stoppedProcess A N n ŌČ ‚ąāP := hSquare_eq_A n
    _ ‚Č§ ‚ąę _ : ő©, C ‚ąāP := hA_integral_le
    _ = C := by
      simp [integral_const, probReal_univ, smul_eq_mul]

