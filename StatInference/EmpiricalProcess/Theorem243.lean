    {Observation : Type u} {Index : Type v}
    {indexClass : Set Index} {classFun : Index -> Observation -> тДЭ}
    {n : тДХ} (sample : SampleAt Observation (n + 1))
    (hterm :
      тИА index, index тИИ indexClass ->
        |vdVWWeightedSampleSum classFun
          (fun _ : Fin (n + 1) => ((n + 1 : тДХ) : тДЭ)тБ╗┬╣) index sample| тЙд
          ((n + 1 : тДХ) : тДЭ)тБ╗┬╣ *
            тИС omitted : Fin (n + 1),
              vdVWWeightedClassSupremum indexClass classFun
                (fun _ : Fin n => (n : тДЭ)тБ╗┬╣)
                (omitted.removeNth sample)) :
    vdVWWeightedClassSupremum indexClass classFun
      (fun _ : Fin (n + 1) => ((n + 1 : тДХ) : тДЭ)тБ╗┬╣) sample тЙд
      ((n + 1 : тДХ) : тДЭ)тБ╗┬╣ *
        тИС omitted : Fin (n + 1),
          vdVWWeightedClassSupremum indexClass classFun
