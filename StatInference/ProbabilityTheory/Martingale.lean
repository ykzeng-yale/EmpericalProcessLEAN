theorem
    durrett2019_theorem_4_5_7_min_terminal_lintegral_eq_tail_cut_lintegral
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©} [IsFiniteMeasure P]
    {Ainf : ő© -> ‚ĄĚ}
    (hAinf_nonneg : 0 ‚Č§ŠĶź[P] Ainf)
    (hAinf_int : Integrable Ainf P)
    (a : ‚ĄĚ) :
    ENNReal.ofReal (‚ąę ŌČ, min (Ainf ŌČ) (a ^ 2) ‚ąāP) =
      ‚ąę‚ĀĽ b in Set.Ioi (0 : ‚ĄĚ),
        P {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} := by
  have hMin_nonneg :
      0 ‚Č§ŠĶź[P] fun ŌČ => min (Ainf ŌČ) (a ^ 2) := by
    filter_upwards [hAinf_nonneg] with ŌČ hŌČ
    exact le_min hŌČ (sq_nonneg a)
  have hMin_int : Integrable (fun ŌČ => min (Ainf ŌČ) (a ^ 2)) P := by
    simpa [Pi.inf_apply] using hAinf_int.inf (integrable_const (a ^ 2))
  have hleft :
      ENNReal.ofReal (‚ąę ŌČ, min (Ainf ŌČ) (a ^ 2) ‚ąāP) =
        ‚ąę‚ĀĽ ŌČ, ENNReal.ofReal (min (Ainf ŌČ) (a ^ 2)) ‚ąāP :=
    ofReal_integral_eq_lintegral_ofReal hMin_int hMin_nonneg
  have hlayer :
      (‚ąę‚ĀĽ ŌČ, ENNReal.ofReal (min (Ainf ŌČ) (a ^ 2)) ‚ąāP) =
        ‚ąę‚ĀĽ b in Set.Ioi (0 : ‚ĄĚ),
          P {ŌČ : ő© | b < min (Ainf ŌČ) (a ^ 2)} :=
    StatInference.ProbabilityMeasure.lintegral_eq_lintegral_tail_lt
      (őľ := P) (X := fun ŌČ => min (Ainf ŌČ) (a ^ 2))
      hMin_nonneg hMin_int.aestronglyMeasurable.aemeasurable
  calc
    ENNReal.ofReal (‚ąę ŌČ, min (Ainf ŌČ) (a ^ 2) ‚ąāP)
        = ‚ąę‚ĀĽ ŌČ, ENNReal.ofReal (min (Ainf ŌČ) (a ^ 2)) ‚ąāP := hleft
    _ = ‚ąę‚ĀĽ b in Set.Ioi (0 : ‚ĄĚ),
          P {ŌČ : ő© | b < min (Ainf ŌČ) (a ^ 2)} := hlayer
    _ = ‚ąę‚ĀĽ b in Set.Ioi (0 : ‚ĄĚ),
          P {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} := by
      refine MeasureTheory.lintegral_congr_ae ?_
      filter_upwards [] with b
      apply MeasureTheory.measure_congr
      filter_upwards [] with ŌČ
      exact propext lt_min_iff

