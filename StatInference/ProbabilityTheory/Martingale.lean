            ((ENNReal.ofReal (p - 1))⁻¹ *
              (T ^ (1 / p) * M ^ (1 / q))) := hAssembled
      _ =
          (ENNReal.ofReal p * (ENNReal.ofReal (p - 1))⁻¹) *
            (T ^ (1 / p) * M ^ (1 / q)) := by
            ac_rfl
  have hScalar :
      M ≤
        ((ENNReal.ofReal p * (ENNReal.ofReal (p - 1))⁻¹) *
