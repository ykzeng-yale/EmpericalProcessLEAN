    (hξ_memLp_two : ∀ n, MemLp (ξ n) (2 : ℝ≥0∞) P)
    (hξ_indep : _root_.ProbabilityTheory.iIndepFun ξ P)
    (hξ_mean_zero : ∀ n, (∫ ω, ξ n ω ∂P) = 0)
    (hξ_second_moment : ∀ n, (∫ ω, ξ n ω ^ 2 ∂P) = sigmaSq n)
