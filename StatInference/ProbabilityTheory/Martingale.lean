    (hq : ‚ąÄ i, Measurable (q i)) {X : (őĻ -> S) -> ‚ĄĚ‚Č•0‚ąě}
    (hlim :
      ‚ąÄŠĶź x ‚ąāMeasure.infinitePi őĹ,
        Tendsto
          (fun n => (durrett2019_theorem_4_3_8_cylinderLikelihood (Iseq n) q x).toReal)
          atTop (ūĚďĚ ((X x).toReal)))
    (hpair :
      Tendsto
        (fun n =>
          Filter.liminf
