          ENNReal.ofReal (epsilon / 3))
        atTop (𝓝 0) := by
    have hdiv :=
      ENNReal.Tendsto.div_const htailOfReal (Or.inr hden_ne_zero)
    simpa [ENNReal.zero_div] using hdiv
