            (тИС i : Fin n, small (sample i)) := by
      rw [тЖР Finset.sum_add_distrib]
      exact Finset.sum_congr rfl fun i _hi => hdecomp (sample i)
    rw [hsum_decomp]
    ring
  have hupper :
      empiricalAverage sample envelope тЙд
        empiricalAverage sample tail + K / 2 := by
    rw [havg_decomp]
