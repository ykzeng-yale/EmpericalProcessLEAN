  have hIoi_int : IntegrableOn g (Set.Ioi (1 : ℝ)) volume := by
    refine
      (integrableOn_Ioi_rpow_of_lt
        (a := (-2 : ℝ)) (c := (1 : ℝ)) (by norm_num) (by norm_num)).congr_fun
        ?_ measurableSet_Ioi
