theorem durrett2019_theorem_4_2_8_martingale_transform_nonnegative
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {őľ : Measure ő©} [IsFiniteMeasure őľ] {‚ĄĪ : Filtration ‚Ąē mő©}
    {H X : ‚Ąē -> ő© -> ‚ĄĚ} {R : ‚ĄĚ}
    (hX : Martingale X ‚ĄĪ őľ)
