/--
Durrett 2019, Exercise 4.4.11 bounded-variance support: a uniform second
moment bound and summable inverse-square normalizer imply the scaled
square-increment summability consumed by the transform route.
-/
theorem durrett2019_exercise_4_4_11_scaled_summable_of_variance_bound
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©}
    {H X : ‚Ąē -> ő© -> ‚ĄĚ} {b : ‚Ąē -> ‚ĄĚ} {K : ‚ĄĚ}
    (hH_eq : ‚ąÄ n ŌČ, H n ŌČ = (b n)‚ĀĽ¬Ļ)
    (hvariance_bound :
      ‚ąÄ k : ‚Ąē,
        (‚ąę ŌČ, (X (k + 1) ŌČ - X k ŌČ) ^ 2 ‚ąāP) ‚Č§ K)
    (hb_inv_sq_summable :
      Summable fun k : ‚Ąē => ((b (k + 1))‚ĀĽ¬Ļ) ^ 2) :
    Summable fun k : ‚Ąē =>
      ‚ąę ŌČ, (H (k + 1) ŌČ * (X (k + 1) ŌČ - X k ŌČ)) ^ 2 ‚ąāP := by
  refine Summable.of_nonneg_of_le (fun k => integral_nonneg fun ŌČ => sq_nonneg _) ?_
    (hb_inv_sq_summable.mul_left K)
  intro k
  have hscale_nonneg : 0 ‚Č§ ((b (k + 1))‚ĀĽ¬Ļ) ^ 2 := sq_nonneg _
  have hscaled_eq :
      (‚ąę ŌČ, (H (k + 1) ŌČ * (X (k + 1) ŌČ - X k ŌČ)) ^ 2 ‚ąāP) =
        ((b (k + 1))‚ĀĽ¬Ļ) ^ 2 *
          ‚ąę ŌČ, (X (k + 1) ŌČ - X k ŌČ) ^ 2 ‚ąāP := by
    calc
      (‚ąę ŌČ, (H (k + 1) ŌČ * (X (k + 1) ŌČ - X k ŌČ)) ^ 2 ‚ąāP)
          = ‚ąę ŌČ,
              ((b (k + 1))‚ĀĽ¬Ļ) ^ 2 *
                (X (k + 1) ŌČ - X k ŌČ) ^ 2 ‚ąāP := by
              refine integral_congr_ae (ae_of_all P fun ŌČ => ?_)
              change (H (k + 1) ŌČ * (X (k + 1) ŌČ - X k ŌČ)) ^ 2 =
                ((b (k + 1))‚ĀĽ¬Ļ) ^ 2 * (X (k + 1) ŌČ - X k ŌČ) ^ 2
              rw [hH_eq (k + 1) ŌČ]
              ring
      _ = ((b (k + 1))‚ĀĽ¬Ļ) ^ 2 *
            ‚ąę ŌČ, (X (k + 1) ŌČ - X k ŌČ) ^ 2 ‚ąāP := by
              rw [integral_const_mul]
  rw [hscaled_eq]
  calc
    ((b (k + 1))‚ĀĽ¬Ļ) ^ 2 *
        ‚ąę ŌČ, (X (k + 1) ŌČ - X k ŌČ) ^ 2 ‚ąāP
        ‚Č§ ((b (k + 1))‚ĀĽ¬Ļ) ^ 2 * K :=
          mul_le_mul_of_nonneg_left (hvariance_bound k) hscale_nonneg
    _ = K * ((b (k + 1))‚ĀĽ¬Ļ) ^ 2 := by ring

