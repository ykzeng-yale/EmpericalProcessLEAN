-/
theorem
    durrett2019_theorem_4_5_7_tail_cut_weighted_kernel_measurable
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©} [SFinite P]
    {Ainf : ő© -> ‚ĄĚ}
    (hAinf_meas : Measurable Ainf) :
    Measurable (Function.uncurry fun a b : ‚ĄĚ =>
      P {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} /
        (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě)) := by
  let s : Set ((‚ĄĚ √ó ‚ĄĚ) √ó ő©) :=
