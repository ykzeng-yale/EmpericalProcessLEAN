    (hνidentity :
      ∀ {A : Set Ω}, MeasurableSet A ->
        ν.real A =
          ∫ ω in A, (Y ω).toReal ∂μ + ν.real (A ∩ {ω | Y ω = ∞}))
    (hμtop : μ {ω | X ω = ∞} = 0)
    (hνtop : ν {ω | Y ω = ∞} = 0) :
    μ ≪ ν ∧ ν ≪ μ := by
  exact
    ⟨durrett2019_theorem_4_3_8_absolutelyContinuous_of_source_real_identity_no_top_mass
        (μ := μ) (ν := ν) (X := X) hμidentity hμtop,
      durrett2019_theorem_4_3_8_absolutelyContinuous_of_source_real_identity_no_top_mass
        (μ := ν) (ν := μ) (X := Y) hνidentity hνtop⟩

