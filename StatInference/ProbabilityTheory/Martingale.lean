/--
Durrett 2019, `L^2` support: an ordinary real second-moment bound gives the
corresponding mathlib `eLpNorm ¬∑ 2` bound.
-/
theorem durrett2019_eLpNorm_two_le_of_integral_sq_le
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©} [IsFiniteMeasure P]
    {Y : ő© -> ‚ĄĚ} {C : ‚ĄĚ}
    (hY : MemLp Y (2 : ‚ĄĚ‚Č•0‚ąě) P)
    (hbound : (‚ąę ŌČ, Y ŌČ ^ 2 ‚ąāP) ‚Č§ C) :
    eLpNorm Y (2 : ‚ĄĚ‚Č•0‚ąě) P ‚Č§ ENNReal.ofReal (C ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ)) := by
  have h_eq :
      eLpNorm Y (2 : ‚ĄĚ‚Č•0‚ąě) P =
        ENNReal.ofReal
          ((‚ąę ŌČ, ‚ÄĖY ŌČ‚ÄĖ ^ (2 : ‚ĄĚ‚Č•0‚ąě).toReal ‚ąāP) ^
            (2 : ‚ĄĚ‚Č•0‚ąě).toReal‚ĀĽ¬Ļ) := by
    exact
      MemLp.eLpNorm_eq_integral_rpow_norm
        (f := Y) (p := (2 : ‚ĄĚ‚Č•0‚ąě)) (by norm_num) (by norm_num) hY
  rw [h_eq]
  apply ENNReal.ofReal_le_ofReal
  have hnorm_bound :
      (‚ąę ŌČ, ‚ÄĖY ŌČ‚ÄĖ ^ (2 : ‚ĄĚ‚Č•0‚ąě).toReal ‚ąāP) ‚Č§ C := by
    simpa [Real.norm_eq_abs, Real.rpow_two, sq_abs] using hbound
  have hnorm_nonneg :
      0 ‚Č§ (‚ąę ŌČ, ‚ÄĖY ŌČ‚ÄĖ ^ (2 : ‚ĄĚ‚Č•0‚ąě).toReal ‚ąāP) := by
    refine integral_nonneg (fun ŌČ => ?_)
    positivity
  exact Real.rpow_le_rpow hnorm_nonneg hnorm_bound (by norm_num)

/--
Durrett 2019, `L^2` support: a `lintegral` bound on the pointwise square gives
the corresponding mathlib `eLpNorm ¬∑ 2` bound.
-/
theorem durrett2019_eLpNorm_two_le_of_lintegral_ofReal_sq_le
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©}
    {Y : ő© -> ‚ĄĚ} {C : ‚ĄĚ}
    (hC_nonneg : 0 ‚Č§ C)
    (hbound : (‚ąę‚ĀĽ ŌČ, ENNReal.ofReal (Y ŌČ ^ 2) ‚ąāP) ‚Č§ ENNReal.ofReal C) :
    eLpNorm Y (ENNReal.ofReal (2 : ‚ĄĚ)) P ‚Č§
      ENNReal.ofReal (C ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ)) := by
  have hp_ne_zero : ENNReal.ofReal (2 : ‚ĄĚ) ‚Č† 0 := by
    rw [ne_eq, ENNReal.ofReal_eq_zero]
    norm_num
  have hp_ne_top : ENNReal.ofReal (2 : ‚ĄĚ) ‚Č† ‚ąě := ENNReal.ofReal_ne_top
  have htoReal : (ENNReal.ofReal (2 : ‚ĄĚ)).toReal = 2 := by
    simp
  rw [eLpNorm_eq_lintegral_rpow_enorm_toReal hp_ne_zero hp_ne_top]
  have hsq :
      (‚ąę‚ĀĽ ŌČ, ‚ÄĖY ŌČ‚ÄĖ‚āĎ ^ (ENNReal.ofReal (2 : ‚ĄĚ)).toReal ‚ąāP) =
        ‚ąę‚ĀĽ ŌČ, ENNReal.ofReal (Y ŌČ ^ 2) ‚ąāP := by
    refine lintegral_congr_ae (ae_of_all P fun ŌČ => ?_)
    have hpoint : ‚ÄĖY ŌČ‚ÄĖ‚āĎ ^ (2 : ‚ĄĚ) = ENNReal.ofReal (Y ŌČ ^ 2) := by
      rw [ENNReal.rpow_two]
      calc
        ‚ÄĖY ŌČ‚ÄĖ‚āĎ ^ (2 : ‚Ąē) = (ENNReal.ofReal ‚ÄĖY ŌČ‚ÄĖ) ^ (2 : ‚Ąē) := by
          rw [ofReal_norm_eq_enorm]
        _ = ENNReal.ofReal (‚ÄĖY ŌČ‚ÄĖ ^ 2) := by
          rw [‚Üź ENNReal.ofReal_pow (norm_nonneg (Y ŌČ)) 2]
        _ = ENNReal.ofReal (Y ŌČ ^ 2) := by
          simp [Real.norm_eq_abs, sq_abs]
    simpa [htoReal] using hpoint
  have hlintegral :
      (‚ąę‚ĀĽ ŌČ, ‚ÄĖY ŌČ‚ÄĖ‚āĎ ^ (ENNReal.ofReal (2 : ‚ĄĚ)).toReal ‚ąāP) ‚Č§
        ENNReal.ofReal C := by
    rw [hsq]
    exact hbound
  have hroot :
      ((‚ąę‚ĀĽ ŌČ, ‚ÄĖY ŌČ‚ÄĖ‚āĎ ^ (ENNReal.ofReal (2 : ‚ĄĚ)).toReal ‚ąāP) ^
          (1 / (ENNReal.ofReal (2 : ‚ĄĚ)).toReal)) ‚Č§
        (ENNReal.ofReal C) ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ) := by
    simpa [htoReal] using
      ENNReal.rpow_le_rpow hlintegral (by norm_num : 0 ‚Č§ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ))
  have hright :
      (ENNReal.ofReal C) ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ) =
        ENNReal.ofReal (C ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ)) := by
    rw [ENNReal.ofReal_rpow_of_nonneg hC_nonneg (by norm_num : 0 ‚Č§ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ))]
  exact hroot.trans_eq hright

/--
Durrett 2019, `L^2` support: an `eLpNorm ¬∑ 2` bound by a real radius gives the
ordinary real second-moment bound.
-/
theorem durrett2019_integral_sq_le_of_eLpNorm_two_le_ofReal
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©} [IsFiniteMeasure P]
    {Y : ő© -> ‚ĄĚ} {R : ‚ĄĚ}
    (hY : MemLp Y (2 : ‚ĄĚ‚Č•0‚ąě) P) (hR_nonneg : 0 ‚Č§ R)
    (hLp : eLpNorm Y (2 : ‚ĄĚ‚Č•0‚ąě) P ‚Č§ ENNReal.ofReal R) :
    (‚ąę ŌČ, Y ŌČ ^ 2 ‚ąāP) ‚Č§ R ^ 2 := by
  let I : ‚ĄĚ := ‚ąę ŌČ, ‚ÄĖY ŌČ‚ÄĖ ^ (2 : ‚ĄĚ) ‚ąāP
  have hI_nonneg : 0 ‚Č§ I := by
    dsimp [I]
    refine integral_nonneg (fun ŌČ => ?_)
    positivity
  have h_eq :
      eLpNorm Y (2 : ‚ĄĚ‚Č•0‚ąě) P =
        ENNReal.ofReal (I ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ)) := by
    have hraw :=
      MemLp.eLpNorm_eq_integral_rpow_norm
        (f := Y) (p := (2 : ‚ĄĚ‚Č•0‚ąě)) (by norm_num) (by norm_num) hY
    simpa [I] using hraw
  have hroot_nonneg : 0 ‚Č§ I ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ) :=
    Real.rpow_nonneg hI_nonneg _
  have hroot_le : I ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ) ‚Č§ R := by
    have hle_ofReal :
        ENNReal.ofReal (I ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ)) ‚Č§ ENNReal.ofReal R := by
      simpa [h_eq] using hLp
    have htoReal :=
      ENNReal.toReal_le_of_le_ofReal hR_nonneg hle_ofReal
    simpa [ENNReal.toReal_ofReal hroot_nonneg] using htoReal
  have hsquare :
      (I ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ)) ^ 2 ‚Č§ R ^ 2 :=
    (sq_le_sq‚āÄ hroot_nonneg hR_nonneg).2 hroot_le
  have hleft_eq : (I ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ)) ^ 2 = I := by
    rw [show ((2 : ‚ĄĚ)‚ĀĽ¬Ļ) = (1 / (2 : ‚ĄĚ)) by norm_num]
    rw [‚Üź Real.sqrt_eq_rpow, Real.sq_sqrt hI_nonneg]
  have hI_le : I ‚Č§ R ^ 2 := by
    rw [hleft_eq] at hsquare
    exact hsquare
  simpa [I, Real.norm_eq_abs, Real.rpow_two, sq_abs] using hI_le

/--
Durrett 2019, Theorem 4.5.1 finite-horizon support: Doob's `L^2` maximal
inequality plus a supplied second-moment bound controls the finite running
absolute maximum in `eLpNorm` form.
-/
theorem durrett2019_theorem_4_5_1_runningAbsMax_eLpNorm_two_le_of_integral_sq_le
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] {‚ĄĪ : Filtration ‚Ąē mő©}
    {X : ‚Ąē -> ő© -> ‚ĄĚ} (hX : Martingale X ‚ĄĪ P)
    {n : ‚Ąē} {C : ‚ĄĚ}
    (hXn_memLp_two : MemLp (X n) (2 : ‚ĄĚ‚Č•0‚ąě) P)
    (hXn_sq_le : (‚ąę ŌČ, X n ŌČ ^ 2 ‚ąāP) ‚Č§ C) :
    eLpNorm (durrett2019_runningAbsMax X n) (2 : ‚ĄĚ‚Č•0‚ąě) P ‚Č§
      ENNReal.ofReal (2 : ‚ĄĚ) * ENNReal.ofReal (C ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ)) := by
  have hDoob :=
    durrett2019_theorem_4_4_4_martingale_absMax_eLpNorm_bound
      (P := P) (‚ĄĪ := ‚ĄĪ) (Y := X) hX Real.HolderConjugate.two_two n
  have hTerminal :
      eLpNorm (X n) (2 : ‚ĄĚ‚Č•0‚ąě) P ‚Č§
        ENNReal.ofReal (C ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ)) :=
    durrett2019_eLpNorm_two_le_of_integral_sq_le
      (P := P) (Y := X n) hXn_memLp_two hXn_sq_le
  calc
    eLpNorm (durrett2019_runningAbsMax X n) (2 : ‚ĄĚ‚Č•0‚ąě) P
        ‚Č§ ENNReal.ofReal ((2 : ‚ĄĚ) / (2 - 1)) *
            eLpNorm (X n) (2 : ‚ĄĚ‚Č•0‚ąě) P := by
          simpa [durrett2019_runningAbsMax] using hDoob
    _ ‚Č§ ENNReal.ofReal ((2 : ‚ĄĚ) / (2 - 1)) *
          ENNReal.ofReal (C ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ)) :=
          by
            simpa [mul_comm] using
              mul_le_mul_right hTerminal (ENNReal.ofReal ((2 : ‚ĄĚ) / (2 - 1)))
    _ = ENNReal.ofReal (2 : ‚ĄĚ) * ENNReal.ofReal (C ^ ((2 : ‚ĄĚ)‚ĀĽ¬Ļ)) := by
          norm_num

/--
Durrett 2019, Theorem 4.5.1 finite-horizon support: the finite running
absolute maximum is in `L^2` once the terminal second moment is bounded.
-/
theorem durrett2019_theorem_4_5_1_runningAbsMax_memLp_two_of_integral_sq_le
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] {‚ĄĪ : Filtration ‚Ąē mő©}
    {X : ‚Ąē -> ő© -> ‚ĄĚ} (hX : Martingale X ‚ĄĪ P)
    {n : ‚Ąē} {C : ‚ĄĚ}
    (hXn_memLp_two : MemLp (X n) (2 : ‚ĄĚ‚Č•0‚ąě) P)
