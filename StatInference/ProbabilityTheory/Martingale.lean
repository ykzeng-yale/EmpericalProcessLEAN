  have hnorm : Integrable (fun ŌČ => ‚ÄĖY ŌČ‚ÄĖ ^ (2 : ‚Ąē)) P :=
    hY.integrable_norm_pow'
  exact hnorm.congr (ae_of_all P fun ŌČ => by
