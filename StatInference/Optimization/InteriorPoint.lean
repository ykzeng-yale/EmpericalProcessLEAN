theorem sourceGrad_dualLocalNorm_scaled_le_of_preliminaryPath_barrier
    [CompleteSpace E]
    {s : Set E} {hess invHess : E -> E →L[ℝ] E}
    {phiGrad : E -> E} {third : E -> E -> E -> ℝ}
