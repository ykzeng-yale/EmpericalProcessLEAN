theorem durrett2019_exercise_4_4_11_kronecker_ratio_eq
    {A b : ‚Ąē -> ‚ĄĚ} (hA0 : A 0 = 0) {n : ‚Ąē}
    (hb : b (n + 1) ‚Č† 0) :
    (‚ąĎ k ‚ąą Finset.range (n + 1), b (k + 1) * (A (k + 1) - A k)) / b (n + 1) =
      A (n + 1) -
        (‚ąĎ k ‚ąą Finset.range n, A (k + 1) * (b (k + 2) - b (k + 1))) /
          b (n + 1) := by
  rw [durrett2019_exercise_4_4_11_kronecker_summation_by_parts hA0 n]
  field_simp [hb]

/--
