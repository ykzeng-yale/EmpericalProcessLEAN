    by_cases hsmall : |X0 ω| < a n
    · have hle : |X0 ω| ≤ |a n| := hsmall.le.trans (le_abs_self (a n))
      simpa [hsmall, Real.norm_eq_abs, abs_of_nonneg (abs_nonneg (X0 ω))] using hle
    · simp [hsmall]

/--
