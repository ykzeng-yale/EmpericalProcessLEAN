/--
Durrett 2019, Theorem 4.4.7, orthogonality of martingale increments.  If
`Y` is `‚ĄĪ_m`-measurable and square-integrable, then the increment
`X_n - X_m` is orthogonal to `Y`.
-/
theorem durrett2019_theorem_4_4_7_martingale_increment_mul_integral_eq_zero
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] {‚ĄĪ : Filtration ‚Ąē mő©}
    {X : ‚Ąē -> ő© -> ‚ĄĚ} (hX : Martingale X ‚ĄĪ P)
    (hX_memLp_two : ‚ąÄ k, MemLp (X k) (2 : ‚ĄĚ‚Č•0‚ąě) P)
    {m n : ‚Ąē} (hmn : m ‚Č§ n) {Y : ő© -> ‚ĄĚ}
    (hY_meas : StronglyMeasurable[‚ĄĪ m] Y)
    (hY_memLp_two : MemLp Y (2 : ‚ĄĚ‚Č•0‚ąě) P) :
    (‚ąę ŌČ, (X n ŌČ - X m ŌČ) * Y ŌČ ‚ąāP) = 0 := by
  have hdiff_int : Integrable (fun ŌČ => X n ŌČ - X m ŌČ) P :=
    (hX.integrable n).sub (hX.integrable m)
  have hdiff_memLp :
      MemLp (fun ŌČ => X n ŌČ - X m ŌČ) (2 : ‚ĄĚ‚Č•0‚ąě) P :=
    (hX_memLp_two n).sub (hX_memLp_two m)
  have hYdiff_int :
      Integrable (fun ŌČ => Y ŌČ * (X n ŌČ - X m ŌČ)) P := by
    simpa [Pi.mul_apply] using hY_memLp_two.integrable_mul hdiff_memLp
  have hcond_diff :
      P[(fun ŌČ => X n ŌČ - X m ŌČ) | ‚ĄĪ m] =ŠĶź[P] 0 := by
    refine (condExp_sub (hX.integrable n) (hX.integrable m) (‚ĄĪ m)).trans ?_
    filter_upwards
      [hX.condExp_ae_eq hmn,
       hX.condExp_ae_eq (i := m) (j := m) le_rfl] with
      ŌČ hn hm
    simp [Pi.sub_apply, hn, hm]
  have hpull :
      P[(fun ŌČ => Y ŌČ * (X n ŌČ - X m ŌČ)) | ‚ĄĪ m] =ŠĶź[P]
        fun ŌČ => Y ŌČ * P[(fun ŌČ => X n ŌČ - X m ŌČ) | ‚ĄĪ m] ŌČ := by
    filter_upwards
      [condExp_mul_of_stronglyMeasurable_left hY_meas hYdiff_int hdiff_int]
      with ŌČ hŌČ
    simpa [Pi.mul_apply] using hŌČ
  have hcond_product_zero :
      P[(fun ŌČ => Y ŌČ * (X n ŌČ - X m ŌČ)) | ‚ĄĪ m] =ŠĶź[P] 0 := by
    filter_upwards [hpull, hcond_diff] with ŌČ hpullŌČ hdiffŌČ
    rw [hpullŌČ, hdiffŌČ]
    simp
  have hYdiff_integral_zero :
      (‚ąę ŌČ, Y ŌČ * (X n ŌČ - X m ŌČ) ‚ąāP) = 0 := by
    calc
      (‚ąę ŌČ, Y ŌČ * (X n ŌČ - X m ŌČ) ‚ąāP)
          = ‚ąę ŌČ, P[(fun ŌČ => Y ŌČ * (X n ŌČ - X m ŌČ)) | ‚ĄĪ m] ŌČ ‚ąāP :=
            (integral_condExp (‚ĄĪ.le m)).symm
      _ = 0 := integral_eq_zero_of_ae hcond_product_zero
  calc
    (‚ąę ŌČ, (X n ŌČ - X m ŌČ) * Y ŌČ ‚ąāP)
        = ‚ąę ŌČ, Y ŌČ * (X n ŌČ - X m ŌČ) ‚ąāP := by
          refine integral_congr_ae (ae_of_all P fun ŌČ => ?_)
          ring
    _ = 0 := hYdiff_integral_zero

/--
Durrett 2019, Theorem 4.4.7 increment-increment corollary: disjoint
square-integrable martingale increments have zero covariance.
-/
theorem durrett2019_theorem_4_4_7_martingale_increment_increment_integral_eq_zero
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] {‚ĄĪ : Filtration ‚Ąē mő©}
    {X : ‚Ąē -> ő© -> ‚ĄĚ} (hX : Martingale X ‚ĄĪ P)
    (hX_memLp_two : ‚ąÄ k, MemLp (X k) (2 : ‚ĄĚ‚Č•0‚ąě) P)
    {‚Ąď m n : ‚Ąē} (h‚Ąďm : ‚Ąď ‚Č§ m) (hmn : m ‚Č§ n) :
    (‚ąę ŌČ, (X n ŌČ - X m ŌČ) * (X m ŌČ - X ‚Ąď ŌČ) ‚ąāP) = 0 := by
  exact
    durrett2019_theorem_4_4_7_martingale_increment_mul_integral_eq_zero
      (P := P) (‚ĄĪ := ‚ĄĪ) (X := X) hX hX_memLp_two hmn
      ((hX.stronglyMeasurable m).sub
        ((hX.stronglyMeasurable ‚Ąď).mono (‚ĄĪ.mono h‚Ąďm)))
      ((hX_memLp_two m).sub (hX_memLp_two ‚Ąď))

/--
Durrett 2019, Theorem 4.4.8, conditional variance formula for a
square-integrable martingale.
-/
theorem durrett2019_theorem_4_4_8_martingale_conditional_variance_formula
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] {‚ĄĪ : Filtration ‚Ąē mő©}
    {X : ‚Ąē -> ő© -> ‚ĄĚ} (hX : Martingale X ‚ĄĪ P)
    (hX_memLp_two : ‚ąÄ k, MemLp (X k) (2 : ‚ĄĚ‚Č•0‚ąě) P)
    {m n : ‚Ąē} (hmn : m ‚Č§ n) :
    P[(fun ŌČ => (X n ŌČ - X m ŌČ) ^ 2) | ‚ĄĪ m] =ŠĶź[P]
      fun ŌČ => P[(fun ŌČ => X n ŌČ ^ 2) | ‚ĄĪ m] ŌČ - X m ŌČ ^ 2 := by
  have hXn_sq_int : Integrable (fun ŌČ => X n ŌČ ^ 2) P :=
    durrett2019_integrable_sq_of_memLp_two (P := P) (Y := X n) (hX_memLp_two n)
  have hXm_sq_int : Integrable (fun ŌČ => X m ŌČ ^ 2) P :=
    durrett2019_integrable_sq_of_memLp_two (P := P) (Y := X m) (hX_memLp_two m)
  have hcross_int : Integrable (fun ŌČ => X m ŌČ * X n ŌČ) P := by
    simpa [Pi.mul_apply] using (hX_memLp_two m).integrable_mul (hX_memLp_two n)
  have htwo_cross_int :
      Integrable (fun ŌČ => 2 * (X m ŌČ * X n ŌČ)) P :=
    hcross_int.const_mul 2
  have hPastSq :
      P[(fun ŌČ => X m ŌČ ^ 2) | ‚ĄĪ m] = fun ŌČ => X m ŌČ ^ 2 :=
    condExp_of_stronglyMeasurable (‚ĄĪ.le m) ((hX.stronglyMeasurable m).pow 2)
      hXm_sq_int
  have hPullCross :
      P[(fun ŌČ => X m ŌČ * X n ŌČ) | ‚ĄĪ m] =ŠĶź[P]
        fun ŌČ => X m ŌČ * P[X n | ‚ĄĪ m] ŌČ := by
    filter_upwards
      [condExp_mul_of_stronglyMeasurable_left (hX.stronglyMeasurable m)
        hcross_int (hX.integrable n)] with ŌČ hŌČ
    simpa [Pi.mul_apply] using hŌČ
  have hTwoCross :
      P[(fun ŌČ => 2 * (X m ŌČ * X n ŌČ)) | ‚ĄĪ m] =ŠĶź[P]
        fun ŌČ => 2 * P[(fun ŌČ => X m ŌČ * X n ŌČ) | ‚ĄĪ m] ŌČ := by
    filter_upwards
      [condExp_ofNat (őľ := P) (m := ‚ĄĪ m) 2
        (fun ŌČ => X m ŌČ * X n ŌČ)] with ŌČ hŌČ
    simpa using hŌČ
  have hExpand :
      (fun ŌČ => (X n ŌČ - X m ŌČ) ^ 2) =ŠĶź[P]
        ((fun ŌČ => X n ŌČ ^ 2) - (fun ŌČ => 2 * (X m ŌČ * X n ŌČ))) +
          fun ŌČ => X m ŌČ ^ 2 :=
    ae_of_all P fun ŌČ => by
      simp only [Pi.add_apply, Pi.sub_apply]
      ring_nf
  refine (condExp_congr_ae hExpand).trans ?_
  filter_upwards
    [condExp_add (hXn_sq_int.sub htwo_cross_int) hXm_sq_int (‚ĄĪ m),
     condExp_sub hXn_sq_int htwo_cross_int (‚ĄĪ m),
     hTwoCross,
     hPullCross,
     hX.condExp_ae_eq hmn,
     EventuallyEq.of_eq hPastSq] with
    ŌČ hAdd hSub hTwo hPull hCond hPast
  rw [hAdd]
  simp only [Pi.add_apply]
  rw [hSub]
  simp only [Pi.sub_apply]
  rw [hTwo, hPull, hCond, hPast]
  ring

/--
Durrett 2019, Theorem 4.5.1 increasing-process display: the canonical Doob
predictable part of the square submartingale agrees a.e. with the finite sum of
conditional squared increments.
-/
theorem durrett2019_theorem_4_5_1_predictablePart_square_ae_eq_sum_conditional_variance
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] {‚ĄĪ : Filtration ‚Ąē mő©}
    {X : ‚Ąē -> ő© -> ‚ĄĚ} (hX : Martingale X ‚ĄĪ P)
    (hX_memLp_two : ‚ąÄ n, MemLp (X n) (2 : ‚ĄĚ‚Č•0‚ąě) P) :
    ‚ąÄ n,
      predictablePart (fun k ŌČ => X k ŌČ ^ 2) ‚ĄĪ P n =ŠĶź[P]
        fun ŌČ =>
          ‚ąĎ i ‚ąą Finset.range n,
            P[(fun ŌČ => (X (i + 1) ŌČ - X i ŌČ) ^ 2) | ‚ĄĪ i] ŌČ := by
  intro n
  rw [predictablePart]
  have hsum :
      (‚ąĎ i ‚ąą Finset.range n,
        P[(fun ŌČ => X (i + 1) ŌČ ^ 2) - fun ŌČ => X i ŌČ ^ 2 | ‚ĄĪ i]) =ŠĶź[P]
        (‚ąĎ i ‚ąą Finset.range n,
          P[(fun ŌČ => (X (i + 1) ŌČ - X i ŌČ) ^ 2) | ‚ĄĪ i]) := by
    refine eventuallyEq_sum fun i hi => ?_
    have hXip1_sq_int : Integrable (fun ŌČ => X (i + 1) ŌČ ^ 2) P :=
      durrett2019_integrable_sq_of_memLp_two (P := P) (Y := X (i + 1))
        (hX_memLp_two (i + 1))
    have hXi_sq_int : Integrable (fun ŌČ => X i ŌČ ^ 2) P :=
      durrett2019_integrable_sq_of_memLp_two (P := P) (Y := X i)
        (hX_memLp_two i)
    have hPastSq :
        P[(fun ŌČ => X i ŌČ ^ 2) | ‚ĄĪ i] = fun ŌČ => X i ŌČ ^ 2 :=
      condExp_of_stronglyMeasurable (‚ĄĪ.le i) ((hX.stronglyMeasurable i).pow 2)
        hXi_sq_int
    have hleft :
        P[(fun ŌČ => X (i + 1) ŌČ ^ 2) - fun ŌČ => X i ŌČ ^ 2 | ‚ĄĪ i] =ŠĶź[P]
          fun ŌČ => P[(fun ŌČ => X (i + 1) ŌČ ^ 2) | ‚ĄĪ i] ŌČ - X i ŌČ ^ 2 := by
      refine (condExp_sub hXip1_sq_int hXi_sq_int (‚ĄĪ i)).trans ?_
      exact EventuallyEq.of_eq (by
        ext ŌČ
        simp [Pi.sub_apply, hPastSq])
    have hvar :=
      durrett2019_theorem_4_4_8_martingale_conditional_variance_formula
        (P := P) (‚ĄĪ := ‚ĄĪ) (X := X) hX hX_memLp_two
        (m := i) (n := i + 1) i.le_succ
    exact hleft.trans hvar.symm
  exact hsum.trans (EventuallyEq.of_eq (by ext ŌČ; simp [Finset.sum_apply]))

/--
Durrett 2019, Theorem 4.5.1 source bridge using the textbook increasing
process display: if the finite conditional-variance sums converge a.e. to an
integrable terminal variable `A‚ąě`, then `E (sup_m |X_m|^2) ‚Č§ 4 * E A‚ąě` in
`lintegral` form.
-/
theorem durrett2019_theorem_4_5_1_lintegral_runningAbsSup_sq_le_of_conditionalVariance_tendsto
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] {‚ĄĪ : Filtration ‚Ąē mő©}
    [SigmaFiniteFiltration P ‚ĄĪ]
    {X : ‚Ąē -> ő© -> ‚ĄĚ} (hX : Martingale X ‚ĄĪ P)
    {Ainf : ő© -> ‚ĄĚ}
    (hX_memLp_two : ‚ąÄ n, MemLp (X n) (2 : ‚ĄĚ‚Č•0‚ąě) P)
    (hX0 : X 0 =ŠĶź[P] 0)
    (hAinf_int : Integrable Ainf P)
    (hA_tendsto :
      ‚ąÄŠĶź ŌČ ‚ąāP,
        Tendsto
          (fun n =>
            ‚ąĎ i ‚ąą Finset.range n,
              P[(fun ŌČ => (X (i + 1) ŌČ - X i ŌČ) ^ 2) | ‚ĄĪ i] ŌČ)
          atTop (ūĚďĚ (Ainf ŌČ)))
    (hBdd :
      ‚ąÄŠĶź ŌČ ‚ąāP,
        BddAbove (Set.range fun n => durrett2019_runningAbsMax X n ŌČ)) :
    (‚ąę‚ĀĽ ŌČ, ENNReal.ofReal (durrett2019_runningAbsSup X ŌČ ^ 2) ‚ąāP) ‚Č§
      ENNReal.ofReal (4 * ‚ąę ŌČ, Ainf ŌČ ‚ąāP) := by
  have hdisplay_all :
      ‚ąÄŠĶź ŌČ ‚ąāP,
        ‚ąÄ n,
          predictablePart (fun k ŌČ => X k ŌČ ^ 2) ‚ĄĪ P n ŌČ =
            ‚ąĎ i ‚ąą Finset.range n,
              P[(fun ŌČ => (X (i + 1) ŌČ - X i ŌČ) ^ 2) | ‚ĄĪ i] ŌČ := by
    exact ae_all_iff.2
      (durrett2019_theorem_4_5_1_predictablePart_square_ae_eq_sum_conditional_variance
        (P := P) (‚ĄĪ := ‚ĄĪ) (X := X) hX hX_memLp_two)
  have hpred_tendsto :
      ‚ąÄŠĶź ŌČ ‚ąāP,
        Tendsto
          (fun n => predictablePart (fun k ŌČ => X k ŌČ ^ 2) ‚ĄĪ P n ŌČ)
          atTop (ūĚďĚ (Ainf ŌČ)) := by
    filter_upwards [hdisplay_all, hA_tendsto] with ŌČ hdisplayŌČ htendŌČ
    have hseq :
        (fun n => predictablePart (fun k ŌČ => X k ŌČ ^ 2) ‚ĄĪ P n ŌČ) =
          fun n =>
            ‚ąĎ i ‚ąą Finset.range n,
              P[(fun ŌČ => (X (i + 1) ŌČ - X i ŌČ) ^ 2) | ‚ĄĪ i] ŌČ := by
      funext n
      exact hdisplayŌČ n
    simpa [hseq] using htendŌČ
  exact
    durrett2019_theorem_4_5_1_lintegral_runningAbsSup_sq_le_of_predictablePart_square_tendsto
      (P := P) (‚ĄĪ := ‚ĄĪ) (X := X) hX hX_memLp_two hX0
      hAinf_int hpred_tendsto hBdd

/--
Durrett 2019, Theorem 4.5.2 countable-threshold cover bridge.

If a target event is almost surely covered by countably many threshold events,
and each threshold event carries almost-sure convergence of the martingale
path, then the target event carries almost-sure convergence.
-/
theorem durrett2019_theorem_4_5_2_exists_ae_tendsto_on_event_cover
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©}
    {X : ‚Ąē -> ő© -> ‚ĄĚ} {FiniteVar : Set ő©} {E : ‚Ąē -> Set ő©}
    (hcover : ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą FiniteVar -> ‚ąÉ k, ŌČ ‚ąą E k)
    (hconv : ‚ąÄ k, ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą E k ->
      ‚ąÉ z : ‚ĄĚ, Tendsto (fun n => X n ŌČ) atTop (ūĚďĚ z)) :
    ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą FiniteVar ->
      ‚ąÉ z : ‚ĄĚ, Tendsto (fun n => X n ŌČ) atTop (ūĚďĚ z) := by
  have hconv_all :
      ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÄ k, ŌČ ‚ąą E k ->
        ‚ąÉ z : ‚ĄĚ, Tendsto (fun n => X n ŌČ) atTop (ūĚďĚ z) :=
    ae_all_iff.2 hconv
  filter_upwards [hcover, hconv_all] with ŌČ hcoverŌČ hconvŌČ hFinite
  rcases hcoverŌČ hFinite with ‚ü®k, hk‚ü©
  exact hconvŌČ k hk

/--
Durrett 2019, Theorem 4.5.2 stopped-process event bridge.

Convergence of a stopped process transfers back to the original process on any
event where the stopping time is almost surely infinite.
-/
theorem durrett2019_theorem_4_5_2_stopped_convergence_on_event
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©}
    {X : ‚Ąē -> ő© -> ‚ĄĚ} {N : ő© -> ‚Ąē‚ąě} {E : Set ő©}
    (hStopped : ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÉ z : ‚ĄĚ,
      Tendsto (fun n => stoppedProcess X N n ŌČ) atTop (ūĚďĚ z))
    (hSurvive : ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą E -> N ŌČ = ‚ä§) :
    ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą E ->
      ‚ąÉ z : ‚ĄĚ, Tendsto (fun n => X n ŌČ) atTop (ūĚďĚ z) := by
  have hTransfer :
      ‚ąÄŠĶź ŌČ ‚ąāP, N ŌČ = ‚ä§ ->
        ‚ąÉ z : ‚ĄĚ, Tendsto (fun n => X n ŌČ) atTop (ūĚďĚ z) :=
    durrett2019_theorem_4_3_1_stopped_tendsto_on_survival
      (X := X) (N := N) (őľ := P) hStopped
  filter_upwards [hTransfer, hSurvive] with ŌČ hconvŌČ hsurvŌČ hE
  exact hconvŌČ (hsurvŌČ hE)

/--
Durrett 2019, Theorem 4.5.2 stopped-threshold cover bridge.

This packages the final proof skeleton in the textbook: prove convergence for
each stopped process, prove that each threshold event is contained in the
survival event of its stopping time, and cover `{A‚ąě < ‚ąě}` by those thresholds.
-/
theorem durrett2019_theorem_4_5_2_exists_ae_tendsto_of_stopped_event_cover
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©}
    {X : ‚Ąē -> ő© -> ‚ĄĚ} {N : ‚Ąē -> ő© -> ‚Ąē‚ąě}
    {FiniteVar : Set ő©} {E : ‚Ąē -> Set ő©}
    (hcover : ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą FiniteVar -> ‚ąÉ k, ŌČ ‚ąą E k)
    (hStopped : ‚ąÄ k, ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÉ z : ‚ĄĚ,
      Tendsto (fun n => stoppedProcess X (N k) n ŌČ) atTop (ūĚďĚ z))
    (hSurvive : ‚ąÄ k, ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą E k -> N k ŌČ = ‚ä§) :
    ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą FiniteVar ->
      ‚ąÉ z : ‚ĄĚ, Tendsto (fun n => X n ŌČ) atTop (ūĚďĚ z) := by
  have hconv_events :
      ‚ąÄ k, ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą E k ->
        ‚ąÉ z : ‚ĄĚ, Tendsto (fun n => X n ŌČ) atTop (ūĚďĚ z) := by
    intro k
    exact
      durrett2019_theorem_4_5_2_stopped_convergence_on_event
        (P := P) (X := X) (N := N k) (E := E k)
        (hStopped k) (hSurvive k)
  exact
    durrett2019_theorem_4_5_2_exists_ae_tendsto_on_event_cover
      (P := P) (X := X) (FiniteVar := FiniteVar) (E := E)
      hcover hconv_events

/--
Durrett 2019, Theorem 4.5.2 threshold stopping time:
`N_a = inf {n : A_{n+1} > a^2}`.
-/
noncomputable def durrett2019_theorem_4_5_2_firstPredictableAbove
    {ő© : Type*} (A : ‚Ąē -> ő© -> ‚ĄĚ) (a : ‚ĄĚ) : ő© -> ‚Ąē‚ąě :=
  hittingAfter (fun n ŌČ => A (n + 1) ŌČ) (Set.Ioi (a ^ 2)) 0

/--
Durrett 2019, Theorem 4.5.2 threshold stopping-time bridge.

The textbook uses that `A_{n+1}` is `‚ĄĪ_n`-measurable.  In Lean this is the
adaptedness of the shifted process `n ‚Ü¶ A_{n+1}`.
-/
theorem durrett2019_theorem_4_5_2_firstPredictableAbove_isStoppingTime
    {ő© : Type*} [mő© : MeasurableSpace ő©] {‚ĄĪ : Filtration ‚Ąē mő©}
    {A : ‚Ąē -> ő© -> ‚ĄĚ} (a : ‚ĄĚ)
