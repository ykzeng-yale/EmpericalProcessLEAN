    (hq_pos : ∀ t,
      t ∈ Set.Icc (0 : ℝ) 1 ->
        0 < localNorm hess (hessianSegmentPoint x y t) (y - x))
    (hqderiv : ∀ t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        HasDerivWithinAt
          (fun s : ℝ => localNorm hess (hessianSegmentPoint x y s) (y - x))
          (localNormDeriv t)
          (interior (Set.Icc (0 : ℝ) 1)) t)
    (hderiv_bound : ∀ t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        localNormDeriv t ≤
          M * (localNorm hess (hessianSegmentPoint x y t) (y - x)) ^ (2 : ℕ))
