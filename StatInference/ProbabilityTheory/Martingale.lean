  ¬∑ simpa using
      (stronglyAdapted_const' ‚ĄĪ (fun n : ‚Ąē => (b (n + 1))‚ĀĽ¬Ļ) :
        StronglyAdapted ‚ĄĪ (fun n : ‚Ąē => fun _ : ő© => (b (n + 1))‚ĀĽ¬Ļ))
  ¬∑ intro n ŌČ
    exact inv_le_one_of_one_le‚āÄ (hb_one_le n)
  ¬∑ intro n ŌČ
    exact inv_nonneg.mpr (zero_le_one.trans (hb_one_le n))
  ¬∑ intro n ŌČ
    rfl
  ¬∑ intro k
    exact ne_of_gt (zero_lt_one.trans_le (hb_one_le (k + 1)))
  ¬∑ exact
      durrett2019_exercise_4_4_11_reciprocalTransform_memLp_two_of_process_memLp
        (P := P) (X := X) (b := b) hX_memLp_two

/--
Durrett 2019, Theorem 4.5.3 Kronecker support with a random normalizer.

The deterministic Exercise 4.4.11 theorem already proves the pathwise
Kronecker step for a fixed normalizing sequence.  This wrapper applies it
outside one null set when the normalizer depends on the sample point, as in
the textbook choice `b_n = f(A_n)`.
-/
theorem durrett2019_theorem_4_5_3_normalized_process_ae_tendsto_zero_of_transform_tendsto
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©}
    {H X b : ‚Ąē -> ő© -> ‚ĄĚ}
    (hX0 : X 0 =ŠĶź[P] 0)
    (hH_eq : ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÄ n : ‚Ąē, H n ŌČ = (b n ŌČ)‚ĀĽ¬Ļ)
    (hb_nonzero : ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÄ k : ‚Ąē, b (k + 1) ŌČ ‚Č† 0)
    (hb_increment_nonneg :
      ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÄ k : ‚Ąē, 0 ‚Č§ b (k + 2) ŌČ - b (k + 1) ŌČ)
    (hb_atTop :
      ‚ąÄŠĶź ŌČ ‚ąāP, Tendsto (fun n : ‚Ąē => b (n + 1) ŌČ) atTop atTop)
    (hTransform_tendsto :
      ‚ąÄŠĶź ŌČ ‚ąāP,
        ‚ąÉ Y : ‚ĄĚ,
          Tendsto (fun n : ‚Ąē => durrett2019_stochasticTransform H X n ŌČ)
            atTop (ūĚďĚ Y)) :
    ‚ąÄŠĶź ŌČ ‚ąāP,
      Tendsto (fun n : ‚Ąē => X n ŌČ / b n ŌČ) atTop (ūĚďĚ 0) := by
  filter_upwards
    [hX0, hH_eq, hb_nonzero, hb_increment_nonneg, hb_atTop, hTransform_tendsto]
    with ŌČ hX0ŌČ hHŌČ hb_nonzeroŌČ hb_increment_nonnegŌČ hb_atTopŌČ hTransformŌČ
  rcases hTransformŌČ with ‚ü®Y, hY‚ü©
  have hincrement :
      Tendsto
        (fun n : ‚Ąē => (X (n + 1) ŌČ - X 0 ŌČ) / b (n + 1) ŌČ)
        atTop (ūĚďĚ 0) := by
    refine
      durrett2019_exercise_4_4_11_normalized_increment_sum_tendsto_zero
        (A := fun n : ‚Ąē => durrett2019_stochasticTransform H X n ŌČ)
        (X := fun n : ‚Ąē => X n ŌČ) (b := fun n : ‚Ąē => b n ŌČ)
        ?_ ?_ hb_nonzeroŌČ (L := Y) ?_ hb_increment_nonnegŌČ hb_atTopŌČ
    ¬∑ simp [durrett2019_stochasticTransform]
    ¬∑ intro k
      have hinc :=
        congrFun
          (durrett2019_exercise_4_4_11_stochasticTransform_increment_eq H X k) ŌČ
      calc
        durrett2019_stochasticTransform H X (k + 1) ŌČ -
            durrett2019_stochasticTransform H X k ŌČ
            = H (k + 1) ŌČ * (X (k + 1) ŌČ - X k ŌČ) := by
              simpa [Pi.sub_apply, Pi.mul_apply] using hinc
        _ = (X (k + 1) ŌČ - X k ŌČ) / b (k + 1) ŌČ := by
              rw [hHŌČ (k + 1)]
              ring
    ¬∑ exact hY.comp (tendsto_add_atTop_nat 1)
  have hshifted :
      Tendsto (fun n : ‚Ąē => X (n + 1) ŌČ / b (n + 1) ŌČ) atTop (ūĚďĚ 0) :=
    durrett2019_exercise_4_4_11_normalized_process_tendsto_zero_of_initial_zero
      (X := fun n : ‚Ąē => X n ŌČ) (b := fun n : ‚Ąē => b n ŌČ) hX0ŌČ hincrement
  exact
    (tendsto_add_atTop_iff_nat
      (f := fun n : ‚Ąē => X n ŌČ / b n ŌČ) 1).mp hshifted

/--
Durrett 2019, Theorem 4.5.3 event-local Kronecker support with a random
normalizer.

This is the event-local version of
`durrett2019_theorem_4_5_3_normalized_process_ae_tendsto_zero_of_transform_tendsto`.
It keeps all transform convergence and monotonicity hypotheses global, but only
requires normalizer divergence on the event where the clock has infinite
