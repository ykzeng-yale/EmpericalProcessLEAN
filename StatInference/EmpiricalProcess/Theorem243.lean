/--
Closed-form value of the finite-center sub-Gaussian tail majorant over
`(0, тИЮ)`.
-/
theorem vdVWTheorem243_integral_subGaussian_tail_bound_eq
    {cardinality : тДХ} {c : тДЭтЙе0} (hc : 0 < (c : тДЭ)) :
    (тИл t in Set.Ioi (0 : тДЭ),
        (cardinality : тДЭ) *
          (2 * Real.exp (-(t ^ 2) / (2 * (c : тДЭ))))) =
      (cardinality : тДЭ) * Real.sqrt (2 * Real.pi * (c : тДЭ)) := by
  have _hc : 0 < (c : тДЭ) := hc
  have hprev :
      (тИл t in Set.Ioi (0 : тДЭ),
          (cardinality : тДЭ) *
            (2 * Real.exp (-(t ^ 2) / (2 * (c : тДЭ))))) =
        (cardinality : тДЭ) *
          (2 * (Real.sqrt (Real.pi / ((2 * (c : тДЭ))тБ╗┬╣)) / 2)) := by
    calc
      (тИл t in Set.Ioi (0 : тДЭ),
          (cardinality : тДЭ) *
            (2 * Real.exp (-(t ^ 2) / (2 * (c : тДЭ)))))
          = тИл t in Set.Ioi (0 : тДЭ),
              ((cardinality : тДЭ) * 2) *
                Real.exp (-((2 * (c : тДЭ))тБ╗┬╣) * t ^ 2) := by
              refine setIntegral_congr_fun measurableSet_Ioi ?_
              intro t _ht
              ring_nf
      _ = ((cardinality : тДЭ) * 2) *
            (тИл t in Set.Ioi (0 : тДЭ),
              Real.exp (-((2 * (c : тДЭ))тБ╗┬╣) * t ^ 2)) := by
              rw [integral_const_mul]
      _ = (cardinality : тДЭ) *
            (2 * (Real.sqrt (Real.pi / ((2 * (c : тДЭ))тБ╗┬╣)) / 2)) := by
              rw [integral_gaussian_Ioi]
              ring
  rw [hprev]
  congr 1
  rw [div_inv_eq_mul]
  ring_nf

/--
Closed-form finite-center expectation bound obtained from the compiled
sub-Gaussian union tail and Gaussian integral.

This is still a coarse `N * sqrt c` bound; the later textbook maximal
inequality sharpens it by splitting the tail integral at a logarithmic radius.
-/
theorem vdVWTheorem243FiniteCenterExpectedSupremum_le_subGaussian_tail_closedForm
    {╬й : Type u} [MeasurableSpace ╬й] {╬╝ : Measure ╬й} [IsProbabilityMeasure ╬╝]
    {cardinality : тДХ} (hcardinality : 0 < cardinality)
