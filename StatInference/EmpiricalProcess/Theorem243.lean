    (X : Fin cardinality -> ╬й -> тДЭ) {c : тДЭтЙе0} {epsilon : тДЭ}
    (hX : тИА centerIndex : Fin cardinality, HasSubgaussianMGF (X centerIndex) c ╬╝)
    (hepsilon : 0 тЙд epsilon) :
    ╬╝.real {╧Й | epsilon тЙд (тиЖ centerIndex : Fin cardinality, |X centerIndex ╧Й|)} тЙд
      (cardinality : тДЭ) *
        (2 * Real.exp (-(epsilon ^ 2) / (2 * (c : тДЭ)))) := by
  have hsubset :
      {╧Й | epsilon тЙд (тиЖ centerIndex : Fin cardinality, |X centerIndex ╧Й|)} тКЖ
        (тЛГ centerIndex : Fin cardinality, {╧Й | epsilon тЙд |X centerIndex ╧Й|}) := by
    intro ╧Й h╧Й
    have h╧Й_sup :
        epsilon тЙд (тиЖ centerIndex : Fin cardinality, |X centerIndex ╧Й|) := by
      simpa using h╧Й
    obtain тЯиcenterIndex, hcenterIndexтЯй :
        тИГ centerIndex : Fin cardinality,
          |X centerIndex ╧Й| =
            тиЖ centerIndex : Fin cardinality, |X centerIndex ╧Й| :=
      exists_eq_ciSup_of_finite
    exact Set.mem_iUnion.mpr
      тЯиcenterIndex, by simpa [тЖР hcenterIndex] using h╧Й_supтЯй
  calc
    ╬╝.real {╧Й | epsilon тЙд (тиЖ centerIndex : Fin cardinality, |X centerIndex ╧Й|)}
        тЙд ╬╝.real
          (тЛГ centerIndex : Fin cardinality,
