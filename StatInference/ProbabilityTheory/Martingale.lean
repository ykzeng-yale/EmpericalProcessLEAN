      hvariance_bound hb_inv_sq_summable
  · simpa using
      (stronglyAdapted_const' ℱ (fun n : ℕ => (b (n + 1))⁻¹) :
        StronglyAdapted ℱ (fun n : ℕ => fun _ : Ω => (b (n + 1))⁻¹))
