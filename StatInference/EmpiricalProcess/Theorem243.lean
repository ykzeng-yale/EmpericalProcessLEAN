/-- Elementary bound used in the finite-net scale comparison. -/
theorem vdVWTheorem243_exp_neg_one_le_half :
    Real.exp (-1) тЙд (1 / 2 : тДЭ) := by
  have h2raw := Real.add_one_le_exp (1 : тДЭ)
  have h2 : (2 : тДЭ) тЙд Real.exp 1 := by
    norm_num at h2raw тКв
    exact h2raw
  rw [Real.exp_neg]
  simpa [one_div] using one_div_le_one_div_of_le (by norm_num : (0 : тДЭ) < 2) h2

/--
The logarithmic radius based on `cardinality` is bounded by the finite-net
display radius based on `cardinality + 1`.
-/
theorem vdVWTheorem243_logRadius_log_le_succ
    {cardinality : тДХ} (hcardinality : 0 < cardinality) :
    1 + Real.log (cardinality : тДЭ) тЙд
      1 + Real.log ((cardinality : тДЭ) + 1) := by
  have hcpos : 0 < (cardinality : тДЭ) := by exact_mod_cast hcardinality
  have hcle : (cardinality : тДЭ) тЙд (cardinality : тДЭ) + 1 := by linarith
  linarith [Real.log_le_log hcpos hcle]

/--
The compiled log-radius Mills upper is dominated by the VdV&W finite-net
Hoeffding display scale under the explicit positive assumptions on the net
cardinality, sample size, and truncation level.
-/
theorem VdVWTheorem243LogRadiusMillsUpperToHoeffdingScale.of_pos
    {cardinality n : тДХ} {M : тДЭ}
    (hcardinality : 0 < cardinality) (hn : 0 < n) (hM_pos : 0 < M) :
    VdVWTheorem243LogRadiusMillsUpperToHoeffdingScale cardinality n M := by
  unfold VdVWTheorem243LogRadiusMillsUpperToHoeffdingScale
  let c : тДЭтЙе0 :=
    NNReal.mk (M ^ 2 / (n : тДЭ))
      (div_nonneg (sq_nonneg M) (Nat.cast_nonneg n))
  let a : тДЭ := 1 + Real.log (cardinality : тДЭ)
  let b : тДЭ := 1 + Real.log ((cardinality : тДЭ) + 1)
  let r : тДЭ := Real.sqrt (2 * (c : тДЭ) * a)
  have hc : 0 < (c : тДЭ) := by
    dsimp [c]
    exact vdVWTheorem243_truncated_commonProxy_pos hn hM_pos
  have hc_nonneg : 0 тЙд (c : тДЭ) := le_of_lt hc
  have hcardinality_one : (1 : тДЭ) тЙд (cardinality : тДЭ) := by
    exact_mod_cast Nat.succ_le_of_lt hcardinality
  have ha_nonneg : 0 тЙд a := by
    dsimp [a]
    have hlog : 0 тЙд Real.log (cardinality : тДЭ) :=
      Real.log_nonneg hcardinality_one
    linarith
  have ha_one : 1 тЙд a := by
    dsimp [a]
    have hlog : 0 тЙд Real.log (cardinality : тДЭ) :=
      Real.log_nonneg hcardinality_one
    linarith
  have hb_nonneg : 0 тЙд b := by
    dsimp [b]
    have hge : (1 : тДЭ) тЙд (cardinality : тДЭ) + 1 := by
      have hc0 : 0 тЙд (cardinality : тДЭ) := by exact_mod_cast Nat.zero_le cardinality
      linarith
    have hlog : 0 тЙд Real.log ((cardinality : тДЭ) + 1) :=
      Real.log_nonneg hge
    linarith
  have hab : a тЙд b := by
    dsimp [a, b]
    exact vdVWTheorem243_logRadius_log_le_succ hcardinality
  have hr_pos : 0 < r := by
    dsimp [r, a, c]
    exact vdVWTheorem243_logRadius_pos
      (cardinality := cardinality)
      (c := NNReal.mk (M ^ 2 / (n : тДЭ))
        (div_nonneg (sq_nonneg M) (Nat.cast_nonneg n)))
      hcardinality hc
  have hr_nonneg : 0 тЙд r := le_of_lt hr_pos
  have hr_sq : r ^ 2 = 2 * (c : тДЭ) * a := by
    dsimp [r]
    rw [Real.sq_sqrt]
    positivity
  have hc_div_r_le : (c : тДЭ) / r тЙд r / 2 := by
    rw [div_le_iffтВА hr_pos]
    calc
      (c : тДЭ) тЙд (c : тДЭ) * a := by nlinarith
      _ = r / 2 * r := by
        calc
          (c : тДЭ) * a = r ^ 2 / 2 := by
            rw [hr_sq]
            ring
          _ = r / 2 * r := by ring
  have hmills_le : 2 * Real.exp (-1) * ((c : тДЭ) / r) тЙд r / 2 := by
    have he : 2 * Real.exp (-1) тЙд (1 : тДЭ) := by
      nlinarith [vdVWTheorem243_exp_neg_one_le_half]
    have hdiv_nonneg : 0 тЙд (c : тДЭ) / r := div_nonneg hc_nonneg hr_nonneg
    calc
      2 * Real.exp (-1) * ((c : тДЭ) / r) тЙд 1 * ((c : тДЭ) / r) := by
        exact mul_le_mul_of_nonneg_right he hdiv_nonneg
      _ = (c : тДЭ) / r := by ring
      _ тЙд r / 2 := hc_div_r_le
  have hlog_le :
      vdVWTheorem243LogRadiusMillsUpper cardinality c тЙд (3 / 2) * r := by
    unfold vdVWTheorem243LogRadiusMillsUpper
    dsimp [r, a]
    calc
      Real.sqrt (2 * (c : тДЭ) * (1 + Real.log (cardinality : тДЭ))) +
          2 * Real.exp (-1) *
            ((c : тДЭ) /
              Real.sqrt (2 * (c : тДЭ) * (1 + Real.log (cardinality : тДЭ)))) тЙд
          r + r / 2 := by
        dsimp [r, a] at hmills_le тКв
        nlinarith
      _ = (3 / 2) * r := by ring
  have hthree_le :
      (3 / 2 : тДЭ) * r тЙд vdVWTheorem243FiniteNetHoeffdingUpper cardinality n M := by
    have hleft_nonneg : 0 тЙд (3 / 2 : тДЭ) * r := by positivity
    have hright_nonneg :
        0 тЙд vdVWTheorem243FiniteNetHoeffdingUpper cardinality n M :=
      vdVWTheorem243FiniteNetMaximalUpper_nonneg cardinality
        (vdVWTheorem243HoeffdingCenterScale_nonneg n hM_pos.le)
    rw [тЖР sq_le_sqтВА hleft_nonneg hright_nonneg]
    have hnreal_pos : 0 < (n : тДЭ) := by exact_mod_cast hn
    have h6div_nonneg : 0 тЙд 6 / (n : тДЭ) := div_nonneg (by norm_num) hnreal_pos.le
    calc
      ((3 / 2 : тДЭ) * r) ^ 2 = (9 / 2) * (c : тДЭ) * a := by
        rw [mul_pow, hr_sq]
        ring
      _ тЙд 6 * (c : тДЭ) * b := by
        nlinarith
      _ = (vdVWTheorem243FiniteNetHoeffdingUpper cardinality n M) ^ 2 := by
        unfold vdVWTheorem243FiniteNetHoeffdingUpper
        unfold vdVWTheorem243FiniteNetMaximalUpper
        unfold vdVWTheorem243HoeffdingCenterScale
        dsimp [b, c]
        rw [mul_pow, mul_pow, Real.sq_sqrt hb_nonneg, Real.sq_sqrt h6div_nonneg]
        dsimp [c, b]
        field_simp [ne_of_gt hnreal_pos]
  exact hlog_le.trans hthree_le

