    intro n
    exact (hMax_meas n).ennreal_ofReal
  have hmono : Monotone f := by
    intro n m hnm ω
    dsimp [f]
    exact ENNReal.ofReal_le_ofReal
      ((durrett2019_runningAbsMax_mono (X := X) ω) hnm)
  calc
    (∫⁻ ω, ⨆ n : ℕ, ENNReal.ofReal (durrett2019_runningAbsMax X n ω) ∂P)
