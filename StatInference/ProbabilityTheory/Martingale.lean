/--
Durrett 2019, Exercise 4.4.6 deterministic variance clock
`s_n^2 = sum_{1 <= m <= n} sigma_m^2`.
-/
def durrett2019_exercise_4_4_6_varianceClock (sigmaSq : ‚Ąē -> ‚ĄĚ) : ‚Ąē -> ‚ĄĚ :=
  fun n => ‚ąĎ m ‚ąą Finset.Icc 1 n, sigmaSq m

@[simp]
