    {őĻ S : Type*} [MeasurableSpace S]
    {őľ őĹ : őĻ -> Measure S} [‚ąÄ i, IsProbabilityMeasure (őľ i)]
    [‚ąÄ i, IsProbabilityMeasure (őĹ i)]
    {Iseq : ‚Ąē -> Finset őĻ} {q : őĻ -> S -> ‚ĄĚ‚Č•0‚ąě}
