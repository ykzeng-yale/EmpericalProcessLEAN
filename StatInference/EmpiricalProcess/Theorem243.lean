    {Observation : Type v}
    {cardinality : (n : тДХ) -> SampleAt Observation n -> тДХ -> тДХ}
    {base : тДХ}
    (hbase_pos : 0 < base)
    (hterminal_le :
      тИА n (sample : SampleAt Observation n),
        cardinality n sample n тЙд base ^ n) :
    тИА n (sample : SampleAt Observation n),
      vdVWLogEmpiricalL1CoveringCardinality (cardinality n) sample n /
          (n : тДЭ) тЙд Real.log (2 * ((base : тДЭ) + 1)) := by
  intro n sample
  by_cases hn : n = 0
  ┬╖ subst n
    have harg_ge_one : (1 : тДЭ) тЙд 2 * ((base : тДЭ) + 1) := by
      have hbase_nonneg : (0 : тДЭ) тЙд (base : тДЭ) := Nat.cast_nonneg _
      nlinarith
    have hlog_nonneg : 0 тЙд Real.log (2 * ((base : тДЭ) + 1)) :=
      Real.log_nonneg harg_ge_one
    simpa using hlog_nonneg
  ┬╖ have hn_pos_nat : 0 < n := Nat.pos_of_ne_zero hn
    have hn_pos : (0 : тДЭ) < (n : тДЭ) := by exact_mod_cast hn_pos_nat
    rw [div_le_iffтВА hn_pos]
    unfold vdVWLogEmpiricalL1CoveringCardinality
    have hcard_arg_pos : 0 < ((cardinality n sample n : тДЭ) + 1) := by
      have hnonneg :
          (0 : тДЭ) тЙд (cardinality n sample n : тДЭ) :=
        Nat.cast_nonneg _
      linarith
    have hbase_real_nonneg : (0 : тДЭ) тЙд (base : тДЭ) := Nat.cast_nonneg _
    have hbase_le_base_add_one :
        (base : тДЭ) тЙд (base : тДЭ) + 1 := by linarith
    have hbase_pow_le :
        (base : тДЭ) ^ n тЙд ((base : тДЭ) + 1) ^ n :=
      pow_le_pow_leftтВА hbase_real_nonneg hbase_le_base_add_one n
    have hone_le_pow :
        (1 : тДЭ) тЙд ((base : тДЭ) + 1) ^ n :=
      one_le_powтВА (by linarith : (1 : тДЭ) тЙд (base : тДЭ) + 1)
    have hcard_le_pow :
        (cardinality n sample n : тДЭ) тЙд (base : тДЭ) ^ n := by
      exact_mod_cast hterminal_le n sample
    have harg_le :
        ((cardinality n sample n : тДЭ) + 1) тЙд
          2 * (((base : тДЭ) + 1) ^ n) := by
      nlinarith
    have hlog_le :
        Real.log ((cardinality n sample n : тДЭ) + 1) тЙд
          Real.log (2 * (((base : тДЭ) + 1) ^ n)) :=
      Real.log_le_log hcard_arg_pos harg_le
    have htwo_ne : (2 : тДЭ) тЙа 0 := by norm_num
    have hbase_add_pow_ne : ((base : тДЭ) + 1) ^ n тЙа 0 := by positivity
    have hlog_prod :
        Real.log (2 * (((base : тДЭ) + 1) ^ n)) =
          Real.log (2 : тДЭ) + (n : тДЭ) * Real.log ((base : тДЭ) + 1) := by
      rw [Real.log_mul htwo_ne hbase_add_pow_ne, Real.log_pow]
    have htarget_rewrite :
        Real.log (2 * ((base : тДЭ) + 1)) * (n : тДЭ) =
          (n : тДЭ) * Real.log (2 : тДЭ) +
            (n : тДЭ) * Real.log ((base : тДЭ) + 1) := by
      have hbase_add_ne : ((base : тДЭ) + 1) тЙа 0 := by positivity
      rw [Real.log_mul htwo_ne hbase_add_ne]
      ring
    have hlog2_nonneg : 0 тЙд Real.log (2 : тДЭ) :=
      Real.log_nonneg (by norm_num)
    have hn_ge_one : (1 : тДЭ) тЙд (n : тДЭ) := by
      exact_mod_cast hn_pos_nat
    calc
      Real.log ((cardinality n sample n : тДЭ) + 1)
          тЙд Real.log (2 * (((base : тДЭ) + 1) ^ n)) := hlog_le
      _ = Real.log (2 : тДЭ) +
            (n : тДЭ) * Real.log ((base : тДЭ) + 1) := hlog_prod
      _ тЙд (n : тДЭ) * Real.log (2 : тДЭ) +
            (n : тДЭ) * Real.log ((base : тДЭ) + 1) := by nlinarith
      _ = Real.log (2 * ((base : тДЭ) + 1)) * (n : тДЭ) :=
        htarget_rewrite.symm

