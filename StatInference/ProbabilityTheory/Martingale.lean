    _ = ‚ąę‚ĀĽ y, fI y ‚ąāMeasure.pi (fun i : I => őĹ i) := by
          exact lintegral_restrict_infinitePi
            (őľ := őĹ) (s := I) hfI_meas
    _ = ‚ąŹ i : I, ‚ąę‚ĀĽ y, (q i y) ^ ((1 : ‚ĄĚ) / 2) ‚ąāőĹ i := by
          exact
            durrett2019_theorem_4_3_8_finiteProductLikelihood_rpow_half_lintegral
