-/
def VdVWTheorem243LogRadiusMillsUpperToHoeffdingScale
    (cardinality n : тДХ) (M : тДЭ) : Prop :=
  vdVWTheorem243LogRadiusMillsUpper cardinality
      (NNReal.mk (M ^ 2 / (n : тДЭ))
