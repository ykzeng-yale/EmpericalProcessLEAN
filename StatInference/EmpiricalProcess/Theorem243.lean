  exact
    vdVWWeightedClassSupremum_le_sum_abs_mul_bound_of_uniform_bound
      weights (pairedSample ghostSample) (by positivity)
      (fun index hindex z =>
        abs_vdVWTruncatedClassFun_pairDifference_le_two_mul_max_M_zero
          henvelope hindex z)

