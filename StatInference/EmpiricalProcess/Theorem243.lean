    (тИС i : Fin n, (((n : тДЭ)тБ╗┬╣ * classFun center (sample i)) ^ 2)) тЙд
      M ^ 2 / (n : тДЭ) := by
  by_cases hn : n = 0
  ┬╖ subst n
    simp
  ┬╖ have hn_cast : (n : тДЭ) тЙа 0 := Nat.cast_ne_zero.mpr hn
    calc
      (тИС i : Fin n, (((n : тДЭ)тБ╗┬╣ * classFun center (sample i)) ^ 2))
          тЙд тИС _i : Fin n, ((n : тДЭ)тБ╗┬╣ ^ 2 * M ^ 2) := by
            apply Finset.sum_le_sum
            intro i _hi
            have hf_sq_le : (classFun center (sample i)) ^ 2 тЙд M ^ 2 := by
              have hsq_abs : |classFun center (sample i)| ^ 2 тЙд M ^ 2 :=
                (sq_le_sqтВА (abs_nonneg _) hM_nonneg).2 (hbound i)
              simpa [sq_abs] using hsq_abs
            rw [mul_pow]
            exact mul_le_mul_of_nonneg_left hf_sq_le (sq_nonneg ((n : тДЭ)тБ╗┬╣))
      _ = (n : тДЭ) * ((n : тДЭ)тБ╗┬╣ ^ 2 * M ^ 2) := by
            simp [Finset.sum_const, Finset.card_univ, Fintype.card_fin,
              nsmul_eq_mul]
      _ = M ^ 2 / (n : тДЭ) := by
            field_simp [hn_cast]

