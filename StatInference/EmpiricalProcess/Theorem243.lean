  have hc_le_M : c ≤ M := by
    exact (le_max_right 1 c).trans (le_max_left (max 1 c) M0)
  have hM_ge : M0 ≤ M := le_max_right (max 1 c) M0
  have htail_lt :
      ∫ x, Set.indicator {y : Observation | M < envelope y} envelope x ∂P <
