        n ŌČ ‚Č§ a ^ 2 := by
  intro n
  rw [durrett2019_theorem_4_5_2_firstPredictableAbove, stoppedProcess]
  let ŌĄ := hittingAfter (fun n ŌČ => A (n + 1) ŌČ) (Set.Ioi (a ^ 2)) 0
  let p : ‚Ąē := (min (n : ‚Ąē‚ąě) (ŌĄ ŌČ)).untopA
  change A p ŌČ ‚Č§ a ^ 2
