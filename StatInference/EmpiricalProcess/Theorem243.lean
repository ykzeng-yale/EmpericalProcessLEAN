/--
Terminal log-cardinality bound from a product-type cardinality estimate.

This is the arithmetic handoff needed after a future finite-grid or packing
argument proves `cardinality + 1 тЙд base ^ n` for the empirical cover selected
at the sample size.
-/
theorem
    vdVWLogEmpiricalL1CoveringCardinality_terminal_div_le_of_succ_terminal_le_pow
    {Observation : Type v}
    {cardinality : (n : тДХ) -> SampleAt Observation n -> тДХ -> тДХ}
    {base : тДХ}
    (hbase_one : 1 тЙд base)
    (hterminal_succ_le :
      тИА n (sample : SampleAt Observation n),
        cardinality n sample n + 1 тЙд base ^ n) :
    тИА n (sample : SampleAt Observation n),
      vdVWLogEmpiricalL1CoveringCardinality (cardinality n) sample n /
          (n : тДЭ) тЙд Real.log (base : тДЭ) := by
  intro n sample
  by_cases hn : n = 0
  ┬╖ subst n
    have hbase_ge_one_real : (1 : тДЭ) тЙд (base : тДЭ) := by
      exact_mod_cast hbase_one
    have hlog_nonneg : 0 тЙд Real.log (base : тДЭ) :=
      Real.log_nonneg hbase_ge_one_real
    simpa using hlog_nonneg
  ┬╖ have hn_pos_nat : 0 < n := Nat.pos_of_ne_zero hn
    have hn_pos : (0 : тДЭ) < (n : тДЭ) := by exact_mod_cast hn_pos_nat
    rw [div_le_iffтВА hn_pos]
    unfold vdVWLogEmpiricalL1CoveringCardinality
    have harg_pos : 0 < ((cardinality n sample n : тДЭ) + 1) := by
      have hnonneg :
          (0 : тДЭ) тЙд (cardinality n sample n : тДЭ) :=
        Nat.cast_nonneg _
      linarith
    have harg_le_pow :
        ((cardinality n sample n : тДЭ) + 1) тЙд (base : тДЭ) ^ n := by
      have hnat :
          cardinality n sample n + 1 тЙд base ^ n :=
        hterminal_succ_le n sample
      have hcast :
          ((cardinality n sample n + 1 : тДХ) : тДЭ) тЙд
            ((base ^ n : тДХ) : тДЭ) := by
        exact_mod_cast hnat
      simpa [Nat.cast_add, Nat.cast_one, Nat.cast_pow] using hcast
    have hlog_le :
        Real.log ((cardinality n sample n : тДЭ) + 1) тЙд
          Real.log ((base : тДЭ) ^ n) :=
      Real.log_le_log harg_pos harg_le_pow
    calc
      Real.log ((cardinality n sample n : тДЭ) + 1)
          тЙд Real.log ((base : тДЭ) ^ n) := hlog_le
      _ = (n : тДЭ) * Real.log (base : тДЭ) := Real.log_pow (base : тДЭ) n
      _ = Real.log (base : тДЭ) * (n : тДЭ) := by ring

