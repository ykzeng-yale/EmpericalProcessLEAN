/--
Durrett 2019, Theorem 4.5.2 terminal-bound threshold cover.

If `A_{n+1}` is almost surely bounded by a finite terminal variable `A‚ąě`, then
almost every path belongs to one of the countably many threshold events
`‚ąÄ n, A_{n+1} <= k^2`.
-/
theorem durrett2019_theorem_4_5_2_threshold_cover_of_ae_le_terminal
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©}
    {A : ‚Ąē -> ő© -> ‚ĄĚ} {Ainf : ő© -> ‚ĄĚ}
    (hA_le_Ainf : ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÄ n, A (n + 1) ŌČ ‚Č§ Ainf ŌČ) :
    ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą (Set.univ : Set ő©) ->
      ‚ąÉ k : ‚Ąē, ŌČ ‚ąą {ŌČ : ő© | ‚ąÄ n, A (n + 1) ŌČ ‚Č§ (k : ‚ĄĚ) ^ 2} := by
  filter_upwards [hA_le_Ainf] with ŌČ hle _hmem
  obtain ‚ü®k, hk‚ü© := exists_nat_gt (max (1 : ‚ĄĚ) |Ainf ŌČ|)
  refine ‚ü®k, ?_‚ü©
  intro n
  have hk_abs : |Ainf ŌČ| < (k : ‚ĄĚ) :=
    lt_of_le_of_lt (le_max_right (1 : ‚ĄĚ) |Ainf ŌČ|) hk
  have hk_one : (1 : ‚ĄĚ) < (k : ‚ĄĚ) :=
    lt_of_le_of_lt (le_max_left (1 : ‚ĄĚ) |Ainf ŌČ|) hk
  have hk_sq : Ainf ŌČ ‚Č§ (k : ‚ĄĚ) ^ 2 := by
    have hAinf_le_abs : Ainf ŌČ ‚Č§ |Ainf ŌČ| := le_abs_self _
    have hk_ge_sq : (k : ‚ĄĚ) ‚Č§ (k : ‚ĄĚ) ^ 2 := by
      have hk_nonneg : 0 ‚Č§ (k : ‚ĄĚ) := by positivity
      have hmul := mul_le_mul_of_nonneg_left (le_of_lt hk_one) hk_nonneg
      simpa [pow_two] using hmul
    calc
      Ainf ŌČ ‚Č§ |Ainf ŌČ| := hAinf_le_abs
      _ ‚Č§ (k : ‚ĄĚ) := le_of_lt hk_abs
      _ ‚Č§ (k : ‚ĄĚ) ^ 2 := hk_ge_sq
  exact (hle n).trans hk_sq

