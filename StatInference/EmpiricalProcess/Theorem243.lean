    (hsup_meas :
      AEStronglyMeasurable
        (fun ╧Й : ╬й =>
          vdVWWeightedClassSupremum indexClass classFun weights (sample ╧Й)) ╬╝)
    (hterm :
      тИА index, index тИИ indexClass ->
        Integrable
          (fun ╧Й : ╬й =>
            vdVWWeightedSampleSum classFun weights index (sample ╧Й)) ╬╝) :
    Integrable
      (fun ╧Й : ╬й =>
        vdVWWeightedClassSupremum indexClass classFun weights (sample ╧Й)) ╬╝ := by
  have hsum_integrable :
      Integrable
        (fun ╧Й : ╬й =>
          hindex_finite.toFinset.sum (fun index =>
