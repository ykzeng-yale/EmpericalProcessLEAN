    simpa using hY
  simpa using
    durrett2019_theorem_3_4_10_lindebergFeller_of_integrableSq
      (P := P) (P' := P') (X := X) (varianceLimit := 1) (Y := Y)
      hX hX2 hindep (by norm_num) hmean_zero hvariance hlindeberg hY'

