  refine ⟨?_, ?_⟩
  · exact measurable_pi_lambda _ fun i =>
      measurable_fst.comp (measurable_pi_apply i)
  · have hmap :
        (Measure.pi fun _ : Fin n =>
          ((⟨P.prod P, inferInstance⟩ :
            MeasureTheory.ProbabilityMeasure (Observation × Observation)) :
