    VdVWTheorem243SelectedFixedRadiusTailSideConditions.of_logCardinality_log_linear_bound
    {Observation : Type v} {Index : Type w} [MeasurableSpace Observation]
    [Countable Index]
    {P : Measure Observation} [IsProbabilityMeasure P]
