    (hA0 : A 0 = 0)
    (hA_mono : ‚ąÄŠĶź ŌČ ‚ąāP, Monotone fun n => A n ŌČ)
    (hA_tendsto : ‚ąÄŠĶź ŌČ ‚ąāP, Tendsto (fun n => A n ŌČ) atTop (ūĚďĚ (Ainf ŌČ)))
