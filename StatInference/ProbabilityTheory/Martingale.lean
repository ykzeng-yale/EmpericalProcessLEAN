    intro n _
    have h :=
      durrett2019_theorem_4_3_5_trimmed_rnDeriv_setLIntegral
        (μ := μ) (ρ := ρ) (ℱ := ℱ) n (hμρ n)
        (A := Set.univ) MeasurableSet.univ
    simpa [setLIntegral_univ] using h

