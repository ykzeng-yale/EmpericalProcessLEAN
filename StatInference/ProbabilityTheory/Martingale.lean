    martingalePart (MeasureTheory.BorelCantelli.process B) ‚ĄĪ P n =
      fun ŌČ : ő© =>
        MeasureTheory.BorelCantelli.process B n ŌČ -
          durrett2019_theorem_4_5_5_conditionalProbabilitySum P ‚ĄĪ B n ŌČ := by
  ext ŌČ
  have hformula :=
    congrFun
