theorem integrable_vdVWWeightedClassSupremum_of_finite
    {╬й : Type x} [MeasurableSpace ╬й] {╬╝ : Measure ╬й}
    {Observation : Type u} {Index : Type v}
    {indexClass : Set Index} {classFun : Index -> Observation -> тДЭ}
