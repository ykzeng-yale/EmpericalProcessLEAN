        StronglyMeasurable[‚ĄĪ n]
          (‚ąĎ i ‚ąą Finset.range (n + 1),
            Set.indicator {ŌČ : ő© | N ŌČ = (i : ‚Ąē‚ąě)} (A i)) := by
