      ENNReal.ofReal p * (ENNReal.ofReal (p - 1))‚ĀĽ¬Ļ =
        ENNReal.ofReal (p / (p - 1)) := by
    have hp_sub_pos : 0 < p - 1 := hpq.sub_one_pos
    rw [ENNReal.ofReal_div_of_pos hp_sub_pos]
    rfl
  change M ‚Č§ (ENNReal.ofReal (p / (p - 1)) * T ^ (1 / p)) ^ p
  rw [‚Üź hCoeff]
