theorem durrett2019_exercise_4_4_10_Ico_sum_le_tsum_tail_of_summable
    {q : ‚Ąē -> ‚ĄĚ} (hq_nonneg : ‚ąÄ k, 0 ‚Č§ q k) (hq_summable : Summable q)
