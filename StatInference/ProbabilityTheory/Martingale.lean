    (őľ := P) (X := Y) hY_nonneg hY_meas]
  refine MeasureTheory.lintegral_mono_ae ?_
  filter_upwards
    [ae_restrict_mem (őľ := volume) (measurableSet_Ioi : MeasurableSet (Set.Ioi (0 : ‚ĄĚ)))]
    with a ha
