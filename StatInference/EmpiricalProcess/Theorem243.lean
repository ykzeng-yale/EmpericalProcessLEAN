      VdVWChebyshev_betaLower_productSample_centeredTruncated_uniformWeights_succ_abs_lt_half
        (P := P) (indexClass := indexClass) (classFun := classFun)
        (envelope := envelope) (M := M) (x := epsilon) (n := n)
        henvelope hM hindex (htruncIntegrable index hindex) hepsilon
  exact hcheb.trans
    (measure_mono (by
      intro ghostSample hghost
      exact ⟨index, hindex, hbad_index, hghost⟩))

