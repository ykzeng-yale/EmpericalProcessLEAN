    (S : Chewi127BoundedMartingaleCLTSource Ω Ω' E P Q)
    (L : StrongDual ℝ E) (N : ℕ) (t : ℝ) :
    Integrable
      (fun ω =>
        ∏ k ∈ Finset.range N,
          S.projectedInverseCompensationFactor L N t k ω *
            (1 + S.projectedCompensatedTaylorErrorFactor L N t k ω)) P := by
  simpa [Chewi127BoundedMartingaleCLTSource.projectedNormalizedTaylorFactor]
    using S.projectedNormalizedTaylorProduct_integrable_of_uniform_bound L N t

/--
The displayed right compensated full-inverse product is exactly the product of
the normalized Taylor factors.  This is the useful algebraic shape for the
right-product route, because the normalized factors already have the proved
row bound `≤ 1`.
-/
theorem Chewi127BoundedMartingaleCLTSource.projectedCompensatedFullInverseRight_integral_eq_normalizedTaylorProduct_integral
    {Ω Ω' E : Type*} [mΩ : MeasurableSpace Ω] {P : Measure Ω}
    [IsProbabilityMeasure P] [MeasurableSpace Ω'] {Q : Measure Ω'}
    [IsProbabilityMeasure Q]
    [NormedAddCommGroup E] [NormedSpace ℝ E] [CompleteSpace E]
    [MeasurableSpace E] [OpensMeasurableSpace E] [BorelSpace E]
    (S : Chewi127BoundedMartingaleCLTSource Ω Ω' E P Q)
    (L : StrongDual ℝ E) (N : ℕ) (t : ℝ) :
    (∫ ω,
        (∏ k ∈ Finset.range N,
          S.projectedInverseCompensationFactor L N t k ω) *
        ∏ k ∈ Finset.range N,
          (1 + S.projectedCompensatedTaylorErrorFactor L N t k ω) ∂P) =
      ∫ ω, ∏ k ∈ Finset.range N,
        S.projectedNormalizedTaylorFactor L N t k ω ∂P := by
  refine integral_congr_ae <| ae_of_all P fun ω => ?_
  simp only [Chewi127BoundedMartingaleCLTSource.projectedNormalizedTaylorFactor]
  rw [← Finset.prod_mul_distrib]

/--
The normalized Taylor product has the inverse-compensation Gaussian limit once
the compensated-error row sum vanishes.  This is the sharpened right-product
route: it uses the already-proved normalized-factor bound and does not assume
any separate bound on `1 +` the compensated Taylor error.
-/
theorem Chewi127BoundedMartingaleCLTSource.projectedNormalizedTaylorProduct_tendsto_exp_of_compensated_error
    {Ω Ω' E : Type*} [mΩ : MeasurableSpace Ω] {P : Measure Ω}
    [IsProbabilityMeasure P] [MeasurableSpace Ω'] {Q : Measure Ω'}
    [IsProbabilityMeasure Q]
    [NormedAddCommGroup E] [NormedSpace ℝ E] [CompleteSpace E]
    [MeasurableSpace E] [OpensMeasurableSpace E] [BorelSpace E]
    (S : Chewi127BoundedMartingaleCLTSource Ω Ω' E P Q)
    (L : StrongDual ℝ E) (t : ℝ)
    (herror_int :
      ∀ N : ℕ,
        Integrable
          (fun ω =>
            ∑ k ∈ Finset.range N,
              ‖S.projectedCompensatedTaylorErrorFactor L N t k ω‖) P)
    (herror :
      Tendsto
        (fun N : ℕ =>
          ∫ ω,
            ∑ k ∈ Finset.range N,
              ‖S.projectedCompensatedTaylorErrorFactor L N t k ω‖ ∂P)
        atTop (𝓝 0)) :
    Tendsto
      (fun N : ℕ =>
        ∫ ω, ∏ k ∈ Finset.range N,
          S.projectedNormalizedTaylorFactor L N t k ω ∂P)
      atTop
      (𝓝 (Complex.exp
        (-(S.covariance_limit.S_infty L L * t ^ 2 / 2 : ℝ)))) := by
  have hdiff_int :
      ∀ N : ℕ,
        Integrable
          (fun ω =>
            ∑ k ∈ Finset.range N,
              ‖S.projectedNormalizedTaylorFactor L N t k ω -
                  S.projectedInverseCompensationFactor L N t k ω‖) P :=
    fun N => S.projectedNormalizedInverseDifference_row_integrable_of_uniform_bound
      L N t
  have hdiff_error :
      Tendsto
        (fun N : ℕ =>
          ∫ ω,
            ∑ k ∈ Finset.range N,
              ‖S.projectedNormalizedTaylorFactor L N t k ω -
                  S.projectedInverseCompensationFactor L N t k ω‖ ∂P)
        atTop (𝓝 0) := by
    refine squeeze_zero'
      (Eventually.of_forall fun N =>
        integral_nonneg fun ω =>
          Finset.sum_nonneg fun k _hk => norm_nonneg
            (S.projectedNormalizedTaylorFactor L N t k ω -
              S.projectedInverseCompensationFactor L N t k ω))
      ?_ herror
    filter_upwards
      [S.projectedInverseCompensationFactor_eventually_row_norm_le_one L t]
      with N hN
    refine integral_mono_ae (hdiff_int N) (herror_int N) ?_
    filter_upwards [hN] with ω hω
    refine Finset.sum_le_sum ?_
    intro k hk
    have hsplit :
        S.projectedNormalizedTaylorFactor L N t k ω -
            S.projectedInverseCompensationFactor L N t k ω =
          S.projectedInverseCompensationFactor L N t k ω *
            S.projectedCompensatedTaylorErrorFactor L N t k ω := by
      simp [Chewi127BoundedMartingaleCLTSource.projectedNormalizedTaylorFactor]
      ring
    calc
      ‖S.projectedNormalizedTaylorFactor L N t k ω -
          S.projectedInverseCompensationFactor L N t k ω‖
          = ‖S.projectedInverseCompensationFactor L N t k ω *
              S.projectedCompensatedTaylorErrorFactor L N t k ω‖ := by
            rw [hsplit]
      _ = ‖S.projectedInverseCompensationFactor L N t k ω‖ *
            ‖S.projectedCompensatedTaylorErrorFactor L N t k ω‖ := by
            rw [norm_mul]
      _ ≤ 1 * ‖S.projectedCompensatedTaylorErrorFactor L N t k ω‖ :=
            mul_le_mul_of_nonneg_right (hω k hk)
              (norm_nonneg
                (S.projectedCompensatedTaylorErrorFactor L N t k ω))
      _ = ‖S.projectedCompensatedTaylorErrorFactor L N t k ω‖ := by
            simp
  have hdiff :
      Tendsto
        (fun N : ℕ =>
          (∫ ω, ∏ k ∈ Finset.range N,
              S.projectedNormalizedTaylorFactor L N t k ω ∂P) -
            ∫ ω, ∏ k ∈ Finset.range N,
              S.projectedInverseCompensationFactor L N t k ω ∂P)
        atTop (𝓝 0) :=
    chewi127_integral_product_sub_product_tendsto_zero_of_integral_sum_norm
      (fun N k ω => S.projectedNormalizedTaylorFactor L N t k ω)
      (fun N k ω => S.projectedInverseCompensationFactor L N t k ω)
      (S.projectedNormalizedTaylorFactor_eventually_row_norm_le_one L t)
      (S.projectedInverseCompensationFactor_eventually_row_norm_le_one L t)
      (fun N => S.projectedNormalizedTaylorProduct_integrable_of_uniform_bound
        L N t)
      (fun N => S.projectedInverseCompensationProduct_integrable L N t)
      hdiff_int hdiff_error
  have hnormalized_product :=
    hdiff.add
      (S.projectedInverseCompensationProduct_tendsto_exp_of_uniform_bound L t)
  simpa only [zero_add] using
    hnormalized_product.congr' (Eventually.of_forall fun N => by
      ring)

