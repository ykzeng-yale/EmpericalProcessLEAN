      refine eventually_atTop.2 ⟨n, fun m hnm => ?_⟩
      exact hX.setIntegral_eq hnm hs
    exact tendsto_nhds_unique (tendsto_const_nhds.congr' hevent) htend
  · exact (hX.stronglyMeasurable n).aestronglyMeasurable

