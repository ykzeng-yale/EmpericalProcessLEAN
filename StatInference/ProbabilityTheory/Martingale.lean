/--
Durrett 2019, Theorem 4.5.1 monotone-convergence support: uniform ordinary
second-moment bounds on the finite running maxima pass to the nonnegative
`lintegral` of their pointwise `iSup`.
-/
theorem durrett2019_runningAbsMax_lintegral_iSup_sq_le_of_integral_sq_le
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©}
    {X : ‚Ąē -> ő© -> ‚ĄĚ} {C : ‚ĄĚ}
    (hMax_meas : ‚ąÄ n, Measurable (durrett2019_runningAbsMax X n))
    (hMax_sq_int :
      ‚ąÄ n, Integrable (fun ŌČ => durrett2019_runningAbsMax X n ŌČ ^ 2) P)
    (hMax_sq_le :
      ‚ąÄ n, (‚ąę ŌČ, durrett2019_runningAbsMax X n ŌČ ^ 2 ‚ąāP) ‚Č§ C) :
    (‚ąę‚ĀĽ ŌČ,
        ‚®Ü n : ‚Ąē,
          ENNReal.ofReal (durrett2019_runningAbsMax X n ŌČ ^ 2) ‚ąāP) ‚Č§
      ENNReal.ofReal C := by
  let f : ‚Ąē -> ő© -> ‚ĄĚ‚Č•0‚ąě := fun n ŌČ =>
    ENNReal.ofReal (durrett2019_runningAbsMax X n ŌČ ^ 2)
  have hf : ‚ąÄ n, Measurable (f n) := by
    intro n
    exact ((hMax_meas n).pow_const (2 : ‚Ąē)).ennreal_ofReal
  have hmono : Monotone f := by
    intro n m hnm ŌČ
    dsimp [f]
    refine ENNReal.ofReal_le_ofReal ?_
    exact
      (sq_le_sq‚āÄ
        (durrett2019_runningAbsMax_nonneg (X := X) n ŌČ)
        (durrett2019_runningAbsMax_nonneg (X := X) m ŌČ)).2
        ((durrett2019_runningAbsMax_mono (X := X) ŌČ) hnm)
  have hbound :
      (‚ąę‚ĀĽ ŌČ, ‚®Ü n : ‚Ąē, f n ŌČ ‚ąāP) ‚Č§ ENNReal.ofReal C := by
    calc
      (‚ąę‚ĀĽ ŌČ, ‚®Ü n : ‚Ąē, f n ŌČ ‚ąāP)
          = ‚®Ü n : ‚Ąē, ‚ąę‚ĀĽ ŌČ, f n ŌČ ‚ąāP := lintegral_iSup hf hmono
      _ ‚Č§ ENNReal.ofReal C := by
          refine iSup_le ?_
          intro n
          rw [‚Üź ofReal_integral_eq_lintegral_ofReal (hMax_sq_int n)
            (Eventually.of_forall fun ŌČ => sq_nonneg
              (durrett2019_runningAbsMax X n ŌČ))]
          exact ENNReal.ofReal_le_ofReal (hMax_sq_le n)
  simpa [f] using hbound

/--
Durrett 2019, Theorem 4.5.1 monotone-convergence support: if the terminal
