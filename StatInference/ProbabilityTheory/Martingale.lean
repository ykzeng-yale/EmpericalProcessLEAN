theorem durrett2019_theorem_4_5_7_terminal_tail_sq_measure_aemeasurable
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©} [IsFiniteMeasure P]
    {Ainf : ő© -> ‚ĄĚ}
    (hAinf_int : Integrable Ainf P) :
    AEMeasurable (fun a : ‚ĄĚ => P {ŌČ : ő© | a ^ 2 < Ainf ŌČ})
      (volume.restrict (Set.Ioi (0 : ‚ĄĚ))) := by
  let AinfMeas := hAinf_int.aestronglyMeasurable.aemeasurable
  let AinfMk : ő© -> ‚ĄĚ := AinfMeas.mk Ainf
  have hmk_meas : Measurable fun a : ‚ĄĚ => P {ŌČ : ő© | a ^ 2 < AinfMk ŌČ} := by
    let s : Set (‚ĄĚ √ó ő©) := {z | z.1 ^ 2 < AinfMk z.2}
    have hs : MeasurableSet s := by
      exact measurableSet_lt (measurable_fst.pow_const 2)
        (AinfMeas.measurable_mk.comp measurable_snd)
    simpa [s] using (measurable_measure_prodMk_left (őĹ := P) hs)
  have heq :
      (fun a : ‚ĄĚ => P {ŌČ : ő© | a ^ 2 < Ainf ŌČ}) =
        fun a : ‚ĄĚ => P {ŌČ : ő© | a ^ 2 < AinfMk ŌČ} := by
    funext a
    apply MeasureTheory.measure_congr
    filter_upwards [AinfMeas.ae_eq_mk] with ŌČ hŌČ
    change (a ^ 2 < Ainf ŌČ) = (a ^ 2 < AinfMk ŌČ)
    rw [hŌČ]
  rw [heq]
  exact hmk_meas.aemeasurable

/--
Durrett 2019, Theorem 4.5.7 deterministic RHS support.

Layer-cake form of the truncated terminal clock:
`E(A_infty ‚ąß a^2) = ‚ąę_0^‚ąě P(b < A_infty, b < a^2) db`.
This is the first line of the second Fubini/calculus computation in the
textbook proof.
