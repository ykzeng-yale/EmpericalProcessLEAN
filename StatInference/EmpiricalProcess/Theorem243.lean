  · intro sample
    by_cases hk : k < cardinality sample
    · simpa [VdVWFiniteEmpiricalL1CoverSelectedCenterAt, hk] using
        (cover sample).center_mem ⟨k, hk⟩
    · simpa [VdVWFiniteEmpiricalL1CoverSelectedCenterAt, hk] using
