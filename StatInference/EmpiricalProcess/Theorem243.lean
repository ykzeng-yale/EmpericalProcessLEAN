    {Observation : Type v} [MeasurableSpace Observation]
    {P : Measure Observation} [IsProbabilityMeasure P]
    {cardinality : (n : ℕ) -> SampleAt Observation n -> ℕ -> ℕ}
    {K : ℝ}
    (hlogMeasurable :
      ∀ n,
        Measurable fun sample : SampleAt Observation n =>
