      (cardinality : ℝ) *
        (2 * Real.exp (-(epsilon ^ 2) / (2 * (c : ℝ)))) := by
  haveI : Nonempty (Fin cardinality) := ⟨⟨0, hcardinality⟩⟩
  exact
    vdVWTheorem243_finiteCenter_iSup_abs_tail_le_of_hasSubgaussianMGF
