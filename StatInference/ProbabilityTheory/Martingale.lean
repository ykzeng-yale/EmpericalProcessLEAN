    (hY : AEMeasurable Y ŌĀ) (hZ : AEMeasurable Z ŌĀ)
    (hgen : mő© = MeasurableSpace.generateFrom C) (hC : IsPiSystem C)
    (hőľŌĀ : ‚ąÄ n, őľ.trim (‚ĄĪ.le n) ‚Č™ ŌĀ.trim (‚ĄĪ.le n))
