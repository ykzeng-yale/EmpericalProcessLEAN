    (hsub : Submartingale f тД▒ ╬╝)
    (hbdd : тИА n : тДХс╡Тс╡И, eLpNorm (f n) 1 ╬╝ тЙд (R : тДЭтЙе0тИЮ))
    (hcompare :
      тИА a b : тДЪ, a < b -> тИА N : тДХ, тИА ╧Й : ╬й,
