theorem chewi1316_exists_preliminary_final_tail_budget_indices_of_uniformTailBound
    {invHess : E -> E →L[ℝ] E} {phiGrad : E -> E} {xbar0 : E}
    {xseq : ℕ -> E} {tStart c0 nu tailBound : ℝ}
