    {A : Set Ω} {m : ℕ} (hA : MeasurableSet[ℱ m] A) :
    ∀ᶠ n in atTop,
      μ A =
        ∫⁻ ω in A, (μ.trim (ℱ.le n)).rnDeriv (ρ.trim (ℱ.le n)) ω ∂ρ := by
  filter_upwards [eventually_ge_atTop m] with n hmn
  exact
    durrett2019_theorem_4_3_5_trimmed_rnDeriv_setLIntegral
      (μ := μ) (ρ := ρ) (ℱ := ℱ) n (hμρ n)
      (ℱ.mono hmn A hA)

