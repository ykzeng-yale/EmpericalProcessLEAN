    (hb_one_le : ∀ n : ℕ, 1 ≤ b n)
    (hb_increment_nonneg : ∀ k : ℕ, 0 ≤ b (k + 2) - b (k + 1))
    (hb_atTop : Tendsto (fun n : ℕ => b (n + 1)) atTop atTop)
    (hvariance_bound :
      ∀ k : ℕ,
        (∫ ω, (X (k + 1) ω - X k ω) ^ 2 ∂P) ≤ K)
    (hb_inv_sq_summable :
