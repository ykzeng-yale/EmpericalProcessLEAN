    apply MeasureTheory.measure_congr
    filter_upwards [hAinf_meas.ae_eq_mk] with ŌČ hŌČ
    change (b < Ainf ŌČ ‚ąß b < a ^ 2) =
      (b < hAinf_meas.mk Ainf ŌČ ‚ąß b < a ^ 2)
    rw [hŌČ]
  rw [hkernel_eq]
  exact hmk

