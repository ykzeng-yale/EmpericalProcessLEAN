  refine ae_of_all ╬╝ ?_
  intro ╧Й
  have hsup_nonneg :
      0 тЙд vdVWWeightedClassSupremum indexClass classFun weights (sample ╧Й) :=
    vdVWWeightedClassSupremum_nonneg indexClass classFun weights (sample ╧Й)
  rw [Real.norm_eq_abs, abs_of_nonneg hsup_nonneg]
  exact vdVWWeightedClassSupremum_le_sum_abs_of_finite
    hindex_finite weights (sample ╧Й)

