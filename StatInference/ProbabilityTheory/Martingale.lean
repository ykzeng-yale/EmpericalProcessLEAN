/--
Durrett 2019, Theorem 4.5.5 centered-indicator conditional-variance algebra.

This is the reusable conditional-expectation calculation behind
`E((1_B - E(1_B | F))^2 | F) <= E(1_B | F)`.  The remaining source work for
the theorem-specific indicator is to discharge the boundedness/integrability
side conditions from `0 <= E(1_B | F) <= 1`.
-/
theorem durrett2019_theorem_4_5_5_condExp_centered_indicator_sq_le_of_source
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} {m : MeasurableSpace ő©} (hm : m ‚Č§ mő©)
    [SigmaFinite (P.trim hm)] {I p : ő© -> ‚ĄĚ}
    (hI_sq : (fun ŌČ : ő© => I ŌČ ^ 2) =ŠĶź[P] I)
    (hI_int : Integrable I P)
    (hp_cond : P[I | m] =ŠĶź[P] p)
    (hp_meas : StronglyMeasurable[m] p)
    (hIp_int : Integrable (fun ŌČ : ő© => p ŌČ * I ŌČ) P)
    (hp_sq_int : Integrable (fun ŌČ : ő© => p ŌČ ^ 2) P) :
    P[(fun ŌČ : ő© => (I ŌČ - p ŌČ) ^ 2) | m] ‚Č§ŠĶź[P] p := by
  have hI_sq_int : Integrable (fun ŌČ : ő© => I ŌČ ^ 2) P :=
    hI_int.congr hI_sq.symm
  have htwoIp_int : Integrable (fun ŌČ : ő© => 2 * (p ŌČ * I ŌČ)) P :=
    hIp_int.const_mul 2
  have hExpand :
      (fun ŌČ : ő© => (I ŌČ - p ŌČ) ^ 2) =ŠĶź[P]
        ((fun ŌČ : ő© => I ŌČ ^ 2) - (fun ŌČ : ő© => 2 * (p ŌČ * I ŌČ))) +
          fun ŌČ : ő© => p ŌČ ^ 2 :=
    ae_of_all P fun ŌČ => by
      simp only [Pi.add_apply, Pi.sub_apply]
      ring
  have hI_sq_cond :
      P[(fun ŌČ : ő© => I ŌČ ^ 2) | m] =ŠĶź[P] P[I | m] :=
    condExp_congr_ae hI_sq
  have hPull :
      P[(fun ŌČ : ő© => p ŌČ * I ŌČ) | m] =ŠĶź[P]
        fun ŌČ : ő© => p ŌČ * P[I | m] ŌČ :=
    condExp_mul_of_stronglyMeasurable_left
      (őľ := P) (m := m) hp_meas hIp_int hI_int
  have hTwo :
      P[(fun ŌČ : ő© => 2 * (p ŌČ * I ŌČ)) | m] =ŠĶź[P]
        fun ŌČ : ő© => 2 * P[(fun ŌČ : ő© => p ŌČ * I ŌČ) | m] ŌČ := by
    filter_upwards
      [condExp_ofNat (őľ := P) (m := m) 2 (fun ŌČ : ő© => p ŌČ * I ŌČ)] with
      ŌČ hŌČ
    simpa using hŌČ
  have hp_sq_cond :
      P[(fun ŌČ : ő© => p ŌČ ^ 2) | m] = fun ŌČ : ő© => p ŌČ ^ 2 :=
    condExp_of_stronglyMeasurable hm (hp_meas.pow 2) hp_sq_int
  have hcenter_eq :
      P[(fun ŌČ : ő© => (I ŌČ - p ŌČ) ^ 2) | m] =ŠĶź[P]
        fun ŌČ : ő© => p ŌČ - p ŌČ ^ 2 := by
    refine (condExp_congr_ae hExpand).trans ?_
    filter_upwards
      [condExp_add (hI_sq_int.sub htwoIp_int) hp_sq_int m,
       condExp_sub hI_sq_int htwoIp_int m,
       hI_sq_cond,
       hp_cond,
       hTwo,
       hPull,
       EventuallyEq.of_eq hp_sq_cond] with
      ŌČ hAdd hSub hI2 hP hTwoŌČ hPullŌČ hPSq
    rw [hAdd]
    simp only [Pi.add_apply]
    rw [hSub]
    simp only [Pi.sub_apply]
    rw [hI2, hP, hTwoŌČ, hPullŌČ, hP, hPSq]
    ring
  filter_upwards [hcenter_eq] with ŌČ hŌČ
  rw [hŌČ]
  nlinarith [sq_nonneg (p ŌČ)]

/--
Durrett 2019, Theorem 4.5.5 theorem-specific centered-indicator
conditional-variance estimate, with only the remaining boundedness-derived
integrability facts left explicit.
-/
theorem durrett2019_theorem_4_5_5_condExp_centered_borelCantelli_indicator_sq_le
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] {‚ĄĪ : Filtration ‚Ąē mő©}
    [SigmaFiniteFiltration P ‚ĄĪ] {B : ‚Ąē -> Set ő©}
    (hB_meas : ‚ąÄ n, MeasurableSet (B n))
    (hIp_int :
      ‚ąÄ k : ‚Ąē,
        Integrable
          (fun ŌČ : ő© =>
            P[(B (k + 1)).indicator (1 : ő© -> ‚ĄĚ) | ‚ĄĪ k] ŌČ *
              (B (k + 1)).indicator (1 : ő© -> ‚ĄĚ) ŌČ) P)
    (hp_sq_int :
      ‚ąÄ k : ‚Ąē,
        Integrable
          (fun ŌČ : ő© =>
            P[(B (k + 1)).indicator (1 : ő© -> ‚ĄĚ) | ‚ĄĪ k] ŌČ ^ 2) P) :
    ‚ąÄ k : ‚Ąē,
      P[(fun ŌČ : ő© =>
          ((B (k + 1)).indicator (1 : ő© -> ‚ĄĚ) ŌČ -
            P[(B (k + 1)).indicator (1 : ő© -> ‚ĄĚ) | ‚ĄĪ k] ŌČ) ^ 2) | ‚ĄĪ k]
        ‚Č§ŠĶź[P] P[(B (k + 1)).indicator (1 : ő© -> ‚ĄĚ) | ‚ĄĪ k] := by
  intro k
  let I : ő© -> ‚ĄĚ := (B (k + 1)).indicator (1 : ő© -> ‚ĄĚ)
  have hI_sq : (fun ŌČ : ő© => I ŌČ ^ 2) =ŠĶź[P] I :=
    ae_of_all P fun ŌČ => by
      by_cases hŌČ : ŌČ ‚ąą B (k + 1)
      ¬∑ simp [I, hŌČ]
      ¬∑ simp [I, hŌČ]
  have hI_int : Integrable I P :=
    (integrable_const (c := (1 : ‚ĄĚ))).indicator (hB_meas (k + 1))
  exact
    durrett2019_theorem_4_5_5_condExp_centered_indicator_sq_le_of_source
      (P := P) (m := ‚ĄĪ k) (hm := ‚ĄĪ.le k)
      (I := I) (p := P[I | ‚ĄĪ k])
      hI_sq hI_int EventuallyEq.rfl stronglyMeasurable_condExp
      (by simpa [I] using hIp_int k)
      (by simpa [I] using hp_sq_int k)

/--
Durrett 2019, Theorem 4.5.5 centered-indicator conditional variance with the
boundedness integrability side conditions discharged from `0 <= p <= 1`.
-/
theorem durrett2019_theorem_4_5_5_condExp_centered_borelCantelli_indicator_sq_le_auto
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] {‚ĄĪ : Filtration ‚Ąē mő©}
    [SigmaFiniteFiltration P ‚ĄĪ] {B : ‚Ąē -> Set ő©}
    (hB_meas : ‚ąÄ n, MeasurableSet (B n)) :
    ‚ąÄ k : ‚Ąē,
      P[(fun ŌČ : ő© =>
          ((B (k + 1)).indicator (1 : ő© -> ‚ĄĚ) ŌČ -
            P[(B (k + 1)).indicator (1 : ő© -> ‚ĄĚ) | ‚ĄĪ k] ŌČ) ^ 2) | ‚ĄĪ k]
        ‚Č§ŠĶź[P] P[(B (k + 1)).indicator (1 : ő© -> ‚ĄĚ) | ‚ĄĪ k] := by
  refine
    durrett2019_theorem_4_5_5_condExp_centered_borelCantelli_indicator_sq_le
      (P := P) (‚ĄĪ := ‚ĄĪ) (B := B) hB_meas ?_ ?_
  ¬∑ intro k
    let I : ő© -> ‚ĄĚ := (B (k + 1)).indicator (1 : ő© -> ‚ĄĚ)
    let p : ő© -> ‚ĄĚ := P[I | ‚ĄĪ k]
    have hI_int : Integrable I P :=
      (integrable_const (c := (1 : ‚ĄĚ))).indicator (hB_meas (k + 1))
    have hI_nonneg : 0 ‚Č§ŠĶź[P] I :=
      ae_of_all P fun ŌČ => by
        by_cases hŌČ : ŌČ ‚ąą B (k + 1) <;> simp [I, hŌČ]
    have hI_le_one : I ‚Č§ŠĶź[P] fun _ : ő© => (1 : ‚ĄĚ) :=
      ae_of_all P fun ŌČ => by
        by_cases hŌČ : ŌČ ‚ąą B (k + 1) <;> simp [I, hŌČ]
    have hp_nonneg : 0 ‚Č§ŠĶź[P] p := by
      simpa [p] using condExp_nonneg (őľ := P) (m := ‚ĄĪ k) hI_nonneg
    have hp_le_one : p ‚Č§ŠĶź[P] fun _ : ő© => (1 : ‚ĄĚ) := by
      have hmono :
          P[I | ‚ĄĪ k] ‚Č§ŠĶź[P] P[(fun _ : ő© => (1 : ‚ĄĚ)) | ‚ĄĪ k] :=
        condExp_mono (őľ := P) (m := ‚ĄĪ k) hI_int (integrable_const (1 : ‚ĄĚ)) hI_le_one
      have hone :
          P[(fun _ : ő© => (1 : ‚ĄĚ)) | ‚ĄĪ k] = fun _ : ő© => (1 : ‚ĄĚ) :=
        condExp_const (őľ := P) (‚ĄĪ.le k) (1 : ‚ĄĚ)
      filter_upwards [hmono, EventuallyEq.of_eq hone] with ŌČ hmonoŌČ honeŌČ
      change P[I | ‚ĄĪ k] ŌČ ‚Č§ (1 : ‚ĄĚ)
      rw [honeŌČ] at hmonoŌČ
      exact hmonoŌČ
    have hI_abs_le_one : ‚ąÄ ŌČ : ő©, ‚ÄĖI ŌČ‚ÄĖ ‚Č§ (1 : ‚ĄĚ) := by
      intro ŌČ
      by_cases hŌČ : ŌČ ‚ąą B (k + 1) <;> simp [I, hŌČ]
    have hmeas :
        AEStronglyMeasurable (fun ŌČ : ő© => p ŌČ * I ŌČ) P :=
      ((stronglyMeasurable_condExp.mono (‚ĄĪ.le k)).mul
        ((stronglyMeasurable_const : StronglyMeasurable (fun _ : ő© => (1 : ‚ĄĚ))).indicator
          (hB_meas (k + 1)))).aestronglyMeasurable
    have hbound :
        ‚ąÄŠĶź ŌČ ‚ąāP, ‚ÄĖp ŌČ * I ŌČ‚ÄĖ ‚Č§ (1 : ‚ĄĚ) := by
      filter_upwards [hp_nonneg, hp_le_one] with ŌČ hp0 hp1
      rw [norm_mul]
      have hp_abs : ‚ÄĖp ŌČ‚ÄĖ ‚Č§ (1 : ‚ĄĚ) := by
        rw [Real.norm_eq_abs]
        have hp0' : 0 ‚Č§ p ŌČ := by simpa using hp0
        have hp1' : p ŌČ ‚Č§ (1 : ‚ĄĚ) := by simpa using hp1
        exact abs_le.mpr ‚ü®by linarith, hp1'‚ü©
      exact mul_le_one‚āÄ hp_abs (norm_nonneg _) (hI_abs_le_one ŌČ)
    simpa [p, I] using Integrable.of_bound hmeas 1 hbound
  ¬∑ intro k
    let I : ő© -> ‚ĄĚ := (B (k + 1)).indicator (1 : ő© -> ‚ĄĚ)
    let p : ő© -> ‚ĄĚ := P[I | ‚ĄĪ k]
    have hI_int : Integrable I P :=
      (integrable_const (c := (1 : ‚ĄĚ))).indicator (hB_meas (k + 1))
    have hI_nonneg : 0 ‚Č§ŠĶź[P] I :=
      ae_of_all P fun ŌČ => by
        by_cases hŌČ : ŌČ ‚ąą B (k + 1) <;> simp [I, hŌČ]
    have hI_le_one : I ‚Č§ŠĶź[P] fun _ : ő© => (1 : ‚ĄĚ) :=
      ae_of_all P fun ŌČ => by
        by_cases hŌČ : ŌČ ‚ąą B (k + 1) <;> simp [I, hŌČ]
    have hp_nonneg : 0 ‚Č§ŠĶź[P] p := by
      simpa [p] using condExp_nonneg (őľ := P) (m := ‚ĄĪ k) hI_nonneg
    have hp_le_one : p ‚Č§ŠĶź[P] fun _ : ő© => (1 : ‚ĄĚ) := by
      have hmono :
          P[I | ‚ĄĪ k] ‚Č§ŠĶź[P] P[(fun _ : ő© => (1 : ‚ĄĚ)) | ‚ĄĪ k] :=
        condExp_mono (őľ := P) (m := ‚ĄĪ k) hI_int (integrable_const (1 : ‚ĄĚ)) hI_le_one
      have hone :
          P[(fun _ : ő© => (1 : ‚ĄĚ)) | ‚ĄĪ k] = fun _ : ő© => (1 : ‚ĄĚ) :=
        condExp_const (őľ := P) (‚ĄĪ.le k) (1 : ‚ĄĚ)
      filter_upwards [hmono, EventuallyEq.of_eq hone] with ŌČ hmonoŌČ honeŌČ
      change P[I | ‚ĄĪ k] ŌČ ‚Č§ (1 : ‚ĄĚ)
      rw [honeŌČ] at hmonoŌČ
      exact hmonoŌČ
    have hmeas : AEStronglyMeasurable (fun ŌČ : ő© => p ŌČ ^ 2) P :=
