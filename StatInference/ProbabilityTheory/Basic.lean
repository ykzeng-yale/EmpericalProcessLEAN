  · exact aestronglyMeasurable_const
  · have hEq : (fun n => eLpNorm (Z n - fun x => 0) 2 P) =
        fun n => eLpNorm (Z n) 2 P := by
      ext n
      congr with x
      simp
    rw [hEq]
    exact hZ

