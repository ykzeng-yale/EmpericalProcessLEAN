  have hfstSupIntegrable :
      Integrable
        (fun sample : SampleAt (Observation × Observation) n =>
          vdVWWeightedClassSupremum indexClass
            (vdVWTruncatedClassFun classFun envelope M) weights
            (fun i : Fin n => (sample i).1))
