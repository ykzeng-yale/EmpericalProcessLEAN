    (hVariance :
      ‚ąÄ n, 0 < n ->
        P[(fun ŌČ => (X n ŌČ - X (n - 1) ŌČ) ^ 2) | ‚ĄĪ (n - 1)] =ŠĶź[P]
          fun ŌČ => variance * Z (n - 1) ŌČ / offspringMean ^ (2 * n))
    (hMeanPrev : ‚ąÄ n, 0 < n -> (‚ąę ŌČ, X (n - 1) ŌČ ‚ąāP) = 1) :
