        (𝓝 (⨆ n : ℕ, ENNReal.ofReal (a n))) :=
    tendsto_atTop_iSup hmono_ofReal
  have heq := tendsto_nhds_unique htend_iSup htend_ofReal
  simpa [a] using heq

