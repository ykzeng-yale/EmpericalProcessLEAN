source-facing `L^2` display.
-/
theorem durrett2019_theorem_2_2_3_integral_sq_centered_average_le_of_iIndepFun
    {Ω : Type u} [MeasurableSpace Ω] {P : Measure Ω} [IsProbabilityMeasure P]
    {X : ℕ -> Ω -> ℝ} {n : ℕ} {mu C : ℝ}
