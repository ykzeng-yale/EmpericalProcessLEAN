    (MeasureTheory.tendstoInMeasure_iff_measureReal_norm.mp htrunc) ε hε
  have hsum : Tendsto
      (fun n : ℕ =>
        (∑ k ∈ Finset.range n, P.real {ω : Ω | b n < |X n k ω|}) +
          P.real {ω : Ω |
            ε ≤ ‖(durrett2019_theorem_2_2_11_truncatedRowSum X b n ω -
