  have hF_meas : AEMeasurable (fun ω => ‖max (X n ω) 0‖ₑ) P := by
    have hterminal_meas : Measurable fun ω => max (X n ω) 0 :=
      (((hX.stronglyMeasurable n).measurable.mono (ℱ.le n) le_rfl).max
