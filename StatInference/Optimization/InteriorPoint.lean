theorem sourceGrad_dualLocalNorm_scaled_le_of_preliminaryPath_sequence_barrier_dualLaws
    {s : Set E} {hess invHess : E -> E →L[ℝ] E}
    {phiGrad : E -> E} {third : E -> E -> E -> ℝ}
    {xbar0 : E} {xseq : ℕ -> E} {tseq lambdaSeq : ℕ -> ℝ}
