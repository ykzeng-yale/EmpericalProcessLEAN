            b (n + 1))
        atTop (nhds 0)) :
    Tendsto
      (fun n : ‚Ąē =>
        (‚ąĎ k ‚ąą Finset.range n, A (k + 1) * (b (k + 2) - b (k + 1))) /
          b (n + 1))
      atTop (nhds L) := by
  have hconstant :
      Tendsto
        (fun n : ‚Ąē =>
          (‚ąĎ k ‚ąą Finset.range n, L * (b (k + 2) - b (k + 1))) /
            b (n + 1))
        atTop (nhds L) :=
    durrett2019_exercise_4_4_11_constant_weighted_tendsto
      (b := b) (L := L) hb_atTop
  have hsum :
      Tendsto
        (fun n : ‚Ąē =>
          (‚ąĎ k ‚ąą Finset.range n, L * (b (k + 2) - b (k + 1))) /
              b (n + 1) +
            (‚ąĎ k ‚ąą Finset.range n,
              (A (k + 1) - L) * (b (k + 2) - b (k + 1))) /
