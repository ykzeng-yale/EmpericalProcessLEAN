theorem durrett2019_theorem_4_5_5_ratio_tendsto_one_on_of_finite_or_max_one_normalized
    {Ω : Type*} [mΩ : MeasurableSpace Ω]
    {P : Measure Ω} {ℱ : Filtration ℕ mΩ} {B : ℕ -> Set Ω}
