          ≤ Real.log (constant eta *
              (((n + 1 : ℕ) : ℝ) ^ degree eta)) :=
        Real.log_le_log hleft_pos (hpoly_bound eta heta n sample)
      _ = Real.log (constant eta) +
          (degree eta : ℝ) * Real.log (((n + 1 : ℕ) : ℝ)) := by
        rw [Real.log_mul hconstant_pos.ne' hpow_pos.ne', Real.log_pow]

