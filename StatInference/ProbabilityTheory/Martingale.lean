    (hAinf_int : Integrable Ainf P)
    (hX0 : X 0 =ᵐ[P] 0)
    (hA0 : A 0 = 0)
    (hA_mono : ∀ᵐ ω ∂P, Monotone fun n => A n ω)
    (hA_tendsto : ∀ᵐ ω ∂P, Tendsto (fun n => A n ω) atTop (𝓝 (Ainf ω)))
