-/
theorem durrett2019_theorem_4_5_3_normalized_process_ae_tendsto_zero_on_of_transform_tendsto
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©}
    {H X b : ‚Ąē -> ő© -> ‚ĄĚ} {InfiniteVar : Set ő©}
    (hX0 : X 0 =ŠĶź[P] 0)
    (hH_eq : ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÄ n : ‚Ąē, H n ŌČ = (b n ŌČ)‚ĀĽ¬Ļ)
    (hb_nonzero : ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÄ k : ‚Ąē, b (k + 1) ŌČ ‚Č† 0)
    (hb_increment_nonneg :
      ‚ąÄŠĶź ŌČ ‚ąāP, ‚ąÄ k : ‚Ąē, 0 ‚Č§ b (k + 2) ŌČ - b (k + 1) ŌČ)
    (hb_atTop_on :
      ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą InfiniteVar ->
        Tendsto (fun n : ‚Ąē => b (n + 1) ŌČ) atTop atTop)
    (hTransform_tendsto :
      ‚ąÄŠĶź ŌČ ‚ąāP,
        ‚ąÉ Y : ‚ĄĚ,
          Tendsto (fun n : ‚Ąē => durrett2019_stochasticTransform H X n ŌČ)
            atTop (ūĚďĚ Y)) :
    ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą InfiniteVar ->
      Tendsto (fun n : ‚Ąē => X n ŌČ / b n ŌČ) atTop (ūĚďĚ 0) := by
  filter_upwards
    [hX0, hH_eq, hb_nonzero, hb_increment_nonneg, hb_atTop_on,
      hTransform_tendsto]
    with ŌČ hX0ŌČ hHŌČ hb_nonzeroŌČ hb_increment_nonnegŌČ hb_atTopŌČ
      hTransformŌČ hInfinite
  rcases hTransformŌČ with ‚ü®Y, hY‚ü©
  have hincrement :
      Tendsto
        (fun n : ‚Ąē => (X (n + 1) ŌČ - X 0 ŌČ) / b (n + 1) ŌČ)
        atTop (ūĚďĚ 0) := by
    refine
      durrett2019_exercise_4_4_11_normalized_increment_sum_tendsto_zero
        (A := fun n : ‚Ąē => durrett2019_stochasticTransform H X n ŌČ)
        (X := fun n : ‚Ąē => X n ŌČ) (b := fun n : ‚Ąē => b n ŌČ)
        ?_ ?_ hb_nonzeroŌČ (L := Y) ?_ hb_increment_nonnegŌČ
        (hb_atTopŌČ hInfinite)
    ¬∑ simp [durrett2019_stochasticTransform]
    ¬∑ intro k
      have hinc :=
        congrFun
          (durrett2019_exercise_4_4_11_stochasticTransform_increment_eq H X k) ŌČ
      calc
        durrett2019_stochasticTransform H X (k + 1) ŌČ -
            durrett2019_stochasticTransform H X k ŌČ
            = H (k + 1) ŌČ * (X (k + 1) ŌČ - X k ŌČ) := by
              simpa [Pi.sub_apply, Pi.mul_apply] using hinc
        _ = (X (k + 1) ŌČ - X k ŌČ) / b (k + 1) ŌČ := by
              rw [hHŌČ (k + 1)]
              ring
    ¬∑ exact hY.comp (tendsto_add_atTop_nat 1)
  have hshifted :
      Tendsto (fun n : ‚Ąē => X (n + 1) ŌČ / b (n + 1) ŌČ) atTop (ūĚďĚ 0) :=
    durrett2019_exercise_4_4_11_normalized_process_tendsto_zero_of_initial_zero
      (X := fun n : ‚Ąē => X n ŌČ) (b := fun n : ‚Ąē => b n ŌČ) hX0ŌČ hincrement
  exact
    (tendsto_add_atTop_iff_nat
      (f := fun n : ‚Ąē => X n ŌČ / b n ŌČ) 1).mp hshifted

