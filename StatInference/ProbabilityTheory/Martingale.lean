-/
theorem durrett2019_exercise_4_4_6_squareMinusVarianceClock_martingale_of_source
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {őľ : Measure ő©} [IsFiniteMeasure őľ] {‚ĄĪ : Filtration ‚Ąē mő©}
    {S eta : ‚Ąē -> ő© -> ‚ĄĚ} {sigmaSq : ‚Ąē -> ‚ĄĚ}
