/--
The linear transition map in the quadratic ASGD recursion:
`I - h A`.
-/
noncomputable def chewi123QuadraticStepMap
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (h : ℝ) (A : E →L[ℝ] E) : E →L[ℝ] E :=
  ContinuousLinearMap.id ℝ E - h • A

/--
Source one-step error recursion for the quadratic ASGD update.

If
`θ_{n+1} = θ_n - h_{n+1} • (A (θ_n - θ⋆) + ξ_{n+1})`, then
`δ_{n+1} = (I - h_{n+1} A) δ_n - h_{n+1} ξ_{n+1}`.
-/
theorem chewi123_quadratic_delta_step
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℝ)
    (theta thetaStar xi thetaNext : E)
    (hstep : thetaNext = theta - h • (A (theta - thetaStar) + xi)) :
    thetaNext - thetaStar =
      chewi123QuadraticStepMap h A (theta - thetaStar) - h • xi := by
  rw [hstep]
  simp [chewi123QuadraticStepMap]
  module

/--
Source-shaped quadratic ASGD trajectory interface for Theorem 12.3.
-/
structure IsChewi123QuadraticASGDTrajectory
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ)
    (theta xi : ℕ -> E) (thetaStar : E) : Prop where
  /-- The displayed quadratic stochastic-gradient update. -/
  step : ∀ n,
    theta (n + 1) =
      theta n - h (n + 1) • (A (theta n - thetaStar) + xi (n + 1))

/--
A quadratic ASGD trajectory supplies the source one-step recursion for
`δ_n = θ_n - θ⋆`.
-/
theorem IsChewi123QuadraticASGDTrajectory.delta_step
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    {A : E →L[ℝ] E} {h : ℕ -> ℝ}
    {theta xi : ℕ -> E} {thetaStar : E}
    (T : IsChewi123QuadraticASGDTrajectory A h theta xi thetaStar)
    (n : ℕ) :
    theta (n + 1) - thetaStar =
      chewi123QuadraticStepMap (h (n + 1)) A (theta n - thetaStar) -
        h (n + 1) • xi (n + 1) :=
  chewi123_quadratic_delta_step A (h (n + 1))
    (theta n) thetaStar (xi (n + 1)) (theta (n + 1)) (T.step n)

/--
Ordered transition product
`(I - h_{start+len} A) ... (I - h_{start+1} A)`.

The recursive definition avoids pretending that endomorphism composition is
commutative; the textbook product is order-sensitive.
-/
noncomputable def chewi123TransitionProductFrom
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (start : ℕ) :
    ℕ -> E →L[ℝ] E
  | 0 => 1
  | len + 1 =>
      chewi123QuadraticStepMap (h (start + len + 1)) A *
        chewi123TransitionProductFrom A h start len

/--
The successor transition product applies the new step after the previous
ordered product.
-/
theorem chewi123TransitionProductFrom_succ_apply
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ)
    (start len : ℕ) (x : E) :
    chewi123TransitionProductFrom A h start (len + 1) x =
      chewi123QuadraticStepMap (h (start + len + 1)) A
        (chewi123TransitionProductFrom A h start len x) := by
  simp [chewi123TransitionProductFrom, ContinuousLinearMap.mul_apply]

/--
Coefficient multiplying the noise increment `ξ_k` in the unrolled quadratic
ASGD recursion up to time `n`.
-/
noncomputable def chewi123NoiseCoefficient
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (k n : ℕ) : E →L[ℝ] E :=
  h k • chewi123TransitionProductFrom A h k (n - k)

/--
Pushing a previous noise coefficient through one more transition gives the
next-time coefficient.
-/
theorem chewi123_stepMap_noiseCoefficient_apply
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) {k n : ℕ}
    (hk : k ≤ n) (x : E) :
    chewi123QuadraticStepMap (h (n + 1)) A
        (chewi123NoiseCoefficient A h k n x) =
      chewi123NoiseCoefficient A h k (n + 1) x := by
  have hlen : (n + 1) - k = (n - k) + 1 := by omega
  have hidx : k + (n - k) + 1 = n + 1 := by omega
  rw [chewi123NoiseCoefficient, chewi123NoiseCoefficient, hlen]
  simp [chewi123TransitionProductFrom, hidx]

/--
Finite unrolling of the quadratic ASGD error recursion.

This is the deterministic source display immediately preceding `(12.5)`,
indexed with Lean's zero-based `range n` and increments `ξ_{j+1}`.
-/
theorem chewi123_quadratic_delta_unroll
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (delta xi : ℕ -> E)
    (hrec : ∀ n,
      delta (n + 1) =
        chewi123QuadraticStepMap (h (n + 1)) A (delta n) -
          h (n + 1) • xi (n + 1)) :
    ∀ n : ℕ,
      delta n =
        chewi123TransitionProductFrom A h 0 n (delta 0) -
          ∑ j ∈ Finset.range n,
            chewi123NoiseCoefficient A h (j + 1) n (xi (j + 1))
  | 0 => by simp [chewi123TransitionProductFrom]
  | n + 1 => by
      have ih := chewi123_quadratic_delta_unroll A h delta xi hrec n
      rw [hrec n, ih]
      rw [map_sub]
      rw [Finset.sum_range_succ]
      have hsum :
          chewi123QuadraticStepMap (h (n + 1)) A
              (∑ j ∈ Finset.range n,
                chewi123NoiseCoefficient A h (j + 1) n (xi (j + 1))) =
            ∑ j ∈ Finset.range n,
              chewi123NoiseCoefficient A h (j + 1) (n + 1) (xi (j + 1)) := by
        rw [map_sum]
        refine Finset.sum_congr rfl ?_
        intro j hj
        exact chewi123_stepMap_noiseCoefficient_apply
          A h (Nat.succ_le_of_lt (Finset.mem_range.mp hj)) (xi (j + 1))
      have hlast :
          chewi123NoiseCoefficient A h (n + 1) (n + 1) (xi (n + 1)) =
            h (n + 1) • xi (n + 1) := by
        simp [chewi123NoiseCoefficient, chewi123TransitionProductFrom]
      rw [hsum, hlast]
      rw [chewi123TransitionProductFrom_succ_apply]
      abel_nf

/--
Trajectory form of the finite quadratic-ASGD unrolling.
-/
theorem IsChewi123QuadraticASGDTrajectory.delta_unroll
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    {A : E →L[ℝ] E} {h : ℕ -> ℝ}
    {theta xi : ℕ -> E} {thetaStar : E}
    (T : IsChewi123QuadraticASGDTrajectory A h theta xi thetaStar)
    (n : ℕ) :
    theta n - thetaStar =
      chewi123TransitionProductFrom A h 0 n (theta 0 - thetaStar) -
        ∑ j ∈ Finset.range n,
          chewi123NoiseCoefficient A h (j + 1) n (xi (j + 1)) :=
  chewi123_quadratic_delta_unroll A h (fun n => theta n - thetaStar) xi
    (fun n => T.delta_step n) n

/--
Averaged nested form of the quadratic ASGD unrolling.

This is the deterministic bridge between the pointwise unrolling and Chewi's
averaged display: the only remaining step is the triangular reindexing that
packages the nested noise sum as the source coefficients `M_k^n`.
-/
theorem chewi123_quadratic_average_delta_unroll_nested
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (delta xi : ℕ -> E)
    (hrec : ∀ n,
      delta (n + 1) =
        chewi123QuadraticStepMap (h (n + 1)) A (delta n) -
          h (n + 1) • xi (n + 1))
    (invN : ℝ) (N : ℕ) :
    invN • (∑ i ∈ Finset.range N, delta i) =
      invN • (∑ i ∈ Finset.range N,
        chewi123TransitionProductFrom A h 0 i (delta 0)) -
        invN • (∑ i ∈ Finset.range N,
          ∑ j ∈ Finset.range i,
            chewi123NoiseCoefficient A h (j + 1) i (xi (j + 1))) := by
  have hunroll := chewi123_quadratic_delta_unroll A h delta xi hrec
  calc
    invN • (∑ i ∈ Finset.range N, delta i)
        = invN • (∑ i ∈ Finset.range N,
            (chewi123TransitionProductFrom A h 0 i (delta 0) -
              ∑ j ∈ Finset.range i,
                chewi123NoiseCoefficient A h (j + 1) i (xi (j + 1)))) := by
          congr 1
          refine Finset.sum_congr rfl ?_
          intro i hi
          exact hunroll i
    _ = invN • (∑ i ∈ Finset.range N,
        chewi123TransitionProductFrom A h 0 i (delta 0)) -
        invN • (∑ i ∈ Finset.range N,
          ∑ j ∈ Finset.range i,
            chewi123NoiseCoefficient A h (j + 1) i (xi (j + 1))) := by
          rw [Finset.sum_sub_distrib, smul_sub]

/--
Trajectory form of the averaged nested quadratic-ASGD unrolling.
-/
theorem IsChewi123QuadraticASGDTrajectory.average_delta_unroll_nested
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    {A : E →L[ℝ] E} {h : ℕ -> ℝ}
    {theta xi : ℕ -> E} {thetaStar : E}
    (T : IsChewi123QuadraticASGDTrajectory A h theta xi thetaStar)
    (invN : ℝ) (N : ℕ) :
    invN • (∑ i ∈ Finset.range N, (theta i - thetaStar)) =
      invN • (∑ i ∈ Finset.range N,
        chewi123TransitionProductFrom A h 0 i (theta 0 - thetaStar)) -
        invN • (∑ i ∈ Finset.range N,
          ∑ j ∈ Finset.range i,
            chewi123NoiseCoefficient A h (j + 1) i (xi (j + 1))) :=
  chewi123_quadratic_average_delta_unroll_nested A h
    (fun n => theta n - thetaStar) xi (fun n => T.delta_step n) invN N

/--
Finite-sum algebra behind the ASGD display `(12.5)`: any coefficient family
`M k` splits into a reference linear map `Ainv` plus the residual
`M k - Ainv`.
-/
theorem chewi123_asgd_noise_sum_split
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (Ainv : E →L[ℝ] E) (M : ℕ -> E →L[ℝ] E) (xi : ℕ -> E)
    (s : Finset ℕ) :
    (∑ k ∈ s, M k (xi k)) =
      (∑ k ∈ s, Ainv (xi k)) +
        ∑ k ∈ s, (M k - Ainv) (xi k) := by
  rw [← sum_add_distrib]
  refine sum_congr rfl ?_
  intro k hk
  simp

/--
Source coefficient multiplying the initial error in the averaged quadratic
ASGD display.
-/
noncomputable def chewi123InitialCoefficient
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (N : ℕ) : E →L[ℝ] E :=
  ∑ i ∈ Finset.range N, chewi123TransitionProductFrom A h 0 i

/--
Source coefficient `M_k^N` multiplying the noise increment `ξ_k` in Chewi's
averaged quadratic ASGD display.
-/
noncomputable def chewi123SourceNoiseCoefficient
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (k N : ℕ) : E →L[ℝ] E :=
  ∑ i ∈ Finset.Ico k N, chewi123NoiseCoefficient A h k i

/-- Applying the initial coefficient is the finite sum of transition products. -/
theorem chewi123InitialCoefficient_apply
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (N : ℕ) (x : E) :
    chewi123InitialCoefficient A h N x =
      ∑ i ∈ Finset.range N, chewi123TransitionProductFrom A h 0 i x := by
  simp [chewi123InitialCoefficient, ContinuousLinearMap.sum_apply]

/-- Applying `M_k^N` is the finite sum of the corresponding noise coefficients. -/
theorem chewi123SourceNoiseCoefficient_apply
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (k N : ℕ) (x : E) :
    chewi123SourceNoiseCoefficient A h k N x =
      ∑ i ∈ Finset.Ico k N, chewi123NoiseCoefficient A h k i x := by
  simp [chewi123SourceNoiseCoefficient, ContinuousLinearMap.sum_apply]

/--
Reindex the inner noise sum from zero-based `j` to Chewi's one-based noise
index `k = j + 1`.
-/
theorem chewi123_nested_noise_sum_eq_source_indexed
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (xi : ℕ -> E) (N : ℕ) :
    (∑ i ∈ Finset.range N,
      ∑ j ∈ Finset.range i,
        chewi123NoiseCoefficient A h (j + 1) i (xi (j + 1))) =
      ∑ i ∈ Finset.range N,
        ∑ k ∈ Finset.Ico 1 (i + 1),
          chewi123NoiseCoefficient A h k i (xi k) := by
  refine Finset.sum_congr rfl ?_
  intro i hi
  rw [Finset.sum_Ico_eq_sum_range]
  refine Finset.sum_congr rfl ?_
  intro j hj
  simp [Nat.add_comm]

/--
Triangular regrouping of the nested averaged-ASGD noise sum into Chewi's
source coefficients `M_k^N`.
-/
theorem chewi123_source_indexed_nested_noise_sum_eq_source_coefficients
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (xi : ℕ -> E) (N : ℕ) :
    (∑ i ∈ Finset.range N,
      ∑ k ∈ Finset.Ico 1 (i + 1),
        chewi123NoiseCoefficient A h k i (xi k)) =
      ∑ k ∈ Finset.Ico 1 N,
        chewi123SourceNoiseCoefficient A h k N (xi k) := by
  rw [Finset.sum_comm'
    (s := Finset.range N) (t := fun i => Finset.Ico 1 (i + 1))
    (t' := Finset.Ico 1 N) (s' := fun k => Finset.Ico k N)
    (f := fun i k => chewi123NoiseCoefficient A h k i (xi k))]
  · refine Finset.sum_congr rfl ?_
    intro k hk
    rw [chewi123SourceNoiseCoefficient_apply]
  · intro i k
    constructor
    · rintro ⟨hiN, hk_i⟩
      have hi_lt : i < N := Finset.mem_range.mp hiN
      have hk_ge_one : 1 ≤ k := (Finset.mem_Ico.mp hk_i).1
      have hk_le_i : k ≤ i := Nat.lt_succ_iff.mp (Finset.mem_Ico.mp hk_i).2
      exact
        ⟨Finset.mem_Ico.mpr ⟨hk_le_i, hi_lt⟩,
          Finset.mem_Ico.mpr ⟨hk_ge_one, lt_of_le_of_lt hk_le_i hi_lt⟩⟩
    · rintro ⟨hi_range, hkN⟩
      have hk_le_i : k ≤ i := (Finset.mem_Ico.mp hi_range).1
      have hi_lt : i < N := (Finset.mem_Ico.mp hi_range).2
      have hk_ge_one : 1 ≤ k := (Finset.mem_Ico.mp hkN).1
      exact
        ⟨Finset.mem_range.mpr hi_lt,
          Finset.mem_Ico.mpr ⟨hk_ge_one, Nat.lt_succ_iff.mpr hk_le_i⟩⟩

/--
Triangular regrouping of the zero-based nested noise sum into Chewi's
`M_k^N` coefficients.
-/
theorem chewi123_nested_noise_sum_eq_source_coefficients
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (xi : ℕ -> E) (N : ℕ) :
    (∑ i ∈ Finset.range N,
      ∑ j ∈ Finset.range i,
        chewi123NoiseCoefficient A h (j + 1) i (xi (j + 1))) =
      ∑ k ∈ Finset.Ico 1 N,
        chewi123SourceNoiseCoefficient A h k N (xi k) :=
  (chewi123_nested_noise_sum_eq_source_indexed A h xi N).trans
    (chewi123_source_indexed_nested_noise_sum_eq_source_coefficients A h xi N)

/--
Chewi's averaged quadratic ASGD display with source coefficients `M_0^N` and
`M_k^N`, before splitting `M_k^N` around `A^{-1}`.
-/
theorem chewi123_quadratic_average_delta_unroll_source_coefficients
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A : E →L[ℝ] E) (h : ℕ -> ℝ) (delta xi : ℕ -> E)
    (hrec : ∀ n,
      delta (n + 1) =
        chewi123QuadraticStepMap (h (n + 1)) A (delta n) -
          h (n + 1) • xi (n + 1))
    (invN : ℝ) (N : ℕ) :
    invN • (∑ i ∈ Finset.range N, delta i) =
      invN • chewi123InitialCoefficient A h N (delta 0) -
        invN • (∑ k ∈ Finset.Ico 1 N,
          chewi123SourceNoiseCoefficient A h k N (xi k)) := by
  rw [chewi123_quadratic_average_delta_unroll_nested A h delta xi hrec]
  rw [chewi123InitialCoefficient_apply]
  rw [chewi123_nested_noise_sum_eq_source_coefficients]

/--
Chewi's `(12.5)` finite-sum split for the quadratic ASGD averaged error.
-/
theorem chewi123_quadratic_average_delta_source_decomposition
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A Ainv : E →L[ℝ] E) (h : ℕ -> ℝ) (delta xi : ℕ -> E)
    (hrec : ∀ n,
      delta (n + 1) =
        chewi123QuadraticStepMap (h (n + 1)) A (delta n) -
          h (n + 1) • xi (n + 1))
    (invN : ℝ) (N : ℕ) :
    invN • (∑ i ∈ Finset.range N, delta i) =
      invN • chewi123InitialCoefficient A h N (delta 0) -
        invN • (∑ k ∈ Finset.Ico 1 N, Ainv (xi k)) -
          invN • (∑ k ∈ Finset.Ico 1 N,
            (chewi123SourceNoiseCoefficient A h k N - Ainv) (xi k)) := by
  rw [chewi123_quadratic_average_delta_unroll_source_coefficients
    A h delta xi hrec invN N]
  rw [chewi123_asgd_noise_sum_split
    (Ainv := Ainv) (M := fun k => chewi123SourceNoiseCoefficient A h k N)
    (xi := xi) (s := Finset.Ico 1 N)]
  rw [smul_add]
  module

/--
Trajectory form of Chewi's `(12.5)` finite-sum split for quadratic ASGD.
-/
theorem IsChewi123QuadraticASGDTrajectory.average_delta_source_decomposition
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    {A Ainv : E →L[ℝ] E} {h : ℕ -> ℝ}
    {theta xi : ℕ -> E} {thetaStar : E}
    (T : IsChewi123QuadraticASGDTrajectory A h theta xi thetaStar)
    (invN : ℝ) (N : ℕ) :
    invN • (∑ i ∈ Finset.range N, (theta i - thetaStar)) =
      invN • chewi123InitialCoefficient A h N (theta 0 - thetaStar) -
        invN • (∑ k ∈ Finset.Ico 1 N, Ainv (xi k)) -
          invN • (∑ k ∈ Finset.Ico 1 N,
            (chewi123SourceNoiseCoefficient A h k N - Ainv) (xi k)) :=
  chewi123_quadratic_average_delta_source_decomposition
    A Ainv h (fun n => theta n - thetaStar) xi
    (fun n => T.delta_step n) invN N

/--
`sqrt N`-scaled source display following Chewi `(12.5)`.
-/
theorem chewi123_quadratic_sqrt_average_delta_source_decomposition
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (A Ainv : E →L[ℝ] E) (h : ℕ -> ℝ) (delta xi : ℕ -> E)
    (hrec : ∀ n,
      delta (n + 1) =
        chewi123QuadraticStepMap (h (n + 1)) A (delta n) -
          h (n + 1) • xi (n + 1))
    (N : ℕ) (hN : 0 < (N : ℝ)) :
    Real.sqrt (N : ℝ) •
        ((N : ℝ)⁻¹ • (∑ i ∈ Finset.range N, delta i)) =
      (Real.sqrt (N : ℝ))⁻¹ • chewi123InitialCoefficient A h N (delta 0) -
        (Real.sqrt (N : ℝ))⁻¹ •
          (∑ k ∈ Finset.Ico 1 N, Ainv (xi k)) -
          (Real.sqrt (N : ℝ))⁻¹ •
            (∑ k ∈ Finset.Ico 1 N,
              (chewi123SourceNoiseCoefficient A h k N - Ainv) (xi k)) := by
  rw [chewi123_quadratic_average_delta_source_decomposition
    A Ainv h delta xi hrec ((N : ℝ)⁻¹) N]
  have hsqrt_pos : 0 < Real.sqrt (N : ℝ) := Real.sqrt_pos.2 hN
  have hsq : (Real.sqrt (N : ℝ)) ^ (2 : ℕ) = (N : ℝ) :=
    Real.sq_sqrt hN.le
  have hscale : Real.sqrt (N : ℝ) * (N : ℝ)⁻¹ =
      (Real.sqrt (N : ℝ))⁻¹ := by
    field_simp [hN.ne', hsqrt_pos.ne']
    nlinarith [hsq]
  rw [smul_sub, smul_sub, smul_smul, smul_smul, smul_smul, hscale]

/--
Trajectory form of the `sqrt N`-scaled source display following Chewi `(12.5)`.
-/
theorem IsChewi123QuadraticASGDTrajectory.sqrt_average_delta_source_decomposition
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    {A Ainv : E →L[ℝ] E} {h : ℕ -> ℝ}
    {theta xi : ℕ -> E} {thetaStar : E}
    (T : IsChewi123QuadraticASGDTrajectory A h theta xi thetaStar)
    (N : ℕ) (hN : 0 < (N : ℝ)) :
    Real.sqrt (N : ℝ) •
        ((N : ℝ)⁻¹ •
          (∑ i ∈ Finset.range N, (theta i - thetaStar))) =
      (Real.sqrt (N : ℝ))⁻¹ •
          chewi123InitialCoefficient A h N (theta 0 - thetaStar) -
        (Real.sqrt (N : ℝ))⁻¹ •
          (∑ k ∈ Finset.Ico 1 N, Ainv (xi k)) -
          (Real.sqrt (N : ℝ))⁻¹ •
            (∑ k ∈ Finset.Ico 1 N,
              (chewi123SourceNoiseCoefficient A h k N - Ainv) (xi k)) :=
  chewi123_quadratic_sqrt_average_delta_source_decomposition
    A Ainv h (fun n => theta n - thetaStar) xi
    (fun n => T.delta_step n) N hN

/--
Scaled ASGD averaged-error decomposition.  This is the source algebra after
the unrolled quadratic recursion has supplied

`avgDelta = invN • M0 delta0 - invN • sum_k M_k xi_k`.

With `sqrtN * invN = invSqrtN`, it rewrites the scaled averaged error as the
initial-condition term, the martingale term with coefficient `Ainv`, and the
coefficient-remainder term.
-/
theorem chewi123_asgd_scaled_average_decomposition
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (sqrtN invN invSqrtN : ℝ)
    (hscale : sqrtN * invN = invSqrtN)
    (Ainv M0 : E →L[ℝ] E) (M : ℕ -> E →L[ℝ] E)
    (delta0 : E) (xi : ℕ -> E) (N : ℕ) (avgDelta : E)
    (havg :
      avgDelta =
        invN • M0 delta0 -
          invN • ∑ k ∈ Finset.range N, M k (xi k)) :
    sqrtN • avgDelta =
      invSqrtN • M0 delta0 -
        invSqrtN • ∑ k ∈ Finset.range N, Ainv (xi k) -
          invSqrtN • ∑ k ∈ Finset.range N, (M k - Ainv) (xi k) := by
  rw [havg, smul_sub, smul_smul, smul_smul, hscale]
  rw [chewi123_asgd_noise_sum_split (Ainv := Ainv) (M := M) (xi := xi)
    (s := Finset.range N)]
  rw [smul_add]
  module

/--
Source-shaped specialization of `chewi123_asgd_scaled_average_decomposition`
with the displayed `sqrt N` and `1 / N` scaling.  This is the finite algebraic
form used just before the martingale CLT term is isolated in Chewi Theorem
12.3.
-/
theorem chewi123_asgd_sqrt_average_decomposition
    {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    (Ainv M0 : E →L[ℝ] E) (M : ℕ -> E →L[ℝ] E)
    (delta0 : E) (xi : ℕ -> E) (N : ℕ) (avgDelta : E)
    (hN : 0 < (N : ℝ))
    (havg :
      avgDelta =
        ((N : ℝ)⁻¹) • M0 delta0 -
          ((N : ℝ)⁻¹) • ∑ k ∈ Finset.range N, M k (xi k)) :
    Real.sqrt (N : ℝ) • avgDelta =
      (Real.sqrt (N : ℝ))⁻¹ • M0 delta0 -
        (Real.sqrt (N : ℝ))⁻¹ • ∑ k ∈ Finset.range N, Ainv (xi k) -
          (Real.sqrt (N : ℝ))⁻¹ •
            ∑ k ∈ Finset.range N, (M k - Ainv) (xi k) := by
  refine
    chewi123_asgd_scaled_average_decomposition
      (sqrtN := Real.sqrt (N : ℝ)) (invN := (N : ℝ)⁻¹)
      (invSqrtN := (Real.sqrt (N : ℝ))⁻¹)
      ?_ Ainv M0 M delta0 xi N avgDelta havg
  have hsqrt_pos : 0 < Real.sqrt (N : ℝ) := Real.sqrt_pos.2 hN
  have hsq : (Real.sqrt (N : ℝ)) ^ (2 : ℕ) = (N : ℝ) :=
    Real.sq_sqrt hN.le
  field_simp [hN.ne', hsqrt_pos.ne']
  nlinarith [hsq]

/--
The martingale CLT term in Chewi Theorem 12.3 is preserved by the continuous
linear map `-A^{-1}`.  This is the continuous-mapping step turning

`n^{-1/2} sum_k xi_k => Z`

into

`-n^{-1/2} sum_k A^{-1} xi_k => -A^{-1} Z`.
-/
theorem chewi123_asgd_neg_linear_noise_clt
    {Ω Ω' E : Type*} [MeasurableSpace Ω] {P : Measure Ω}
    [IsProbabilityMeasure P] [MeasurableSpace Ω'] {Q : Measure Ω'}
    [IsProbabilityMeasure Q]
    [NormedAddCommGroup E] [NormedSpace ℝ E] [MeasurableSpace E]
    [BorelSpace E] [OpensMeasurableSpace E]
    (Ainv : E →L[ℝ] E) {noiseScaled : ℕ -> Ω -> E} {Z : Ω' -> E}
    (hCLT :
      TendstoInDistribution noiseScaled atTop Z (fun _ => P) Q) :
    TendstoInDistribution
      (fun n ω => -Ainv (noiseScaled n ω)) atTop
      (fun ω => -Ainv (Z ω)) (fun _ => P) Q := by
  simpa [Function.comp_def] using
    TendstoInDistribution.continuous_comp
      (g := fun x : E => -Ainv x) Ainv.continuous.neg hCLT

/--
Gaussian laws are preserved by the same `-A^{-1}` map.  This records the
source covariance-pushforward step before later finite-dimensional matrix
work identifies the covariance as `A^{-1} S_infty A^{-1}`.
-/
theorem chewi123_asgd_neg_linear_gaussian_limit
    {Ω' E : Type*} [MeasurableSpace Ω'] {Q : Measure Ω'}
    [NormedAddCommGroup E] [NormedSpace ℝ E] [MeasurableSpace E]
    [BorelSpace E]
    (Ainv : E →L[ℝ] E) {Z : Ω' -> E}
    (hZ : HasGaussianLaw Z Q) :
    HasGaussianLaw (fun ω => -Ainv (Z ω)) Q := by
  simpa using hZ.map_fun (-Ainv)

/--
Slutsky handoff for the source display after `(12.5)`.

Once the martingale CLT supplies the weak limit of the scaled noise sum, the
initial-condition term and the coefficient-remainder term may be discharged
separately as convergence in probability to zero.  This theorem then proves
the distributional limit for the scaled averaged ASGD error.
-/
theorem chewi123_asgd_distribution_limit_of_noise_and_remainders
    {Ω Ω' E : Type*} [MeasurableSpace Ω] {P : Measure Ω}
    [IsProbabilityMeasure P] [MeasurableSpace Ω'] {Q : Measure Ω'}
    [IsProbabilityMeasure Q]
    [NormedAddCommGroup E] [NormedSpace ℝ E] [MeasurableSpace E]
    [SecondCountableTopology E] [BorelSpace E] [OpensMeasurableSpace E]
    (Ainv : E →L[ℝ] E)
    {noiseScaled scaledAverage initial remainder : ℕ -> Ω -> E}
    {Z : Ω' -> E}
    (hNoise :
      TendstoInDistribution noiseScaled atTop Z (fun _ => P) Q)
    (hInitial : TendstoInMeasure P initial atTop (fun _ => 0))
    (hRemainder : TendstoInMeasure P remainder atTop (fun _ => 0))
    (hInitial_meas : ∀ n, AEMeasurable (initial n) P)
    (hRemainder_meas : ∀ n, AEMeasurable (remainder n) P)
    (hDecomp : ∀ n,
      (fun ω => (-Ainv (noiseScaled n ω) + initial n ω) + remainder n ω)
        =ᵐ[P] scaledAverage n) :
    TendstoInDistribution scaledAverage atTop
      (fun ω => -Ainv (Z ω)) (fun _ => P) Q := by
  have hMain :
      TendstoInDistribution
        (fun n ω => -Ainv (noiseScaled n ω)) atTop
        (fun ω => -Ainv (Z ω)) (fun _ => P) Q :=
    chewi123_asgd_neg_linear_noise_clt (Ainv := Ainv) hNoise
  have hWithInitial :
      TendstoInDistribution
        (fun n => (fun ω => -Ainv (noiseScaled n ω)) + initial n) atTop
        (fun ω => -Ainv (Z ω) + (0 : E)) (fun _ => P) Q :=
    hMain.add_of_tendstoInMeasure_const hInitial hInitial_meas
  have hWithRemainder :
      TendstoInDistribution
        (fun n =>
          ((fun ω => -Ainv (noiseScaled n ω)) + initial n) + remainder n)
        atTop
        (fun ω => (-Ainv (Z ω) + (0 : E)) + (0 : E)) (fun _ => P) Q :=
    hWithInitial.add_of_tendstoInMeasure_const hRemainder hRemainder_meas
  refine hWithRemainder.congr (fun n => ?_) ?_
  · filter_upwards [hDecomp n] with ω hω
    simpa [Pi.add_apply] using hω
  · exact ae_of_all _ fun ω => by simp

/--
Chewi Theorem 12.3 handoff from a supplied martingale CLT certificate.

This wraps the proof step after `(12.5)`: the source martingale CLT supplies
the limit for the scaled noise sum, while the initial and coefficient-remainder
terms vanish in probability.
-/
theorem Chewi127MartingaleCLTCertificate.asgd_distribution_limit
    {Ω Ω' E : Type*} [MeasurableSpace Ω] {P : Measure Ω}
    [IsProbabilityMeasure P] [MeasurableSpace Ω'] {Q : Measure Ω'}
    [IsProbabilityMeasure Q]
    [NormedAddCommGroup E] [NormedSpace ℝ E] [MeasurableSpace E]
    [SecondCountableTopology E] [BorelSpace E] [OpensMeasurableSpace E]
    (C : Chewi127MartingaleCLTCertificate Ω Ω' E P Q)
    (Ainv : E →L[ℝ] E)
    {scaledAverage initial remainder : ℕ -> Ω -> E}
    (hInitial : TendstoInMeasure P initial atTop (fun _ => 0))
    (hRemainder : TendstoInMeasure P remainder atTop (fun _ => 0))
    (hInitial_meas : ∀ n, AEMeasurable (initial n) P)
    (hRemainder_meas : ∀ n, AEMeasurable (remainder n) P)
    (hDecomp : ∀ n,
      (fun ω => (-Ainv (C.noiseScaled n ω) + initial n ω) + remainder n ω)
        =ᵐ[P] scaledAverage n) :
    TendstoInDistribution scaledAverage atTop
      (fun ω => -Ainv (C.Z ω)) (fun _ => P) Q :=
  chewi123_asgd_distribution_limit_of_noise_and_remainders
    (Ainv := Ainv) (noiseScaled := C.noiseScaled) (Z := C.Z)
    C.clt hInitial hRemainder hInitial_meas hRemainder_meas hDecomp

/--
CovarianceBilinDual pullback for the `-A^{-1}` Gaussian limit in Chewi
Theorem 12.3.

This reuses the existing van der Vaart covariance-pullback primitive rather
than duplicating covariance foundations in the optimization lane.
-/
theorem Chewi127MartingaleCLTCertificate.neg_linear_covarianceBilinDual
    {Ω Ω' E : Type*} [MeasurableSpace Ω] {P : Measure Ω}
    [IsProbabilityMeasure P] [MeasurableSpace Ω'] {Q : Measure Ω'}
    [IsProbabilityMeasure Q]
    [NormedAddCommGroup E] [NormedSpace ℝ E] [MeasurableSpace E]
    [CompleteSpace E] [SecondCountableTopology E] [BorelSpace E]
    [OpensMeasurableSpace E]
    (C : Chewi127MartingaleCLTCertificate Ω Ω' E P Q)
    (Ainv : E →L[ℝ] E) (L K : StrongDual ℝ E) :
    ProbabilityTheory.covarianceBilinDual
        (Q.map fun ω => -Ainv (C.Z ω)) L K =
      vaart1998_inverseDerivativeCovarianceFunctional (-Ainv)
        (fun L0 K0 =>
          ProbabilityTheory.covarianceBilinDual (Q.map C.Z) L0 K0) L K := by
  simpa using
    vaart1998_covarianceBilinDual_inverseDerivative_map_apply_of_memLp
      (Z := C.Z) (Q := Q) (Dinv := -Ainv)
      C.clt.aemeasurable_limit C.limit_memLp L K

/--
Finite-coordinate covariance table for the `-A^{-1}` Gaussian limit in Chewi
Theorem 12.3.
-/
theorem Chewi127MartingaleCLTCertificate.neg_linear_covarianceTable
    {I Ω Ω' E : Type*} [Fintype I] [MeasurableSpace Ω] {P : Measure Ω}
    [IsProbabilityMeasure P] [MeasurableSpace Ω'] {Q : Measure Ω'}
    [IsProbabilityMeasure Q]
    [NormedAddCommGroup E] [NormedSpace ℝ E] [MeasurableSpace E]
    [CompleteSpace E] [SecondCountableTopology E] [BorelSpace E]
    [OpensMeasurableSpace E]
    (C : Chewi127MartingaleCLTCertificate Ω Ω' E P Q)
    (Ainv : E →L[ℝ] E) (coordinates : I -> StrongDual ℝ E) (i j : I) :
    vaart1998_covarianceTable coordinates
        (fun L K =>
          ProbabilityTheory.covarianceBilinDual
            (Q.map fun ω => -Ainv (C.Z ω)) L K) i j =
      vaart1998_covarianceTable
        (fun k => (coordinates k).comp (-Ainv))
        (fun L K => ProbabilityTheory.covarianceBilinDual (Q.map C.Z) L K)
        i j := by
  simpa using
    vaart1998_covarianceBilinDual_inverseDerivative_table_apply_of_memLp
      (Z := C.Z) (Q := Q) (Dinv := -Ainv)
      (coordinates := coordinates) C.clt.aemeasurable_limit C.limit_memLp i j

/--
Source-shaped Chewi Theorem 12.3 probability/covariance package from a supplied
Theorem 12.7 martingale CLT certificate and the two `o_P(1)` remainder
discharges.
-/
theorem chewi123_asgd_limit_package_of_martingale_certificate
    {Ω Ω' E : Type*} [MeasurableSpace Ω] {P : Measure Ω}
    [IsProbabilityMeasure P] [MeasurableSpace Ω'] {Q : Measure Ω'}
    [IsProbabilityMeasure Q]
    [NormedAddCommGroup E] [NormedSpace ℝ E] [MeasurableSpace E]
    [CompleteSpace E] [SecondCountableTopology E] [BorelSpace E]
    [OpensMeasurableSpace E]
    (C : Chewi127MartingaleCLTCertificate Ω Ω' E P Q)
    (Ainv : E →L[ℝ] E)
    {scaledAverage initial remainder : ℕ -> Ω -> E}
    (hInitial : TendstoInMeasure P initial atTop (fun _ => 0))
    (hRemainder : TendstoInMeasure P remainder atTop (fun _ => 0))
    (hInitial_meas : ∀ n, AEMeasurable (initial n) P)
    (hRemainder_meas : ∀ n, AEMeasurable (remainder n) P)
    (hDecomp : ∀ n,
      (fun ω => (-Ainv (C.noiseScaled n ω) + initial n ω) + remainder n ω)
        =ᵐ[P] scaledAverage n) :
    TendstoInDistribution scaledAverage atTop
        (fun ω => -Ainv (C.Z ω)) (fun _ => P) Q ∧
      HasGaussianLaw (fun ω => -Ainv (C.Z ω)) Q ∧
      ∀ L K : StrongDual ℝ E,
        ProbabilityTheory.covarianceBilinDual
            (Q.map fun ω => -Ainv (C.Z ω)) L K =
          vaart1998_inverseDerivativeCovarianceFunctional (-Ainv)
            (fun L0 K0 =>
              ProbabilityTheory.covarianceBilinDual (Q.map C.Z) L0 K0) L K :=
  ⟨C.asgd_distribution_limit Ainv hInitial hRemainder
      hInitial_meas hRemainder_meas hDecomp,
    chewi123_asgd_neg_linear_gaussian_limit (Ainv := Ainv) C.gaussian_limit,
    fun L K => C.neg_linear_covarianceBilinDual Ainv L K⟩

