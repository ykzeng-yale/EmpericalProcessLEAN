      Real.log ((cardinality n sample n : ℝ) + 1)
          ≤ Real.log (2 * (((base : ℝ) + 1) ^ n)) := hlog_le
      _ = Real.log (2 : ℝ) +
            (n : ℝ) * Real.log ((base : ℝ) + 1) := hlog_prod
      _ ≤ (n : ℝ) * Real.log (2 : ℝ) +
            (n : ℝ) * Real.log ((base : ℝ) + 1) := by nlinarith
      _ = Real.log (2 * ((base : ℝ) + 1)) * (n : ℝ) :=
        htarget_rewrite.symm

