theorem
    VdVWTheorem243DisplayedChebyshevBetaSelectedOuterProbabilityComparison.of_eventual_ghost_product_fiber_lower_bound_or_selectedNet
    {Observation : Type v} {Index : Type w} [MeasurableSpace Observation]
