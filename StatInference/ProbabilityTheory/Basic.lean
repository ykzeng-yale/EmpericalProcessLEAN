        {ω : Ω |
          (fun i : Finset.range m => X i ω) ∈
            durrett2019_theorem_2_5_5_firstCrossingBlockSet m x}) := by
  intro m _hm k _hk hmk
  rcases lt_or_gt_of_ne hmk with hlt | hgt
  · exact
      durrett2019_theorem_2_5_5_firstCrossing_events_disjoint
        (X := X) (x := x) hlt
  · exact
      (durrett2019_theorem_2_5_5_firstCrossing_events_disjoint
        (X := X) (x := x) hgt).symm

