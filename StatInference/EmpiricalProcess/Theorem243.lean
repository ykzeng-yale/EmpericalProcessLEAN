          exact measureReal_mono hsubset
    _ тЙд тИС centerIndex : Fin cardinality,
        ╬╝.real {╧Й | epsilon тЙд |X centerIndex ╧Й|} := by
          exact measureReal_iUnion_fintype_le _
    _ тЙд тИС _centerIndex : Fin cardinality,
