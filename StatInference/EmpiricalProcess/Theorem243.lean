        (vdVWProductMeasure (P.prod P) n)) :
    тИл sample : SampleAt (Observation ├Ч Observation) n,
        vdVWWeightedClassSupremum indexClass
          (fun index : Index => fun z : Observation ├Ч Observation =>
            classFun index z.1 - classFun index z.2)
          (fun _ : Fin n => (n : тДЭ)тБ╗┬╣) sample
        тИВ(vdVWProductMeasure (P.prod P) n) =
      тИл sample : SampleAt (Observation ├Ч Observation) n,
        vdVWWeightedClassSupremum indexClass
          (fun index : Index => fun z : Observation ├Ч Observation =>
            classFun index z.1 - classFun index z.2)
          (vdVWRademacherWeights sign) sample
        тИВ(vdVWProductMeasure (P.prod P) n) := by
  let constPairSup : SampleAt (Observation ├Ч Observation) n -> тДЭ :=
    fun sample =>
      vdVWWeightedClassSupremum indexClass
        (fun index : Index => fun z : Observation ├Ч Observation =>
          classFun index z.1 - classFun index z.2)
        (fun _ : Fin n => (n : тДЭ)тБ╗┬╣) sample
  let signedPairSup : SampleAt (Observation ├Ч Observation) n -> тДЭ :=
    fun sample =>
      vdVWWeightedClassSupremum indexClass
        (fun index : Index => fun z : Observation ├Ч Observation =>
          classFun index z.1 - classFun index z.2)
        (vdVWRademacherWeights sign) sample
  have hcomp :
      тИл sample : SampleAt (Observation ├Ч Observation) n,
          constPairSup
