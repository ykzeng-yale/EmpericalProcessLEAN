    integrableOn_Ioi_rpow_of_lt
      (a := (-2 : ‚ĄĚ)) (c := c) (by norm_num) hc
  have hnonneg :
      0 ‚Č§ŠĶź[volume.restrict (Set.Ioi c)] fun a : ‚ĄĚ => a ^ (-2 : ‚ĄĚ) := by
    filter_upwards
      [self_mem_ae_restrict (measurableSet_Ioi : MeasurableSet (Set.Ioi c))]
      with a ha
    exact Real.rpow_nonneg (le_of_lt (hc.trans ha)) (-2 : ‚ĄĚ)
  have hconvert :
      ENNReal.ofReal (‚ąę a in Set.Ioi c, a ^ (-2 : ‚ĄĚ) ‚ąāvolume) =
        ‚ąę‚ĀĽ a in Set.Ioi c, ENNReal.ofReal (a ^ (-2 : ‚ĄĚ)) ‚ąāvolume :=
