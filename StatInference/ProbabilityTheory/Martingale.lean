  · have hset_empty : {ω | t ≤ min (A ω) R} = (∅ : Set Ω) := by
      ext ω
      simp [htR]
    change
      P {ω | t ≤ min (A ω) R} * ENNReal.ofReal (t ^ (p - 1)) ≤
        ENNReal.ofReal (t ^ (p - 2)) *
          ∫⁻ ω in {ω | t ≤ min (A ω) R}, ‖max (X n ω) 0‖ₑ ∂P
    rw [hset_empty]
    simp

