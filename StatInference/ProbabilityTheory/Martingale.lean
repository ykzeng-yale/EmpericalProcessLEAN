            ‖max (X n ω) 0‖ₑ ∂P) =
      ∫⁻ ω,
        ‖max (X n ω) 0‖ₑ *
          ENNReal.ofReal
            (((Finset.range (n + 1)).sup' Finset.nonempty_range_add_one
                (fun k => max (X k ω) 0)) ^ (p - 1) / (p - 1)) ∂P := by
  let A : Ω -> ℝ := fun ω =>
