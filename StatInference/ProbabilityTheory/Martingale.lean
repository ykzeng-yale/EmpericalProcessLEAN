  intro n
  have hstep :=
    durrett2019_example_4_4_9_branchingProcess_second_moment_integral_recurrence
      (P := P) (‚ĄĪ := ‚ĄĪ) (X := X) (Z := Z)
      (offspringMean := offspringMean) (variance := variance)
