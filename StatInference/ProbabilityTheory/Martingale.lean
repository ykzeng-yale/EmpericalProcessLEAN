      ∀ n, (∫⁻ ω, ENNReal.ofReal (durrett2019_runningAbsMax X n ω) ∂P) ≤ C) :
    (∫⁻ ω,
        ⨆ n : ℕ, ENNReal.ofReal (durrett2019_runningAbsMax X n ω) ∂P) ≤ C := by
