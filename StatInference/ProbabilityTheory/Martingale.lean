    [durrett2019_theorem_4_3_4_conditional_borel_cantelli
      (μ := P) (ℱ := ℱ) (B := B) hB,
      durrett2019_theorem_4_5_5_ratio_tendsto_one_of_adapted_conditionalProbabilitySum_atTop
        (P := P) (ℱ := ℱ) (B := B) hB] with ω hBC hratio
