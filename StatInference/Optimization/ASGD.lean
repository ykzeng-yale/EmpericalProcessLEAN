                        (S.projectedCompensatedTaylorErrorFactor L N t k ω))
              _ = ‖S.projectedCompensatedTaylorErrorFactor L N t k ω‖ := by
                    simp
          exact mul_le_mul_of_nonneg_left hdiff_le (Nat.cast_nonneg k)

