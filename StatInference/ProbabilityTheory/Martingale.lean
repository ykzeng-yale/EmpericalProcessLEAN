/--
Durrett 2019, Theorem 4.5.7 deterministic RHS support.

For each fixed positive `b`, the inner integral after Tonelli collapses to the
tail probability times the square-root layer-cake weight.
-/
theorem durrett2019_theorem_4_5_7_tail_cut_inner_lintegral_eq_tail_weight
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©} [IsFiniteMeasure P]
    {Ainf : ő© -> ‚ĄĚ} {b : ‚ĄĚ} (hb : 0 < b) :
    (‚ąę‚ĀĽ a in Set.Ioi (0 : ‚ĄĚ),
        P {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} /
          (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě) ‚ąāvolume) =
      P {ŌČ : ő© | b < Ainf ŌČ} *
        ENNReal.ofReal (b ^ (((1 : ‚ĄĚ) / 2) - 1)) := by
  let C : ‚ĄĚ‚Č•0‚ąě := P {ŌČ : ő© | b < Ainf ŌČ}
  have hC_ne_top : C ‚Č† ‚ąě := by
    exact measure_ne_top P {ŌČ : ő© | b < Ainf ŌČ}
  have hpoint :
      Set.EqOn
        (fun a : ‚ĄĚ =>
          P {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} /
            (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě))
        (fun a : ‚ĄĚ =>
          (Set.Ioi (Real.sqrt b)).indicator
            (fun a : ‚ĄĚ => C / (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě)) a)
        (Set.Ioi (0 : ‚ĄĚ)) := by
    intro a ha
    have ha_pos : 0 < a := ha
