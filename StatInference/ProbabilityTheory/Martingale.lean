    fun k => {ω : Ω | ∀ n, A (n + 1) ω ≤ (k : ℝ) ^ 2}
  let N : ℕ -> Ω -> ℕ∞ :=
    fun k => durrett2019_theorem_4_5_2_firstPredictableAbove A (k : ℝ)
  have hcover :
