/--
Bad-event inclusion for the final Theorem 2.4.3 untruncation step.

If the population envelope tail is at most `epsilon / 3`, then a large
untruncated centered supremum forces either a large fixed-`M` truncated
centered supremum or a large empirical envelope-tail average.
-/
theorem vdVWTheorem243_untruncated_centered_badEvent_subset_truncated_or_empiricalTail
    {Observation : Type u} {Index : Type v} [MeasurableSpace Observation]
    {P : Measure Observation} [IsProbabilityMeasure P] {n : тДХ}
    {indexClass : Set Index} {classFun : Index -> Observation -> тДЭ}
    {envelope : Observation -> тДЭ} {M epsilon : тДЭ}
    (henvelope : VdVWClassEnvelope indexClass classFun envelope)
    (hn : 0 < n)
    (hepsilon : 0 < epsilon)
    (hclass : VdVWClassCoordinateMeasurable indexClass classFun)
    (henv : Measurable envelope)
    (hclassIntegrable :
      тИА index, index тИИ indexClass -> Integrable (classFun index) P)
    (htruncIntegrable :
      тИА index, index тИИ indexClass ->
        Integrable (vdVWTruncatedClassFun classFun envelope M index) P)
    (htailIntegrable :
      Integrable (Set.indicator {x | M < envelope x} envelope) P)
    (hbdd_truncated :
      тИА sample : SampleAt Observation n,
        BddAbove
          (vdVWWeightedClassValueSet indexClass
            (fun index : Index => fun observation : Observation =>
              vdVWTruncatedClassFun classFun envelope M index observation -
                тИл x, vdVWTruncatedClassFun classFun envelope M index x тИВP)
            (fun _ : Fin n => (n : тДЭ)тБ╗┬╣) sample))
    (hpopulationTail_le :
      тИл x, Set.indicator {y | M < envelope y} envelope x тИВP тЙд
        epsilon / 3) :
    {sample : SampleAt Observation n |
      epsilon <
        dist
          (vdVWWeightedClassSupremum indexClass
            (fun index : Index => fun observation : Observation =>
              classFun index observation - тИл x, classFun index x тИВP)
            (fun _ : Fin n => (n : тДЭ)тБ╗┬╣) sample) 0} тКЖ
      {sample : SampleAt Observation n |
        epsilon / 3 <
          dist
            (vdVWWeightedClassSupremum indexClass
              (fun index : Index => fun observation : Observation =>
                vdVWTruncatedClassFun classFun envelope M index observation -
                  тИл x, vdVWTruncatedClassFun classFun envelope M index x тИВP)
              (fun _ : Fin n => (n : тДЭ)тБ╗┬╣) sample) 0} тИк
      {sample : SampleAt Observation n |
        ENNReal.ofReal (epsilon / 3) <
          ENNReal.ofReal
            (empiricalAverage sample
              (fun x => Set.indicator {y | M < envelope y} envelope x))} := by
  intro sample hbad
  let origCentered : Index -> Observation -> тДЭ :=
    fun index observation =>
      classFun index observation - тИл x, classFun index x тИВP
  let truncCentered : Index -> Observation -> тДЭ :=
    fun index observation =>
      vdVWTruncatedClassFun classFun envelope M index observation -
        тИл x, vdVWTruncatedClassFun classFun envelope M index x тИВP
  let empiricalTail : тДЭ :=
    empiricalAverage sample
      (fun x => Set.indicator {y | M < envelope y} envelope x)
  let populationTail : тДЭ :=
    тИл x, Set.indicator {y | M < envelope y} envelope x тИВP
  let untruncatedSup : тДЭ :=
    vdVWWeightedClassSupremum indexClass origCentered
      (fun _ : Fin n => (n : тДЭ)тБ╗┬╣) sample
  let truncatedSup : тДЭ :=
    vdVWWeightedClassSupremum indexClass truncCentered
      (fun _ : Fin n => (n : тДЭ)тБ╗┬╣) sample
  by_cases htrunc_bad : epsilon / 3 < dist truncatedSup 0
  ┬╖ left
    simpa [truncatedSup, truncCentered] using htrunc_bad
  ┬╖ right
    by_contra hemp_bad
    have hthird_nonneg : 0 тЙд epsilon / 3 := by linarith
    have hemp_le : empiricalTail тЙд epsilon / 3 := by
      by_contra hnot
      have hemp_gt : epsilon / 3 < empiricalTail := lt_of_not_ge hnot
      exact hemp_bad
        ((ENNReal.ofReal_lt_ofReal_iff_of_nonneg hthird_nonneg).mpr
          hemp_gt)
    have htrunc_nonneg : 0 тЙд truncatedSup :=
      vdVWWeightedClassSupremum_nonneg indexClass truncCentered
