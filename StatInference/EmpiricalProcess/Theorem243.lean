                  vdVWTruncatedClassFun classFun envelope M index pair.1 -
                    vdVWTruncatedClassFun classFun envelope M index pair.2)
                (vdVWRademacherWeights z.1) z.2| := by
          simpa [signedBad, Real.dist_eq, sub_zero] using hzbad
