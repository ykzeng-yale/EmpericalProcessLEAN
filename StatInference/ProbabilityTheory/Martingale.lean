        (P := P) (A := A) (Ainf := Ainf) hAinf_int hA0 hA_mono hA_tendsto
  have hiSup_ne_top :
      (‚ąę‚ĀĽ ŌČ,
          ‚®Ü n : ‚Ąē, ENNReal.ofReal (durrett2019_runningAbsMax X n ŌČ) ‚ąāP) ‚Č† ‚ąě := by
    exact ne_top_of_le_ne_top
      (ENNReal.mul_ne_top (by norm_num : (3 : ‚ĄĚ‚Č•0‚ąě) ‚Č† ‚ąě) hS_ne_top)
      hiSup_bound
  have hBdd :
      ‚ąÄŠĶź ŌČ ‚ąāP,
        BddAbove (Set.range fun n => durrett2019_runningAbsMax X n ŌČ) :=
    durrett2019_runningAbsMax_ae_bddAbove_of_iSup_lintegral_ne_top
      (P := P) (X := X)
      (fun n => durrett2019_runningAbsMax_measurable
        (P := P) (‚ĄĪ := ‚ĄĪ) (X := X) hX n)
