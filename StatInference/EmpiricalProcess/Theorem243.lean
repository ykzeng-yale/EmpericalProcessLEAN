    vdVWTheorem243FiniteCenterExpectedSupremum ╬╝ X тЙд
      (cardinality : тДЭ) * Real.sqrt (2 * Real.pi * (c : тДЭ)) := by
  calc
    vdVWTheorem243FiniteCenterExpectedSupremum ╬╝ X
        тЙд тИл t in Set.Ioi (0 : тДЭ),
            (cardinality : тДЭ) *
              (2 * Real.exp (-(t ^ 2) / (2 * (c : тДЭ)))) :=
          vdVWTheorem243FiniteCenterExpectedSupremum_le_integral_subGaussian_tail_bound
            hcardinality X hX
            (vdVWTheorem243_subGaussian_tail_bound_integrable
              (cardinality := cardinality) (c := c) hc)
    _ = (cardinality : тДЭ) * Real.sqrt (2 * Real.pi * (c : тДЭ)) :=
          vdVWTheorem243_integral_subGaussian_tail_bound_eq
            (cardinality := cardinality) (c := c) hc

/-- The finite-center expected supremum is nonnegative for a nonempty net. -/
theorem vdVWTheorem243FiniteCenterExpectedSupremum_nonneg
    {╬й : Type u} [MeasurableSpace ╬й] {╬╝ : Measure ╬й}
    {cardinality : тДХ} [Nonempty (Fin cardinality)]
    (X : Fin cardinality -> ╬й -> тДЭ) :
    0 тЙд vdVWTheorem243FiniteCenterExpectedSupremum ╬╝ X := by
  unfold vdVWTheorem243FiniteCenterExpectedSupremum
  apply integral_nonneg
  intro ╧Й
  exact
    (abs_nonneg (X (Classical.arbitrary (Fin cardinality)) ╧Й)).trans
      (Finite.le_ciSup (fun centerIndex : Fin cardinality => |X centerIndex ╧Й|)
        (Classical.arbitrary (Fin cardinality)))

/--
An almost-sure upper bound on the finite-center supremum implies the same
upper bound on its expectation.

This is the deterministic expectation handoff used after the later
tail-to-expectation/Orlicz maximal inequality supplies the a.e. bound.
-/
theorem vdVWTheorem243FiniteCenterExpectedSupremum_le_of_ae_le
    {╬й : Type u} [MeasurableSpace ╬й] {╬╝ : Measure ╬й} [IsProbabilityMeasure ╬╝]
    {cardinality : тДХ} (X : Fin cardinality -> ╬й -> тДЭ) {upper : тДЭ}
    (hintegrable :
      Integrable (fun ╧Й =>
        тиЖ centerIndex : Fin cardinality, |X centerIndex ╧Й|) ╬╝)
    (hupper : тИАс╡Р ╧Й тИВ╬╝,
