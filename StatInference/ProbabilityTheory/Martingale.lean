  intro k _hk
  have hdiff : MemLp (fun ŌČ => X (k + 1) ŌČ - X k ŌČ) (2 : ‚ĄĚ‚Č•0‚ąě) P :=
    (hX_memLp_two (k + 1)).sub (hX_memLp_two k)
