          simpa [second] using hbase
    _ = S + (2 : ℝ≥0∞) * S := by rw [hsplit, hfirst, hsecond]
    _ = (3 : ℝ≥0∞) * S := by
      nth_rewrite 1 [← one_mul S]
      rw [← add_mul]
      norm_num

