theorem inverseHessianQuadraticUpper_of_dualLocalNorm_le_div_one_sub
    {invHess : E -> E →L[ℝ] E} {x y : E} {M r : ℝ}
    (hMr_lt : M * r < 1)
    (hx_nonneg : ∀ v : E, 0 ≤ inner ℝ v (invHess x v))
