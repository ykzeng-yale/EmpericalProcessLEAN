    (‚ąĎ k ‚ąą Finset.Ico m n, q k) ‚Č§ ‚ąĎ' j : ‚Ąē, q (m + j) := by
  rw [Finset.sum_Ico_eq_sum_range]
  refine Summable.sum_le_tsum (Finset.range (n - m)) (fun j _hj => ?_) ?_
  ¬∑ exact hq_nonneg (m + j)
  ¬∑ exact hq_summable.comp_injective (add_right_injective m)

