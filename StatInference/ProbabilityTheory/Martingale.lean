/--
Durrett 2019, Theorem 4.5.3 variance-ratio integrability support.

If the predictable clock is integrable at every time and `1 <= f(A_n)`, then
the variance-ratio increment is integrable.  This is the honest source-side
replacement for the formerly explicit `hratio_int` assumption.
-/
theorem durrett2019_theorem_4_5_3_variance_ratio_integrable_of_clock_integrable
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} {‚ĄĪ : Filtration ‚Ąē mő©}
    {A : ‚Ąē -> ő© -> ‚ĄĚ} {f : ‚ĄĚ -> ‚ĄĚ}
    (hA_predictable : IsStronglyPredictable ‚ĄĪ A)
    (hf_cont : Continuous f)
    (hf_one_le : ‚ąÄ n : ‚Ąē, ‚ąÄ ŌČ : ő©, 1 ‚Č§ f (A n ŌČ))
    (hA_int : ‚ąÄ n : ‚Ąē, Integrable (A n) P) :
    ‚ąÄ k : ‚Ąē,
      Integrable
        (fun ŌČ => (A (k + 1) ŌČ - A k ŌČ) / (f (A (k + 1) ŌČ)) ^ 2) P := by
  intro k
  let U : ő© -> ‚ĄĚ := fun ŌČ => (f (A (k + 1) ŌČ))‚ĀĽ¬Ļ ^ 2
  let Y : ő© -> ‚ĄĚ := fun ŌČ => A (k + 1) ŌČ - A k ŌČ
  have hY_int : Integrable Y P := by
    dsimp [Y]
    exact (hA_int (k + 1)).sub (hA_int k)
  have hU_sm : AEStronglyMeasurable U P := by
    have hA_sub : StronglyMeasurable[‚ĄĪ (k + 1)] (A (k + 1)) :=
      hA_predictable.stronglyAdapted (k + 1)
    have hA_sm : StronglyMeasurable (A (k + 1)) :=
      hA_sub.mono (‚ĄĪ.le (k + 1))
    have hfA_sm : StronglyMeasurable (fun ŌČ : ő© => f (A (k + 1) ŌČ)) :=
      hf_cont.comp_stronglyMeasurable hA_sm
    have hrec :
        StronglyMeasurable (fun ŌČ : ő© => (1 : ‚ĄĚ) / f (A (k + 1) ŌČ)) :=
      stronglyMeasurable_const.div hfA_sm
    have hpow :
        StronglyMeasurable (fun ŌČ : ő© => ((1 : ‚ĄĚ) / f (A (k + 1) ŌČ)) ^ 2) :=
      hrec.pow 2
    simpa [U, one_div] using hpow.aestronglyMeasurable
  have hU_abs_le : ‚ąÄŠĶź ŌČ ‚ąāP, |U ŌČ| ‚Č§ 1 := by
    refine ae_of_all P fun ŌČ => ?_
    have hpos : 0 < f (A (k + 1) ŌČ) :=
      zero_lt_one.trans_le (hf_one_le (k + 1) ŌČ)
    have hinv_nonneg : 0 ‚Č§ (f (A (k + 1) ŌČ))‚ĀĽ¬Ļ :=
      inv_nonneg.mpr hpos.le
    have hinv_le : (f (A (k + 1) ŌČ))‚ĀĽ¬Ļ ‚Č§ 1 :=
      inv_le_one_of_one_le‚āÄ (hf_one_le (k + 1) ŌČ)
    have hsquare_le : (f (A (k + 1) ŌČ))‚ĀĽ¬Ļ ^ 2 ‚Č§ 1 := by
      calc
        (f (A (k + 1) ŌČ))‚ĀĽ¬Ļ ^ 2
            = (f (A (k + 1) ŌČ))‚ĀĽ¬Ļ * (f (A (k + 1) ŌČ))‚ĀĽ¬Ļ := by
              ring
        _ ‚Č§ 1 * 1 :=
            mul_le_mul hinv_le hinv_le hinv_nonneg zero_le_one
        _ = 1 := by ring
    have hU_nonneg : 0 ‚Č§ U ŌČ := by
      simp [U, sq_nonneg]
    simpa [U, abs_of_nonneg hU_nonneg] using hsquare_le
  have hbase : Integrable (fun ŌČ => U ŌČ * Y ŌČ) P :=
    durrett2019_integrable_mul_of_abs_le_one
      (P := P) (U := U) (Y := Y) hY_int hU_sm hU_abs_le
  have hratio_eq :
      (fun ŌČ => U ŌČ * Y ŌČ) =ŠĶź[P]
        fun ŌČ => (A (k + 1) ŌČ - A k ŌČ) / (f (A (k + 1) ŌČ)) ^ 2 := by
    refine ae_of_all P fun ŌČ => ?_
    simp [U, Y, div_eq_mul_inv, mul_comm]
  exact (integrable_congr hratio_eq).mp hbase

/--
