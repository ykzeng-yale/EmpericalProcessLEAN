    ∫ t in Set.Ici (0 : ℝ), (max t (1 : ℝ))⁻¹ ^ 2 ∂volume = 2 := by
  let g : ℝ -> ℝ := fun t => (max t (1 : ℝ))⁻¹ ^ 2
  have hIcc_int : IntegrableOn g (Set.Icc (0 : ℝ) 1) volume := by
    exact
