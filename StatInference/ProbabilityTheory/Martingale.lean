      Integrable (fun ŌČ => ‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2) P) :
    (‚ąĎ k ‚ąą Finset.range N,
        ‚ąę ŌČ, (A (k + 1) ŌČ - A k ŌČ) / (f (A (k + 1) ŌČ)) ^ 2 ‚ąāP) ‚Č§
      ‚ąę ŌČ, (‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2) ‚ąāP := by
  let ratio : ‚Ąē -> ő© -> ‚ĄĚ := fun k ŌČ =>
    (A (k + 1) ŌČ - A k ŌČ) / (f (A (k + 1) ŌČ)) ^ 2
  have hsum_int :
      Integrable (fun ŌČ => ‚ąĎ k ‚ąą Finset.range N, ratio k ŌČ) P := by
    exact integrable_finsetSum (Finset.range N) (fun k hk => hratio_int k hk)
  calc
    (‚ąĎ k ‚ąą Finset.range N,
        ‚ąę ŌČ, (A (k + 1) ŌČ - A k ŌČ) / (f (A (k + 1) ŌČ)) ^ 2 ‚ąāP)
        = ‚ąę ŌČ, ‚ąĎ k ‚ąą Finset.range N, ratio k ŌČ ‚ąāP := by
          simpa [ratio] using
            (integral_finsetSum (Finset.range N)
              (f := ratio) (őľ := P) (fun k hk => hratio_int k hk)).symm
    _ ‚Č§ ‚ąę ŌČ, (‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2) ‚ąāP := by
        refine integral_mono_ae hsum_int hclock_int (ae_of_all P fun ŌČ => ?_)
        simpa [ratio] using
          durrett2019_theorem_4_5_3_finite_sum_variance_ratio_le_integral_clock
            (f := f) (A := fun k => A k ŌČ) (N := N)
            (fun k hk => hA_mono_step k hk ŌČ)
            (fun k hk => hf_mono k hk ŌČ)
            (fun k hk => hf_one_le k hk ŌČ)
            (fun k hk => hf_int k hk ŌČ)

/--
Durrett 2019, Theorem 4.5.3 integrated summability package.

This is the expectation-level counterpart of V212: a uniform bound on the
integrated finite clock estimates proves summability of the variance-ratio
expectations consumed by the V209 source endpoint.
-/
theorem durrett2019_theorem_4_5_3_integral_variance_ratio_summable_of_integral_clock_bound
    {ő© : Type*} [mő© : MeasurableSpace ő©] {P : Measure ő©}
    {f : ‚ĄĚ -> ‚ĄĚ} {A : ‚Ąē -> ő© -> ‚ĄĚ} {C : ‚ĄĚ}
    (hA_mono_step : ‚ąÄ k : ‚Ąē, ‚ąÄ ŌČ : ő©, A k ŌČ ‚Č§ A (k + 1) ŌČ)
    (hf_mono :
      ‚ąÄ k : ‚Ąē, ‚ąÄ ŌČ : ő©,
        MonotoneOn f (Set.Icc (A k ŌČ) (A (k + 1) ŌČ)))
    (hf_one_le :
      ‚ąÄ k : ‚Ąē, ‚ąÄ ŌČ : ő©,
        ‚ąÄ t ‚ąą Set.Icc (A k ŌČ) (A (k + 1) ŌČ), 1 ‚Č§ f t)
    (hf_int :
      ‚ąÄ k : ‚Ąē, ‚ąÄ ŌČ : ő©,
        IntervalIntegrable (fun t => (f t)‚ĀĽ¬Ļ ^ 2) volume
          (A k ŌČ) (A (k + 1) ŌČ))
    (hratio_int :
      ‚ąÄ k : ‚Ąē,
        Integrable
          (fun ŌČ => (A (k + 1) ŌČ - A k ŌČ) / (f (A (k + 1) ŌČ)) ^ 2) P)
    (hclock_int :
      ‚ąÄ N : ‚Ąē, Integrable (fun ŌČ => ‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2) P)
    (hclock_bound :
      ‚ąÄ N : ‚Ąē, ‚ąę ŌČ, (‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2) ‚ąāP ‚Č§ C) :
    Summable fun k : ‚Ąē =>
      ‚ąę ŌČ, (A (k + 1) ŌČ - A k ŌČ) / (f (A (k + 1) ŌČ)) ^ 2 ‚ąāP := by
  refine summable_of_sum_range_le (c := C) ?hnonneg ?hbound
  ¬∑ intro k
    exact
      integral_nonneg fun ŌČ =>
        div_nonneg (sub_nonneg.mpr (hA_mono_step k ŌČ)) (sq_nonneg _)
  ¬∑ intro N
    exact
      (durrett2019_theorem_4_5_3_finite_integral_variance_ratio_le_integral_clock
        (P := P) (f := f) (A := A) (N := N)
        (fun k _hk ŌČ => hA_mono_step k ŌČ)
        (fun k _hk ŌČ => hf_mono k ŌČ)
        (fun k _hk ŌČ => hf_one_le k ŌČ)
        (fun k _hk ŌČ => hf_int k ŌČ)
        (fun k _hk => hratio_int k)
        (hclock_int N)).trans
        (hclock_bound N)

