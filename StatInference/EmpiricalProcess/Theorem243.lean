  let centeredSup : SampleAt Observation n -> ℝ :=
    fun sample =>
      vdVWWeightedClassSupremum indexClass
        (fun index : Index => fun observation : Observation =>
          vdVWTruncatedClassFun classFun envelope M index observation -
