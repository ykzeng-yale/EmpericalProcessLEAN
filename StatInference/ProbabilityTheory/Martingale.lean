/--
Durrett 2019, Exercise 4.4.11 deterministic support: the centered Toeplitz
remainder vanishes when the scaled partial sums converge, the normalizer has
nonnegative increments, and the normalizer diverges.
-/
theorem durrett2019_exercise_4_4_11_centered_toeplitz_remainder_tendsto_zero
    {A b : ‚Ąē -> ‚ĄĚ} {L : ‚ĄĚ}
    (hA_tendsto : Tendsto (fun n : ‚Ąē => A (n + 1)) atTop (nhds L))
    (hb_increment_nonneg : ‚ąÄ k : ‚Ąē, 0 ‚Č§ b (k + 2) - b (k + 1))
    (hb_atTop : Tendsto (fun n : ‚Ąē => b (n + 1)) atTop atTop) :
    Tendsto
      (fun n : ‚Ąē =>
        (‚ąĎ k ‚ąą Finset.range n,
          (A (k + 1) - L) * (b (k + 2) - b (k + 1))) /
          b (n + 1))
      atTop (nhds 0) := by
  let w : ‚Ąē -> ‚ĄĚ := fun k => b (k + 2) - b (k + 1)
  let centered : ‚Ąē -> ‚ĄĚ := fun k => A (k + 1) - L
  have hcentered_tendsto : Tendsto centered atTop (nhds 0) := by
    simpa [centered] using
      hA_tendsto.sub (tendsto_const_nhds : Tendsto (fun _ : ‚Ąē => L) atTop (nhds L))
  have hw_nonneg : 0 ‚Č§ w := fun k => hb_increment_nonneg k
  have hsumw_atTop : Tendsto (fun n : ‚Ąē => ‚ąĎ k ‚ąą Finset.range n, w k) atTop atTop := by
    have hb_sub :
        Tendsto (fun n : ‚Ąē => b (n + 1) - b 1) atTop atTop := by
      simpa [sub_eq_add_neg] using
        tendsto_atTop_add_const_right atTop (-(b 1)) hb_atTop
    refine hb_sub.congr' ?_
    exact Eventually.of_forall fun n => by
      simp [w, durrett2019_exercise_4_4_11_weight_increment_sum_eq (b := b) n]
  have hterm_little :
      (fun k : ‚Ąē => centered k * w k) =o[atTop] w := by
    rw [Asymptotics.isLittleO_iff]
    intro c hc
    rcases Metric.tendsto_atTop.1 hcentered_tendsto c hc with ‚ü®N, hN‚ü©
    filter_upwards [eventually_ge_atTop N] with k hk
    have hcentered_norm_le : ‚ÄĖcentered k‚ÄĖ ‚Č§ c := by
      exact le_of_lt (by simpa [dist_eq_norm] using hN k hk)
    calc
      ‚ÄĖcentered k * w k‚ÄĖ = ‚ÄĖcentered k‚ÄĖ * ‚ÄĖw k‚ÄĖ := norm_mul _ _
      _ ‚Č§ c * ‚ÄĖw k‚ÄĖ :=
        mul_le_mul_of_nonneg_right hcentered_norm_le (norm_nonneg _)
  have hsum_little :
      (fun n : ‚Ąē => ‚ąĎ k ‚ąą Finset.range n, centered k * w k) =o[atTop]
        fun n : ‚Ąē => ‚ąĎ k ‚ąą Finset.range n, w k :=
    Asymptotics.IsLittleO.sum_range hterm_little hw_nonneg hsumw_atTop
  have hdiv_zero :
      Tendsto
        (fun n : ‚Ąē =>
          (‚ąĎ k ‚ąą Finset.range n, centered k * w k) /
            (‚ąĎ k ‚ąą Finset.range n, w k))
        atTop (nhds 0) :=
    hsum_little.tendsto_div_nhds_zero
  have hweight_ratio :
      Tendsto
        (fun n : ‚Ąē => (‚ąĎ k ‚ąą Finset.range n, w k) / b (n + 1))
        atTop (nhds 1) := by
    simpa [w] using
      durrett2019_exercise_4_4_11_constant_weighted_tendsto
        (b := b) (L := (1 : ‚ĄĚ)) hb_atTop
  have hproduct :
      Tendsto
        (fun n : ‚Ąē =>
          ((‚ąĎ k ‚ąą Finset.range n, centered k * w k) /
              (‚ąĎ k ‚ąą Finset.range n, w k)) *
            ((‚ąĎ k ‚ąą Finset.range n, w k) / b (n + 1)))
        atTop (nhds (0 * 1)) :=
    hdiv_zero.mul hweight_ratio
  have hproduct_zero :
      Tendsto
        (fun n : ‚Ąē =>
          ((‚ąĎ k ‚ąą Finset.range n, centered k * w k) /
              (‚ąĎ k ‚ąą Finset.range n, w k)) *
            ((‚ąĎ k ‚ąą Finset.range n, w k) / b (n + 1)))
        atTop (nhds 0) := by
    simpa using hproduct
  refine hproduct_zero.congr' ?_
  filter_upwards [hsumw_atTop.eventually_ne_atTop (0 : ‚ĄĚ)] with n hsumw_ne
  field_simp [hsumw_ne]
  ring

/--
Durrett 2019, Exercise 4.4.11 deterministic support: the Toeplitz weighted
average of the scaled partial sums converges to the same limit under the
