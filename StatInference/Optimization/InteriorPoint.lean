      (a := a) (t := tMain)
      (phiBound :=
        lambdaPre + |tPre| * dualLocalNorm invHess x (phiGrad xbar0))
      (objBound := dualLocalNorm invHess x (tMain • a))
      hphi le_rfl hbudget hdual_add

