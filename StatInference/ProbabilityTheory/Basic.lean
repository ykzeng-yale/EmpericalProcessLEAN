theorem durrett2019_theorem_2_5_8_ae_randomSeriesConverges_of_truncated_centered_of_realSeriesConverges_of_tsum_tail_ne_top
    {Ω : Type u} [MeasurableSpace Ω] {P : Measure Ω}
    {X : ℕ -> Ω -> ℝ} {A : ℝ} {a : ℕ -> ℝ}
    (htail : (∑' n : ℕ, P {ω : Ω | A < |X n ω|}) ≠ ∞)
    (hcenter :
