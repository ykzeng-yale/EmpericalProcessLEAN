theorem positiveOrthantNegLog_localNorm_eq_sqrtCoord_norm {d : ℕ}
    {x : EuclideanSpace ℝ (Fin d)} (hx : x ∈ positiveOrthant (d := d))
    (v : EuclideanSpace ℝ (Fin d)) :
    localNorm positiveOrthantNegLogHessCLM x v =
      ‖(positiveOrthantNegLogSqrtCoord x).toContinuousLinearMap v‖ := by
  let S : EuclideanSpace ℝ (Fin d) →L[ℝ] EuclideanSpace ℝ (Fin d) :=
    (positiveOrthantNegLogSqrtCoord x).toContinuousLinearMap
  have hmodel :
      positiveOrthantNegLogHessCLM x = (ContinuousLinearMap.adjoint S).comp S := by
    simpa [S] using positiveOrthantNegLogHessCLM_sqrtCoord_model hx
  have hquad :
      inner ℝ v (positiveOrthantNegLogHessCLM x v) = ‖S v‖ ^ (2 : ℕ) := by
    rw [hmodel]
    simpa using (ContinuousLinearMap.apply_norm_sq_eq_inner_adjoint_right S v).symm
  change Real.sqrt (inner ℝ v (positiveOrthantNegLogHessCLM x v)) = ‖S v‖
  rw [hquad]
  exact Real.sqrt_sq (norm_nonneg (S v))

theorem euclideanSpace_norm_le_sqrt_fin_mul_of_abs_coord_le {d : ℕ}
    {z : EuclideanSpace ℝ (Fin d)} {r : ℝ}
    (hr : 0 ≤ r)
    (hcoord : ∀ i : Fin d, |z i| ≤ r) :
    ‖z‖ ≤ Real.sqrt (d : ℝ) * r := by
  have hrhs_nonneg : 0 ≤ Real.sqrt (d : ℝ) * r :=
    mul_nonneg (Real.sqrt_nonneg _) hr
  refine (sq_le_sq₀ (norm_nonneg z) hrhs_nonneg).mp ?_
  rw [EuclideanSpace.real_norm_sq_eq, mul_pow, Real.sq_sqrt (Nat.cast_nonneg d)]
  calc
    ∑ i : Fin d, (z i) ^ (2 : ℕ)
        ≤ ∑ i : Fin d, r ^ (2 : ℕ) := by
          refine Finset.sum_le_sum ?_
          intro i _hi
          exact (sq_le_sq).2 (by simpa [abs_of_nonneg hr] using hcoord i)
    _ = (d : ℝ) * r ^ (2 : ℕ) := by
          simp

theorem positiveOrthantNegLog_localNorm_le_sqrt_fin_mul_of_coord_abs_le {d : ℕ}
    {x0 x : EuclideanSpace ℝ (Fin d)} {r : ℝ}
    (hx0 : x0 ∈ positiveOrthant (d := d))
    (hr : 0 ≤ r)
    (hcoord : ∀ i : Fin d, |x i - x0 i| ≤ r * x0 i) :
    localNorm positiveOrthantNegLogHessCLM x0 (x - x0) ≤
      Real.sqrt (d : ℝ) * r := by
  rw [positiveOrthantNegLog_localNorm_eq_sqrtCoord_norm hx0 (x - x0)]
  refine euclideanSpace_norm_le_sqrt_fin_mul_of_abs_coord_le hr ?_
  intro i
  have hxi_pos : 0 < x0 i := hx0 i
  have hdiv : |(x - x0) i| / x0 i ≤ r := by
    have hcoord' : |(x - x0) i| ≤ r * x0 i := by
      simpa [Pi.sub_apply] using hcoord i
    exact (div_le_iff₀ hxi_pos).2 hcoord'
  have hscaled :
      |(x0 i)⁻¹ * ((x - x0) i)| ≤ r := by
    have hdiv' : |(x - x0) i| * (x0 i)⁻¹ ≤ r := by
      simpa [div_eq_mul_inv] using hdiv
    rw [abs_mul, abs_inv, abs_of_pos hxi_pos]
    simpa [mul_comm] using hdiv'
  have hcoord_eq :
      (x0 i)⁻¹ * x i - (x0 i)⁻¹ * x0 i =
        (x0 i)⁻¹ * ((x - x0) i) := by
    simp
    ring
  have hscaled_sub :
      |(x0 i)⁻¹ * x i - (x0 i)⁻¹ * x0 i| ≤ r := by
    rw [hcoord_eq]
    exact hscaled
  simpa [hx0] using hscaled_sub

theorem positiveOrthantNegLog_sourceRadiusHalf_of_coord_abs_le_inv_two_sqrt
    {d : ℕ}
    {x0 x : EuclideanSpace ℝ (Fin d)}
    (hx0 : x0 ∈ positiveOrthant (d := d))
    (hsqrt_pos : 0 < Real.sqrt (d : ℝ))
    (hcoord : ∀ i : Fin d,
      |x i - x0 i| ≤ (1 / (2 * Real.sqrt (d : ℝ))) * x0 i) :
    localNorm positiveOrthantNegLogHessCLM x0 (x - x0) ≤ 1 / 2 := by
  have hden_pos : 0 < 2 * Real.sqrt (d : ℝ) :=
    mul_pos (by norm_num) hsqrt_pos
  have hr_nonneg : 0 ≤ (1 / (2 * Real.sqrt (d : ℝ)) : ℝ) :=
    div_nonneg zero_le_one hden_pos.le
  have hbound :=
    positiveOrthantNegLog_localNorm_le_sqrt_fin_mul_of_coord_abs_le
      (x0 := x0) (x := x) hx0 hr_nonneg hcoord
  have hscale :
      2⁻¹ * (Real.sqrt (d : ℝ) * (Real.sqrt (d : ℝ))⁻¹) = (2⁻¹ : ℝ) := by
    rw [mul_inv_cancel₀ hsqrt_pos.ne', mul_one]
  simpa [one_div, hscale, mul_assoc, mul_left_comm, mul_comm] using hbound

theorem positiveOrthant_coord_abs_sub_le_mul_of_relative_abs_sub_le {d : ℕ}
    {x0 x : EuclideanSpace ℝ (Fin d)} (hx0 : x0 ∈ positiveOrthant (d := d))
    {r : ℝ} {i : Fin d}
    (hrel : |x i / x0 i - 1| ≤ r) :
    |x i - x0 i| ≤ r * x0 i := by
  have hxi_pos : 0 < x0 i := hx0 i
  have hscale :
      (x i / x0 i - 1) * x0 i = x i - x0 i := by
    field_simp [hxi_pos.ne']
  have habs_eq :
      |x i - x0 i| = |x i / x0 i - 1| * x0 i := by
    calc
      |x i - x0 i| = |(x i / x0 i - 1) * x0 i| := by
        rw [hscale]
      _ = |x i / x0 i - 1| * x0 i := by
        rw [abs_mul, abs_of_pos hxi_pos]
  rw [habs_eq]
  exact mul_le_mul_of_nonneg_right hrel hxi_pos.le

theorem positiveOrthant_mem_of_localNorm_sub_lt_one {d : ℕ}
    {x y : EuclideanSpace ℝ (Fin d)}
    (hx : x ∈ positiveOrthant (d := d))
    (hy : localNorm positiveOrthantNegLogHessCLM x (y - x) < 1) :
    y ∈ positiveOrthant (d := d) := by
  intro i
  let S : EuclideanSpace ℝ (Fin d) →L[ℝ] EuclideanSpace ℝ (Fin d) :=
    (positiveOrthantNegLogSqrtCoord x).toContinuousLinearMap
  have hcoord_norm :
      ‖S (y - x) i‖ ≤ ‖S (y - x)‖ :=
    PiLp.norm_apply_le (S (y - x)) i
  have hcoord_abs_raw :
      |(x i)⁻¹ * y i - (x i)⁻¹ * x i| ≤ ‖S (y - x)‖ := by
    simpa [S, hx, Real.norm_eq_abs] using hcoord_norm
  have hcoord_abs :
      |(x i)⁻¹ * (y i - x i)| ≤ ‖S (y - x)‖ := by
    convert hcoord_abs_raw using 2
    ring
  have hlocal_eq :
      localNorm positiveOrthantNegLogHessCLM x (y - x) = ‖S (y - x)‖ := by
    simpa [S] using positiveOrthantNegLog_localNorm_eq_sqrtCoord_norm hx (y - x)
  have hnorm_lt : ‖S (y - x)‖ < 1 := by
    rwa [← hlocal_eq]
  have habs_lt : |(x i)⁻¹ * (y i - x i)| < 1 :=
    hcoord_abs.trans_lt hnorm_lt
  have hlower : -1 < (x i)⁻¹ * (y i - x i) := (abs_lt.mp habs_lt).1
  have hmul :
      (-1 : ℝ) * x i < ((x i)⁻¹ * (y i - x i)) * x i :=
    mul_lt_mul_of_pos_right hlower (hx i)
  have hright :
      ((x i)⁻¹ * (y i - x i)) * x i = y i - x i := by
    field_simp [(hx i).ne']
  have hshift : -x i < y i - x i := by
    simpa [hright] using hmul
  nlinarith

/--
Coordinate ratio bound from a positive-orthant local-norm displacement bound.
This is the elementary coordinate fact behind the bounded-polytope slack-ratio
route: in the logarithmic-barrier metric, each relative coordinate displacement
is dominated by the full local norm.
-/
theorem positiveOrthant_ratio_abs_le_one_add_of_localNorm_sub_le {d : ℕ}
    {x0 x : EuclideanSpace ℝ (Fin d)} {r : ℝ}
    (hx0 : x0 ∈ positiveOrthant (d := d))
    (hlocal : localNorm positiveOrthantNegLogHessCLM x0 (x - x0) ≤ r) :
    ∀ i : Fin d, |x i / x0 i| ≤ 1 + r := by
  intro i
  let S : EuclideanSpace ℝ (Fin d) →L[ℝ] EuclideanSpace ℝ (Fin d) :=
    (positiveOrthantNegLogSqrtCoord x0).toContinuousLinearMap
  have hcoord_norm :
      ‖S (x - x0) i‖ ≤ ‖S (x - x0)‖ :=
    PiLp.norm_apply_le (S (x - x0)) i
  have hcoord_abs_raw :
      |(x0 i)⁻¹ * x i - (x0 i)⁻¹ * x0 i| ≤ ‖S (x - x0)‖ := by
    simpa [S, hx0, Real.norm_eq_abs] using hcoord_norm
  have hlocal_eq :
      localNorm positiveOrthantNegLogHessCLM x0 (x - x0) = ‖S (x - x0)‖ := by
    simpa [S] using positiveOrthantNegLog_localNorm_eq_sqrtCoord_norm hx0 (x - x0)
  have hnorm_le : ‖S (x - x0)‖ ≤ r := by
    simpa [hlocal_eq] using hlocal
  have hrel_abs : |x i / x0 i - 1| ≤ r := by
    have hrel_eq :
        x i / x0 i - 1 =
          (x0 i)⁻¹ * x i - (x0 i)⁻¹ * x0 i := by
      field_simp [(hx0 i).ne']
    simpa [hrel_eq] using hcoord_abs_raw.trans hnorm_le
  have htri :
      |x i / x0 i| ≤ |x i / x0 i - 1| + 1 := by
    calc
      |x i / x0 i| = |(x i / x0 i - 1) + 1| := by
        congr 1
        ring
      _ ≤ |x i / x0 i - 1| + |(1 : ℝ)| := abs_add_le _ _
      _ = |x i / x0 i - 1| + 1 := by norm_num
  calc
    |x i / x0 i| ≤ |x i / x0 i - 1| + 1 := htri
    _ ≤ r + 1 := by linarith
    _ = 1 + r := by ring

/--
Coordinate ratio bound from a supplied relative slack displacement.  This is
the scalar triangle-inequality form used by moving-center tail estimates:
`|x_i / x0_i - 1| <= rho` immediately gives `|x_i / x0_i| <= 1 + rho`.
-/
theorem positiveOrthant_ratio_abs_le_one_add_of_relative_abs_sub_le {d : ℕ}
    {x0 x : EuclideanSpace ℝ (Fin d)} {rho : ℝ}
    (hrel : ∀ i : Fin d, ‖x i / x0 i - 1‖ ≤ rho) :
    ∀ i : Fin d, |x i / x0 i| ≤ 1 + rho := by
  intro i
  have hrel_abs : |x i / x0 i - 1| ≤ rho := by
    simpa [Real.norm_eq_abs] using hrel i
  have htri :
      |x i / x0 i| ≤ |x i / x0 i - 1| + 1 := by
    calc
      |x i / x0 i| = |(x i / x0 i - 1) + 1| := by
        congr 1
        ring
      _ ≤ |x i / x0 i - 1| + |(1 : ℝ)| := abs_add_le _ _
      _ = |x i / x0 i - 1| + 1 := by norm_num
  calc
    |x i / x0 i| ≤ |x i / x0 i - 1| + 1 := htri
    _ ≤ rho + 1 := by linarith
    _ = 1 + rho := by ring

theorem barrierAffineRange_localNorm_eq_ambient
    {F : Type*} [NormedAddCommGroup F] [InnerProductSpace ℝ F] [CompleteSpace F]
    {d : ℕ} (A : F →L[ℝ] EuclideanSpace ℝ (Fin d))
    (b : EuclideanSpace ℝ (Fin d))
    (y v : A.range) :
    localNorm
        (barrierAffineRangeHess A b positiveOrthantNegLogHessCLM)
        y v =
      localNorm positiveOrthantNegLogHessCLM ((y : EuclideanSpace ℝ (Fin d)) + b)
        (v : EuclideanSpace ℝ (Fin d)) := by
  simp [localNorm, barrierAffineRangeHess, barrierAffinePreimageHess,
    ContinuousLinearMap.adjoint_inner_right]

theorem barrierAffineRangeSet_mem_of_localNorm_sub_lt_one_positiveOrthant
    {F : Type*} [NormedAddCommGroup F] [InnerProductSpace ℝ F] [CompleteSpace F]
    {d : ℕ} (A : F →L[ℝ] EuclideanSpace ℝ (Fin d))
    (b : EuclideanSpace ℝ (Fin d))
    {y z : A.range}
    (hy : y ∈ barrierAffineRangeSet A b (positiveOrthant (d := d)))
    (hz :
      localNorm
          (barrierAffineRangeHess A b positiveOrthantNegLogHessCLM)
          y (z - y) < 1) :
    z ∈ barrierAffineRangeSet A b (positiveOrthant (d := d)) := by
  have hz_range :
      localNorm positiveOrthantNegLogHessCLM
          ((y : EuclideanSpace ℝ (Fin d)) + b)
          ((z - y : A.range) : EuclideanSpace ℝ (Fin d)) < 1 := by
    simpa [barrierAffineRange_localNorm_eq_ambient A b y (z - y)] using hz
  have hvec :
      (((z : EuclideanSpace ℝ (Fin d)) + b) -
          ((y : EuclideanSpace ℝ (Fin d)) + b)) =
        ((z - y : A.range) : EuclideanSpace ℝ (Fin d)) := by
    simp
  have hz_ambient :
      localNorm positiveOrthantNegLogHessCLM
          ((y : EuclideanSpace ℝ (Fin d)) + b)
          (((z : EuclideanSpace ℝ (Fin d)) + b) -
            ((y : EuclideanSpace ℝ (Fin d)) + b)) < 1 := by
    simpa [hvec] using hz_range
  exact positiveOrthant_mem_of_localNorm_sub_lt_one hy hz_ambient

