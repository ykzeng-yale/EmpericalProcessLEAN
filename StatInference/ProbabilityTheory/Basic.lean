          exact hX_int0.abs)
        (fun ω => abs_nonneg (X 0 ω)) K)
  have hM_shift_summable : Summable fun k : ℕ => M (k + 1) :=
    hM_summable.comp_injective (fun a b h => Nat.succ.inj h)
