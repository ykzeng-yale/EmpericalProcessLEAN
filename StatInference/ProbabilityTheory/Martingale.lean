      hX_prev hVariance hMeanPrev
  have hlimit_mem : MemLp (‚ĄĪ.limitProcess X P) (ENNReal.ofReal (2 : ‚ĄĚ)) P :=
    durrett2019_theorem_4_4_6_martingale_limitProcess_memLp_of_eLpNorm_p_bdd
