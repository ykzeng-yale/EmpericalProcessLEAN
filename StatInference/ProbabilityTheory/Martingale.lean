      hA0 hA_mono hA_tendsto n
  have hsplit :
      (‚ąę‚ĀĽ a in Set.Ioi (0 : ‚ĄĚ),
        P {ŌČ : ő© | a ^ 2 < Ainf ŌČ} + second a ‚ąāvolume) =
        (‚ąę‚ĀĽ a in Set.Ioi (0 : ‚ĄĚ), P {ŌČ : ő© | a ^ 2 < Ainf ŌČ} ‚ąāvolume) +
          ‚ąę‚ĀĽ a in Set.Ioi (0 : ‚ĄĚ), second a ‚ąāvolume := by
