    {╬й : Type u} [MeasurableSpace ╬й] {╬╝ : Measure ╬й} [IsFiniteMeasure ╬╝]
    {тД▒ : Filtration тДХс╡Тс╡И (inferInstance : MeasurableSpace ╬й)}
