        exact measure_mono
          (vdVWTheorem243_untruncated_centered_badEvent_subset_truncated_or_empiricalTail
            (P := P) (n := n) (M := M) (epsilon := epsilon)
            henvelope hn hepsilon hclass henv hclassIntegrable
