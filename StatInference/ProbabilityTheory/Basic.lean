  intro n hn
  have hn_ne : (n : ℝ) ≠ 0 := by
    exact_mod_cast (ne_of_gt hn)
  have ha_ne : a n ≠ 0 := (ha_pos n).ne'
  field_simp [hn_ne, ha_ne]

