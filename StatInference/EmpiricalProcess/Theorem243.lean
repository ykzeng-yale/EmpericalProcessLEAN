          (vdVWTruncatedClassFun classFun envelope M) (eta / 2)
          (cardinality sample))
    (sample ghostSample : SampleAt Observation n) (sign : SampleAt ℝ n) :
    (ghostSample, sign) ∈
        (Prod.mk sample ⁻¹'
