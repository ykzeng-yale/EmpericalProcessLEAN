  exact
    durrett2019_theorem_2_1_10_indepFun_partialSumDiff_earlyBlockFunction
      (P := P) (X := fun i : ℕ => fun ω => X (i + 1) ω)
      hShift_indep (fun i => hX_meas (i + 1)) hmn hψ

