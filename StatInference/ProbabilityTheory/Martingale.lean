    hconstant.add hcentered_tendsto
  have hsumL :
      Tendsto
        (fun n : ‚Ąē =>
          (‚ąĎ k ‚ąą Finset.range n, L * (b (k + 2) - b (k + 1))) /
              b (n + 1) +
            (‚ąĎ k ‚ąą Finset.range n,
              (A (k + 1) - L) * (b (k + 2) - b (k + 1))) /
