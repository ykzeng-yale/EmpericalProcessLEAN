    (hratio_mono : ∀ ⦃m n : ℕ⦄, 0 < m -> m ≤ n ->
      a m / (m : ℝ) ≤ a n / (n : ℝ))
    (hbounded_ratio_tail_integrable :
      ∀ C : ℝ,
        (∀ n : ℕ, 1 ≤ n -> a n / (n : ℝ) ≤ C) ->
