    ?_ hweighted_comp_error
  exact Eventually.of_forall fun N =>
    integral_mono_ae (hweighted_diff_int N) (hweighted_comp_int N) <|
      (S.projectedInverseCompensationFactor_row_norm_le_one_ae L N t).mono
        fun ω hω => by
