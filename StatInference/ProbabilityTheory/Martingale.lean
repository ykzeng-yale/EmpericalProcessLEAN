theorem durrett2019_theorem_4_5_7_inv_sq_weight_of_toNNReal_sq
    {a : ‚ĄĚ} (ha : 0 < a) :
    ((((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě))‚ĀĽ¬Ļ =
      ENNReal.ofReal (a ^ (-2 : ‚ĄĚ)) := by
  have hden :
      ((((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě)) =
        ENNReal.ofReal (a ^ 2) := by
    rw [ENNReal.ofReal_pow ha.le 2]
    rw [‚Üź ENNReal.ofNNReal_toNNReal a]
    exact ENNReal.coe_pow (Real.toNNReal a) 2
  have hrpow : (a ^ 2)‚ĀĽ¬Ļ = a ^ (-2 : ‚ĄĚ) := by
    rw [‚Üź Real.rpow_neg_one (a ^ 2)]
    rw [‚Üź Real.rpow_natCast]
    rw [‚Üź Real.rpow_mul ha.le]
    norm_num
  rw [hden, ‚Üź ENNReal.ofReal_inv_of_pos (sq_pos_of_pos ha), hrpow]

/--
