  have hdom : ‚ąÄ n, ‚ąÄŠĶź ŌČ ‚ąāP, ‚ÄĖX n ŌČ‚ÄĖ ‚Č§ durrett2019_runningAbsSup X ŌČ := by
    intro n
    filter_upwards [hBdd] with ŌČ hŌČ
    have hterminal_le_max : ‚ÄĖX n ŌČ‚ÄĖ ‚Č§ durrett2019_runningAbsMax X n ŌČ := by
