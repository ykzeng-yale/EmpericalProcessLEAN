  have hupper_nonneg :
      0 тЙд vdVWTheorem243FiniteNetHoeffdingUpper (cardinality ╧Й n) n M :=
    vdVWTheorem243FiniteNetHoeffdingUpper_nonneg (cardinality ╧Й n) n
      hM_nonneg
