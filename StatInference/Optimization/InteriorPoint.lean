      have hsqrt_ne : Real.sqrt (m : ℝ) ≠ 0 := ne_of_gt hsqrt_pos
      simp [delta, hsqrt_ne]
    have hxbar0Set : xbar0 ∈ polytopeSlackSet aRow bSlack :=
      polytopeSlackSet_of_rangeRestrict_mem aRow bSlack hxbar0Range
    have hgrad_bound :
