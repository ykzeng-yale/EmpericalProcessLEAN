        (μ := M) (ν := N) (ℱ := ℱ) C hC_meas hgen hC
  simpa [M, N, ℱ] using
    durrett2019_theorem_4_3_8_cylinderLikelihood_toReal_tendsto_canonicalRatio_of_trimmedRatio_toReal_tendsto
      (μ := μ) (ν := ν) (q := q) (ℱ := ℱ)
