    őľ.real A = ‚ąę ŌČ in A, (X ŌČ).toReal ‚ąāőĹ + őľ.real (A ‚ą© {ŌČ | X ŌČ = ‚ąě}) := by
  have hYseq : ‚ąÄ n,
      AEMeasurable
        (fun ŌČ => (őľ.trim (‚ĄĪ.le n)).rnDeriv (ŌĀ.trim (‚ĄĪ.le n)) ŌČ) ŌĀ := by
    intro n
    exact
      ((Measure.measurable_rnDeriv (őľ.trim (‚ĄĪ.le n)) (ŌĀ.trim (‚ĄĪ.le n))).mono
