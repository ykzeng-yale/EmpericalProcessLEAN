/--
Durrett 2019, Theorem 4.5.3 clock-tail comparison.

If a finite clock interval lies in `[0, ‚ąě)`, then its clock integral is bounded
by any supplied bound on the global tail integral of `f(t)^{-2}`.
-/
theorem durrett2019_theorem_4_5_3_clock_interval_le_tail_integral_bound
    {f : ‚ĄĚ -> ‚ĄĚ} {a b C : ‚ĄĚ}
    (ha_nonneg : 0 ‚Č§ a)
    (hab : a ‚Č§ b)
    (htail_int :
      IntegrableOn (fun t => (f t)‚ĀĽ¬Ļ ^ 2) (Set.Ici 0) volume)
    (htail_bound :
      ‚ąę t in Set.Ici (0 : ‚ĄĚ), (f t)‚ĀĽ¬Ļ ^ 2 ‚ąāvolume ‚Č§ C) :
    ‚ąę t in a..b, (f t)‚ĀĽ¬Ļ ^ 2 ‚Č§ C := by
  let g : ‚ĄĚ -> ‚ĄĚ := fun t => (f t)‚ĀĽ¬Ļ ^ 2
  have hsubset : Set.Ioc a b ‚äÜ Set.Ici (0 : ‚ĄĚ) := by
    intro t ht
    exact ha_nonneg.trans (le_of_lt ht.1)
  have hnonneg : 0 ‚Č§ŠĶź[volume.restrict (Set.Ici (0 : ‚ĄĚ))] g := by
    exact Eventually.of_forall fun t => sq_nonneg ((f t)‚ĀĽ¬Ļ)
  have hset_le :
      ‚ąę t in Set.Ioc a b, g t ‚ąāvolume ‚Č§
        ‚ąę t in Set.Ici (0 : ‚ĄĚ), g t ‚ąāvolume := by
    exact setIntegral_mono_set htail_int hnonneg hsubset.eventuallyLE
  calc
    ‚ąę t in a..b, (f t)‚ĀĽ¬Ļ ^ 2
        = ‚ąę t in Set.Ioc a b, g t ‚ąāvolume := by
          simp [g, intervalIntegral.integral_of_le hab]
    _ ‚Č§ ‚ąę t in Set.Ici (0 : ‚ĄĚ), g t ‚ąāvolume := hset_le
    _ = ‚ąę t in Set.Ici (0 : ‚ĄĚ), (f t)‚ĀĽ¬Ļ ^ 2 ‚ąāvolume := by
          rfl
    _ ‚Č§ C := htail_bound

/--
Durrett 2019, Theorem 4.5.3 integrated clock-tail comparison.

This derives the uniform integrated clock bound used by V214/V215 from a
global tail-integral bound.  Measurability/integrability of the random finite
clock integrals remains explicit; the theorem removes only the source bound
obligation.
-/
theorem durrett2019_theorem_4_5_3_integrated_clock_bound_of_tail_integral_bound
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsProbabilityMeasure P]
    {f : ‚ĄĚ -> ‚ĄĚ} {A : ‚Ąē -> ő© -> ‚ĄĚ} {C : ‚ĄĚ}
    (hA0_nonneg : ‚ąÄ ŌČ : ő©, 0 ‚Č§ A 0 ŌČ)
    (hA_mono_step : ‚ąÄ k : ‚Ąē, ‚ąÄ ŌČ : ő©, A k ŌČ ‚Č§ A (k + 1) ŌČ)
    (htail_int :
      IntegrableOn (fun t => (f t)‚ĀĽ¬Ļ ^ 2) (Set.Ici 0) volume)
    (hclock_int :
      ‚ąÄ N : ‚Ąē, Integrable (fun ŌČ => ‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2) P)
    (htail_bound :
      ‚ąę t in Set.Ici (0 : ‚ĄĚ), (f t)‚ĀĽ¬Ļ ^ 2 ‚ąāvolume ‚Č§ C) :
    ‚ąÄ N : ‚Ąē, ‚ąę ŌČ, (‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2) ‚ąāP ‚Č§ C := by
  intro N
  have hA0N : ‚ąÄ ŌČ : ő©, A 0 ŌČ ‚Č§ A N ŌČ := by
    intro ŌČ
    induction N with
    | zero =>
        exact le_rfl
    | succ N ih =>
        exact ih.trans (hA_mono_step N ŌČ)
  have hpoint :
      (fun ŌČ => ‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2) ‚Č§ fun _ŌČ => C := by
    intro ŌČ
    exact
      durrett2019_theorem_4_5_3_clock_interval_le_tail_integral_bound
        (f := f) (a := A 0 ŌČ) (b := A N ŌČ) (C := C)
        (hA0_nonneg ŌČ) (hA0N ŌČ) htail_int htail_bound
  calc
    ‚ąę ŌČ, (‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2) ‚ąāP
        ‚Č§ ‚ąę _ŌČ : ő©, C ‚ąāP :=
          integral_mono (hclock_int N) (integrable_const C) hpoint
    _ = C := by simp

/--
Durrett 2019, Theorem 4.5.3 finite random clock-integrability support.

For a continuous reciprocal-square clock integrand, the random clock integral
is measurable because it is the difference of two continuous primitives
evaluated at predictable clock times.  The global tail-integral bound then
gives a uniform bound, hence integrability on a finite measure space.
-/
theorem durrett2019_theorem_4_5_3_finite_clock_integral_integrable_of_tail_integral_bound
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P]
    {‚ĄĪ : Filtration ‚Ąē mő©} {f : ‚ĄĚ -> ‚ĄĚ} {A : ‚Ąē -> ő© -> ‚ĄĚ} {C : ‚ĄĚ}
    (hA_predictable : IsStronglyPredictable ‚ĄĪ A)
    (hfinvSq_cont : Continuous (fun t : ‚ĄĚ => (f t)‚ĀĽ¬Ļ ^ 2))
    (hA0_nonneg : ‚ąÄ ŌČ : ő©, 0 ‚Č§ A 0 ŌČ)
    (hA_mono_step : ‚ąÄ k : ‚Ąē, ‚ąÄ ŌČ : ő©, A k ŌČ ‚Č§ A (k + 1) ŌČ)
    (htail_int :
      IntegrableOn (fun t => (f t)‚ĀĽ¬Ļ ^ 2) (Set.Ici 0) volume)
    (htail_bound :
      ‚ąę t in Set.Ici (0 : ‚ĄĚ), (f t)‚ĀĽ¬Ļ ^ 2 ‚ąāvolume ‚Č§ C) :
    ‚ąÄ N : ‚Ąē, Integrable (fun ŌČ => ‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2) P := by
  intro N
  let g : ‚ĄĚ -> ‚ĄĚ := fun t => (f t)‚ĀĽ¬Ļ ^ 2
  let F : ‚ĄĚ -> ‚ĄĚ := fun x => ‚ąę t in (0 : ‚ĄĚ)..x, g t
  have hg_cont : Continuous g := by
    simpa [g] using hfinvSq_cont
  have hF_cont : Continuous F := by
    have huncurry :
        Continuous (Function.uncurry (fun _x : ‚ĄĚ => fun t : ‚ĄĚ => g t)) := by
      simpa [Function.uncurry] using hg_cont.comp continuous_snd
    simpa [F] using
      (intervalIntegral.continuous_parametric_intervalIntegral_of_continuous
        (őľ := volume) (a‚āÄ := (0 : ‚ĄĚ))
        (f := fun _x : ‚ĄĚ => fun t : ‚ĄĚ => g t)
        huncurry (s := fun x : ‚ĄĚ => x) continuous_id)
  have hA0N : ‚ąÄ ŌČ : ő©, A 0 ŌČ ‚Č§ A N ŌČ := by
    intro ŌČ
    induction N with
    | zero =>
        exact le_rfl
    | succ N ih =>
        exact ih.trans (hA_mono_step N ŌČ)
  have hA0_sm_sub : StronglyMeasurable[‚ĄĪ 0] (A 0) :=
    hA_predictable.stronglyAdapted 0
  have hAN_sm_sub : StronglyMeasurable[‚ĄĪ N] (A N) :=
    hA_predictable.stronglyAdapted N
  have hA0_sm : StronglyMeasurable (A 0) :=
    hA0_sm_sub.mono (‚ĄĪ.le 0)
  have hAN_sm : StronglyMeasurable (A N) :=
    hAN_sm_sub.mono (‚ĄĪ.le N)
  have hbase_sm :
      AEStronglyMeasurable (fun ŌČ : ő© => F (A N ŌČ) - F (A 0 ŌČ)) P :=
    ((hF_cont.comp_stronglyMeasurable hAN_sm).sub
      (hF_cont.comp_stronglyMeasurable hA0_sm)).aestronglyMeasurable
  have hclock_eq :
      (fun ŌČ : ő© => F (A N ŌČ) - F (A 0 ŌČ)) =ŠĶź[P]
        fun ŌČ => ‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2 := by
    refine ae_of_all P fun ŌČ => ?_
    have h0N : IntervalIntegrable g volume (0 : ‚ĄĚ) (A N ŌČ) :=
      hg_cont.intervalIntegrable _ _
    have h00 : IntervalIntegrable g volume (0 : ‚ĄĚ) (A 0 ŌČ) :=
      hg_cont.intervalIntegrable _ _
    simpa [F, g] using
      (intervalIntegral.integral_interval_sub_left
        (őľ := volume) (f := g) (a := (0 : ‚ĄĚ)) (b := A N ŌČ) (c := A 0 ŌČ)
        h0N h00)
  have hclock_sm :
      AEStronglyMeasurable
        (fun ŌČ : ő© => ‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2) P :=
    (aestronglyMeasurable_congr hclock_eq).mp hbase_sm
  have hbounded :
      ‚ąÄŠĶź ŌČ ‚ąāP, ‚ÄĖ‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2‚ÄĖ ‚Č§ C := by
    refine ae_of_all P fun ŌČ => ?_
    have hclock_nonneg :
        0 ‚Č§ ‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2 := by
      exact intervalIntegral.integral_nonneg (hA0N ŌČ) fun t _ht => sq_nonneg ((f t)‚ĀĽ¬Ļ)
    have hclock_le :
        ‚ąę t in A 0 ŌČ..A N ŌČ, (f t)‚ĀĽ¬Ļ ^ 2 ‚Č§ C :=
      durrett2019_theorem_4_5_3_clock_interval_le_tail_integral_bound
        (f := f) (a := A 0 ŌČ) (b := A N ŌČ) (C := C)
        (hA0_nonneg ŌČ) (hA0N ŌČ) htail_int htail_bound
    exact (Real.norm_of_nonneg hclock_nonneg).trans_le hclock_le
  exact ‚ü®hclock_sm, HasFiniteIntegral.of_bounded hbounded‚ü©

/--
Durrett 2019, Theorem 4.5.3 interval-integrability support.

Continuity of the reciprocal-square clock integrand gives every finite
interval-integrability hypothesis used by the deterministic clock comparison.
-/
theorem durrett2019_theorem_4_5_3_interval_integrable_of_reciprocal_sq_continuous
    {f : ‚ĄĚ -> ‚ĄĚ}
    (hfinvSq_cont : Continuous (fun t : ‚ĄĚ => (f t)‚ĀĽ¬Ļ ^ 2)) :
    ‚ąÄ a b : ‚ĄĚ, IntervalIntegrable (fun t : ‚ĄĚ => (f t)‚ĀĽ¬Ļ ^ 2) volume a b := by
  intro a b
  exact hfinvSq_cont.intervalIntegrable a b

/--
Durrett 2019, Theorem 4.5.3 reciprocal-square continuity support.

If `f` is continuous and has no zeros, then the reciprocal-square clock
integrand is continuous.
-/
theorem durrett2019_theorem_4_5_3_reciprocal_sq_continuous_of_continuous_ne_zero
    {f : ‚ĄĚ -> ‚ĄĚ}
    (hf_cont : Continuous f) (hf_ne_zero : ‚ąÄ t : ‚ĄĚ, f t ‚Č† 0) :
    Continuous (fun t : ‚ĄĚ => (f t)‚ĀĽ¬Ļ ^ 2) := by
  have hinv : Continuous (fun t : ‚ĄĚ => (f t)‚ĀĽ¬Ļ) :=
    hf_cont.inv‚āÄ hf_ne_zero
