    _ =
      ENNReal.ofReal
          (∫ x, Set.indicator {y | M < envelope y} envelope x ∂P) /
        ENNReal.ofReal epsilon := by
        rw [
          VdVWOuterExpectation_empiricalEnvelopeTail_eq_ofReal_integral_tail
