    simpa [E] using
      durrett2019_theorem_4_5_2_threshold_cover_of_ae_le_terminal
        (P := P) (A := A) (Ainf := Ainf) hA_le_Ainf
  have hStopped :
      ∀ k, ∀ᵐ ω ∂P, ∃ z : ℝ,
        Tendsto (fun n => stoppedProcess X (N k) n ω) atTop (𝓝 z) := by
    intro k
    have hA0_le : ∀ᵐ ω ∂P, A 0 ω ≤ ((k : ℝ) ^ 2) :=
