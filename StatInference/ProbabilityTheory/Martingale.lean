        ∫ ω, min (Ainf ω) C ∂P :=
    integral_mono_ae hA_stopped_int hMin_int hA_le_min
  calc
    (∫ ω, stoppedProcess X N n ω ^ 2 ∂P)
        = ∫ ω, stoppedProcess A N n ω ∂P := hSquare_eq_A n
    _ ≤ ∫ ω, min (Ainf ω) C ∂P := hA_integral_le

