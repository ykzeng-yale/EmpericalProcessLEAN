theorem hessianSegmentLocalNorm_le_of_riccati_bound_of_mul_lt
    {hess : E -> E →L[ℝ] E} {x y : E} {M r : ℝ}
    {localNormDeriv : ℝ -> ℝ}
    (hMr_nonneg : 0 ≤ M * r) (hMr_lt : M * r < 1)
    (hr_pos : 0 < r)
