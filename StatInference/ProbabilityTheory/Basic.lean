    ((r : ℝ) / a r) *
        durrett2019_theorem_2_5_13_baseAbsAnnulusIntegral P X0 a r ≤
      ((r : ℝ) / a r) *
        (a r * P.real {ω : Ω | a (r - 1) ≤ |X0 ω| ∧ |X0 ω| < a r}) := by
          exact mul_le_mul_of_nonneg_left hbase hcoef_nonneg
