-/
theorem durrett2019_theorem_4_5_3_interval_one_le_of_global_one_le
    {ő© : Type*} {A : ‚Ąē -> ő© -> ‚ĄĚ} {f : ‚ĄĚ -> ‚ĄĚ}
    (hf_one_le : ‚ąÄ t : ‚ĄĚ, 1 ‚Č§ f t) :
    ‚ąÄ k : ‚Ąē, ‚ąÄ ŌČ : ő©,
      ‚ąÄ t ‚ąą Set.Icc (A k ŌČ) (A (k + 1) ŌČ), 1 ‚Č§ f t := by
