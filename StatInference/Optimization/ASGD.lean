            (t * (Real.sqrt (N : ℝ))⁻¹) ω *
          ∏ k ∈ Finset.Ico (r + 1) N,
            S.projectedNormalizedTaylorFactor L N t k ω) P)
    (hsq : ∀ N r : ℕ, r < N ->
      Integrable (fun ω => (L (S.martingale.xi (r + 1) ω)) ^ 2) P)
    (htower_remainder_int : ∀ N r : ℕ, r < N ->
