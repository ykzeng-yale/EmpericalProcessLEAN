      (őľ := őľ) (őĹ := őĹ) (Iseq := Iseq) (q := q) hq hX hlim hhellinger
      (by
        intro A hA
        exact
          durrett2019_theorem_4_3_5_source_real_identity_of_top_set
            (őľ := őľ) (őĹ := Measure.infinitePi őĹ) (X := X) hA hXrn hőľsingTop hőĹtop)
      hőĹtop

/--
