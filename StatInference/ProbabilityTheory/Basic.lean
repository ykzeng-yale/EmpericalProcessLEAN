theorem durrett2019_theorem_2_5_13_linear_tail_measureReal_le_of_ratio_bound
    {Ω : Type u} [MeasurableSpace Ω] {P : Measure Ω} [IsFiniteMeasure P]
    {X0 : Ω -> ℝ}
