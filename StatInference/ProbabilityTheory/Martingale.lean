        durrett2019_theorem_4_5_5_nonnegativeConditionalProbabilitySum P ‚ĄĪ B k ŌČ) =
      fun ŌČ : ő© =>
        max (P[(B (k + 1)).indicator (1 : ő© -> ‚ĄĚ) | ‚ĄĪ k] ŌČ) 0 := by
  ext ŌČ
  simp [durrett2019_theorem_4_5_5_nonnegativeConditionalProbabilitySum,
