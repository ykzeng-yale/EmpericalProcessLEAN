    (hmean_gt_one : 1 < offspringMean) (hvariance_nonneg : 0 ≤ variance)
    (hX : Martingale X ℱ P)
    (hX_memLp_two : ∀ k, MemLp (X k) (2 : ℝ≥0∞) P)
    (hX_zero_sq : (∫ ω, X 0 ω ^ 2 ∂P) = 1)
    (hX_prev :
      ∀ n, 0 < n ->
        X (n - 1) =ᵐ[P] fun ω => Z (n - 1) ω / offspringMean ^ (n - 1))
