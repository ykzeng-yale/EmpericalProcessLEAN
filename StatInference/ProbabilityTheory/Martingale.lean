    {X A : ‚Ąē -> ő© -> ‚ĄĚ} {N : ő© -> ‚Ąē‚ąě}
    (hX : Martingale X ‚ĄĪ P) (hN : IsStoppingTime ‚ĄĪ N)
    (hN_zero_le : ‚ąÄ ŌČ, (0 : ‚Ąē‚ąě) ‚Č§ N ŌČ)
    (hX_memLp_two : ‚ąÄ n, MemLp (X n) (2 : ‚ĄĚ‚Č•0‚ąě) P)
    (hX0 : X 0 =ŠĶź[P] 0)
    (hPredictablePart_eq_A :
      ‚ąÄ n,
        predictablePart (fun k ŌČ => stoppedProcess X N k ŌČ ^ 2) ‚ĄĪ P n
          =ŠĶź[P] stoppedProcess A N n) :
    ‚ąÄ n,
      (‚ąę ŌČ, stoppedProcess X N n ŌČ ^ 2 ‚ąāP) =
        ‚ąę ŌČ, stoppedProcess A N n ŌČ ‚ąāP := by
  have hStopped : Martingale (stoppedProcess X N) ‚ĄĪ P :=
    durrett2019_theorem_4_2_9_martingale_stoppedProcess hX hN
  have hStopped_memLp_two :
      ‚ąÄ n, MemLp (stoppedProcess X N n) (2 : ‚ĄĚ‚Č•0‚ąě) P := by
    intro n
    exact memLp_stoppedProcess (őĻ := ‚Ąē) hN hX_memLp_two n
  have hStopped_zero : stoppedProcess X N 0 =ŠĶź[P] 0 := by
    filter_upwards [hX0] with ŌČ hX0ŌČ
    have hstop : stoppedProcess X N 0 ŌČ = X 0 ŌČ :=
      stoppedProcess_eq_of_le (u := X) (ŌĄ := N) (i := 0) (ŌČ := ŌČ) (hN_zero_le ŌČ)
    simpa [hstop] using hX0ŌČ
  intro n
  calc
    (‚ąę ŌČ, stoppedProcess X N n ŌČ ^ 2 ‚ąāP)
        = ‚ąę ŌČ,
            predictablePart (fun k ŌČ => stoppedProcess X N k ŌČ ^ 2) ‚ĄĪ P n ŌČ ‚ąāP :=
      durrett2019_theorem_4_5_1_square_integral_eq_predictablePart_square_of_initial_zero
