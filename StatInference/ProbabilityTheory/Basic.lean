    (hX : _root_.ProbabilityTheory.HasLaw X μ P)
    (hY : _root_.ProbabilityTheory.HasLaw Y ν P)
    {h : S × T -> E} (hh : Integrable h (μ.prod ν)) :
    ∫ ω, h (X ω, Y ω) ∂P =
      ∫ x, ∫ y, h (x, y) ∂ν ∂μ := by
  have hpair :
      _root_.ProbabilityTheory.HasLaw (fun ω => (X ω, Y ω)) (μ.prod ν) P :=
