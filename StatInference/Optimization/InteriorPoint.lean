/--
Single-endpoint source-tail bound from a mixed-third local-norm segment
certificate.  This is the pointwise form used to handle successor indices in a
preliminary sequence whose zeroth point is exactly the source.
-/
theorem chewi1316_sourceTailBound_of_hessianSegmentMixedThirdLocalNormCertificate_and_inverseIdentity
    {hess : E -> E →L[ℝ] E} {invHess : E -> E →L[ℝ] E}
    {thirdMixed : E -> E -> E -> ℝ} {phiGrad : E -> E}
    {xbar0 y : E} {M r sourceBound den tailBound : ℝ}
    (hden_pos : 0 < den)
    (hxbar0_nonneg : ∀ v : E, 0 ≤ inner ℝ v (hess xbar0 v))
    (hy_nonneg : ∀ v : E, 0 ≤ inner ℝ v (hess y v))
    (hy_inv_nonneg : ∀ v : E, 0 ≤ inner ℝ v (invHess y v))
    (hcert :
      HessianSegmentMixedThirdLocalNormCertificate hess thirdMixed
        xbar0 y M r)
    (hMr_nonneg : 0 ≤ M * r)
    (hMr_lt : M * r < 1)
    (hden_le : den ≤ 1 - M * r)
    (hy_inv_local : ∀ v : E,
      localNorm hess y (invHess y v) =
        dualLocalNorm invHess y v)
    (hxbar0_cauchy : ∀ v w : E,
      inner ℝ v w ≤ dualLocalNorm invHess xbar0 v *
        localNorm hess xbar0 w)
    (hsource :
      dualLocalNorm invHess xbar0 (phiGrad xbar0) ≤ sourceBound)
    (hbudget : sourceBound / den ≤ tailBound) :
    dualLocalNorm invHess y (phiGrad xbar0) ≤ tailBound := by
  have henv :
      HessianSegmentExponentialBounds hess xbar0 y M r :=
    hcert.toHessianSegmentExponentialBounds hMr_nonneg hMr_lt
  have hlower : ∀ w : E,
      den * localNorm hess xbar0 w ≤ localNorm hess y w := by
    intro w
    have hscale :
        den * localNorm hess xbar0 w ≤
          (1 - M * r) * localNorm hess xbar0 w :=
      mul_le_mul_of_nonneg_right hden_le (localNorm_nonneg hess xbar0 w)
    exact hscale.trans
      (mul_one_sub_localNorm_le_of_hessianSegmentExponentialBounds
        (hess := hess) (x := xbar0) (y := y)
        (M := M) (r := r) hMr_lt hxbar0_nonneg hy_nonneg henv w)
  have hdual :
      dualLocalNorm invHess y (phiGrad xbar0) ≤
        dualLocalNorm invHess xbar0 (phiGrad xbar0) / den :=
    dualLocalNorm_le_div_of_localNorm_lower_and_inverseIdentity
      (hess := hess) (invHess := invHess) (x := xbar0) (y := y)
      (den := den) hden_pos hy_inv_nonneg hlower hy_inv_local
      hxbar0_cauchy (phiGrad xbar0)
  exact hdual.trans
    ((div_le_div_of_nonneg_right hsource hden_pos.le).trans hbudget)

/--
Uniform preliminary source-tail bound from source-radius mixed-third segment
certificates on successor indices, with the zeroth index discharged by
`xseq 0 = xbar0`.
-/
theorem chewi1316_uniformTailBound_of_sourceRadius_successor_and_inverseIdentity
    {s : Set E} {hess : E -> E →L[ℝ] E}
    {hessDeriv : E -> E →L[ℝ] (E →L[ℝ] E)}
    {invHess : E -> E →L[ℝ] E}
    {thirdMixed : E -> E -> E -> ℝ} {phiGrad : E -> E}
    {xbar0 : E} {xseq : ℕ -> E} {M sourceBound den tailBound : ℝ}
    (hden_pos : 0 < den)
    (hs : Convex ℝ s)
    (hxbar0 : xbar0 ∈ s)
    (hx0 : xseq 0 = xbar0)
    (hxseq_succ : ∀ N : ℕ, xseq (N + 1) ∈ s)
    (hsc : MixedThirdSelfConcordantOn s hess thirdMixed M)
    (hess_pos : ∀ ⦃z : E⦄, z ∈ s -> ∀ v : E, v ≠ 0 ->
      0 < inner ℝ v (hess z v))
    (hdiff_ne : ∀ N : ℕ, xseq (N + 1) - xbar0 ≠ 0)
    (hhess_cont : ContinuousOn hess s)
    (hhess : ∀ N t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        HasFDerivAt hess
          (hessDeriv (hessianSegmentPoint xbar0 (xseq (N + 1)) t))
          (hessianSegmentPoint xbar0 (xseq (N + 1)) t))
    (hmixed : ∀ N v t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        inner ℝ v
            ((hessDeriv (hessianSegmentPoint xbar0 (xseq (N + 1)) t)
              (xseq (N + 1) - xbar0)) v) =
          hessianSegmentMixedThirdPsiDeriv thirdMixed
            xbar0 (xseq (N + 1)) v t)
    (hMr_lt : ∀ N : ℕ,
      M * localNorm hess xbar0 (xseq (N + 1) - xbar0) < 1)
    (hden_le : ∀ N : ℕ,
      den ≤ 1 - M * localNorm hess xbar0 (xseq (N + 1) - xbar0))
    (hxseq_inv_nonneg : ∀ N v,
      0 ≤ inner ℝ v (invHess (xseq N) v))
    (hxseq_inv_local : ∀ N v,
      localNorm hess (xseq N) (invHess (xseq N) v) =
        dualLocalNorm invHess (xseq N) v)
    (hxbar0_cauchy : ∀ v w : E,
      inner ℝ v w ≤ dualLocalNorm invHess xbar0 v *
        localNorm hess xbar0 w)
    (hsource :
      dualLocalNorm invHess xbar0 (phiGrad xbar0) ≤ sourceBound)
    (hsource_tail : sourceBound ≤ tailBound)
    (hbudget : sourceBound / den ≤ tailBound) :
    ∀ N,
      dualLocalNorm invHess (xseq N) (phiGrad xbar0) ≤ tailBound := by
  intro N
  cases N with
  | zero =>
      simpa [hx0] using hsource.trans hsource_tail
  | succ N =>
      have hcert :
          HessianSegmentMixedThirdLocalNormCertificate hess thirdMixed
            xbar0 (xseq (N + 1)) M
              (localNorm hess xbar0 (xseq (N + 1) - xbar0)) :=
        HessianSegmentMixedThirdLocalNormCertificate.of_convex_mixedThirdSelfConcordantOn_of_hasFDerivAt_sourceRadius
          (s := s) (hess := hess) (hessDeriv := hessDeriv)
          (thirdMixed := thirdMixed) (x := xbar0) (y := xseq (N + 1))
          (M := M) (hMr_lt N) hs hxbar0 (hxseq_succ N) hsc hess_pos
          (hdiff_ne N) hhess_cont (hhess N) (hmixed N)
      have hMr_nonneg :
          0 ≤ M * localNorm hess xbar0 (xseq (N + 1) - xbar0) :=
        mul_nonneg hsc.parameter_pos.le
          (localNorm_nonneg hess xbar0 (xseq (N + 1) - xbar0))
      have htail :=
        chewi1316_sourceTailBound_of_hessianSegmentMixedThirdLocalNormCertificate_and_inverseIdentity
          (hess := hess) (invHess := invHess) (thirdMixed := thirdMixed)
          (phiGrad := phiGrad) (xbar0 := xbar0) (y := xseq (N + 1))
          (M := M)
          (r := localNorm hess xbar0 (xseq (N + 1) - xbar0))
          (sourceBound := sourceBound) (den := den) (tailBound := tailBound)
          hden_pos (fun v => hsc.hess_nonneg hxbar0 v)
          (fun v => hsc.hess_nonneg (hxseq_succ N) v)
          (hxseq_inv_nonneg (N + 1)) hcert hMr_nonneg (hMr_lt N)
          (hden_le N) (hxseq_inv_local (N + 1)) hxbar0_cauchy hsource
          hbudget
      simpa [Nat.succ_eq_add_one] using htail

/--
Uniform preliminary source-tail bound from a single radius budget on successor
source-radius segments.  The global radius budget discharges the per-successor
`M * r_N < 1` and denominator inequalities.
-/
theorem chewi1316_uniformTailBound_of_sourceRadius_successor_radiusBound_and_inverseIdentity
    {s : Set E} {hess : E -> E →L[ℝ] E}
    {hessDeriv : E -> E →L[ℝ] (E →L[ℝ] E)}
    {invHess : E -> E →L[ℝ] E}
    {thirdMixed : E -> E -> E -> ℝ} {phiGrad : E -> E}
    {xbar0 : E} {xseq : ℕ -> E}
    {M radiusBound sourceBound den tailBound : ℝ}
    (hden_pos : 0 < den)
    (hs : Convex ℝ s)
    (hxbar0 : xbar0 ∈ s)
    (hx0 : xseq 0 = xbar0)
    (hxseq_succ : ∀ N : ℕ, xseq (N + 1) ∈ s)
    (hsc : MixedThirdSelfConcordantOn s hess thirdMixed M)
    (hess_pos : ∀ ⦃z : E⦄, z ∈ s -> ∀ v : E, v ≠ 0 ->
      0 < inner ℝ v (hess z v))
    (hdiff_ne : ∀ N : ℕ, xseq (N + 1) - xbar0 ≠ 0)
    (hhess_cont : ContinuousOn hess s)
    (hhess : ∀ N t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        HasFDerivAt hess
          (hessDeriv (hessianSegmentPoint xbar0 (xseq (N + 1)) t))
          (hessianSegmentPoint xbar0 (xseq (N + 1)) t))
    (hmixed : ∀ N v t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        inner ℝ v
            ((hessDeriv (hessianSegmentPoint xbar0 (xseq (N + 1)) t)
              (xseq (N + 1) - xbar0)) v) =
          hessianSegmentMixedThirdPsiDeriv thirdMixed
            xbar0 (xseq (N + 1)) v t)
    (hradius_bound : ∀ N : ℕ,
      localNorm hess xbar0 (xseq (N + 1) - xbar0) ≤ radiusBound)
    (hM_radius_lt : M * radiusBound < 1)
    (hden_le_radius : den ≤ 1 - M * radiusBound)
    (hxseq_inv_nonneg : ∀ N v,
      0 ≤ inner ℝ v (invHess (xseq N) v))
    (hxseq_inv_local : ∀ N v,
      localNorm hess (xseq N) (invHess (xseq N) v) =
        dualLocalNorm invHess (xseq N) v)
    (hxbar0_cauchy : ∀ v w : E,
      inner ℝ v w ≤ dualLocalNorm invHess xbar0 v *
        localNorm hess xbar0 w)
    (hsource :
      dualLocalNorm invHess xbar0 (phiGrad xbar0) ≤ sourceBound)
    (hsource_tail : sourceBound ≤ tailBound)
    (hbudget : sourceBound / den ≤ tailBound) :
    ∀ N,
      dualLocalNorm invHess (xseq N) (phiGrad xbar0) ≤ tailBound :=
  chewi1316_uniformTailBound_of_sourceRadius_successor_and_inverseIdentity
    (s := s) (hess := hess) (hessDeriv := hessDeriv)
    (invHess := invHess) (thirdMixed := thirdMixed) (phiGrad := phiGrad)
    (xbar0 := xbar0) (xseq := xseq) (M := M)
    (sourceBound := sourceBound) (den := den) (tailBound := tailBound)
    hden_pos hs hxbar0 hx0 hxseq_succ hsc hess_pos hdiff_ne hhess_cont
    hhess hmixed
    (by
      intro N
      have hmul_le :
          M * localNorm hess xbar0 (xseq (N + 1) - xbar0) ≤
            M * radiusBound :=
        mul_le_mul_of_nonneg_left (hradius_bound N) hsc.parameter_pos.le
      exact hmul_le.trans_lt hM_radius_lt)
    (by
      intro N
      have hmul_le :
          M * localNorm hess xbar0 (xseq (N + 1) - xbar0) ≤
            M * radiusBound :=
        mul_le_mul_of_nonneg_left (hradius_bound N) hsc.parameter_pos.le
      have hden_mono :
          1 - M * radiusBound ≤
            1 - M * localNorm hess xbar0 (xseq (N + 1) - xbar0) := by
        nlinarith
      exact hden_le_radius.trans hden_mono)
    hxseq_inv_nonneg hxseq_inv_local hxbar0_cauchy hsource hsource_tail
    hbudget

/--
Scalar helper for source-start preliminary tails: if the transported source
budget already controls `sourceBound / den` and `0 < den <= 1`, then the
degenerate source index is controlled by the same `tailBound`.
-/
theorem sourceBound_le_tailBound_of_div_budget
    {sourceBound den tailBound : ℝ}
    (hsource_nonneg : 0 ≤ sourceBound)
    (hden_pos : 0 < den)
    (hden_le_one : den ≤ 1)
    (hbudget : sourceBound / den ≤ tailBound) :
    sourceBound ≤ tailBound := by
  have hsource_le_div : sourceBound ≤ sourceBound / den :=
    le_div_self hsource_nonneg hden_pos hden_le_one
  exact hsource_le_div.trans hbudget

/--
Uniform-radius source-tail bridge with the degenerate source-index tail bound
derived from the denominator budget.  This removes the separate
`sourceBound <= tailBound` side condition from exact-source callers.
-/
theorem chewi1316_uniformTailBound_of_sourceRadius_successor_radiusBound_budget_and_inverseIdentity
    {s : Set E} {hess : E -> E →L[ℝ] E}
    {hessDeriv : E -> E →L[ℝ] (E →L[ℝ] E)}
    {invHess : E -> E →L[ℝ] E}
    {thirdMixed : E -> E -> E -> ℝ} {phiGrad : E -> E}
    {xbar0 : E} {xseq : ℕ -> E}
    {M radiusBound sourceBound den tailBound : ℝ}
    (hden_pos : 0 < den)
    (hs : Convex ℝ s)
    (hxbar0 : xbar0 ∈ s)
    (hx0 : xseq 0 = xbar0)
    (hxseq_succ : ∀ N : ℕ, xseq (N + 1) ∈ s)
    (hsc : MixedThirdSelfConcordantOn s hess thirdMixed M)
    (hess_pos : ∀ ⦃z : E⦄, z ∈ s -> ∀ v : E, v ≠ 0 ->
      0 < inner ℝ v (hess z v))
    (hdiff_ne : ∀ N : ℕ, xseq (N + 1) - xbar0 ≠ 0)
    (hhess_cont : ContinuousOn hess s)
    (hhess : ∀ N t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        HasFDerivAt hess
          (hessDeriv (hessianSegmentPoint xbar0 (xseq (N + 1)) t))
          (hessianSegmentPoint xbar0 (xseq (N + 1)) t))
    (hmixed : ∀ N v t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        inner ℝ v
            ((hessDeriv (hessianSegmentPoint xbar0 (xseq (N + 1)) t)
              (xseq (N + 1) - xbar0)) v) =
          hessianSegmentMixedThirdPsiDeriv thirdMixed
            xbar0 (xseq (N + 1)) v t)
    (hradius_bound : ∀ N : ℕ,
      localNorm hess xbar0 (xseq (N + 1) - xbar0) ≤ radiusBound)
    (hM_radius_lt : M * radiusBound < 1)
    (hden_le_radius : den ≤ 1 - M * radiusBound)
    (hxseq_inv_nonneg : ∀ N v,
      0 ≤ inner ℝ v (invHess (xseq N) v))
    (hxseq_inv_local : ∀ N v,
      localNorm hess (xseq N) (invHess (xseq N) v) =
        dualLocalNorm invHess (xseq N) v)
    (hxbar0_cauchy : ∀ v w : E,
      inner ℝ v w ≤ dualLocalNorm invHess xbar0 v *
        localNorm hess xbar0 w)
    (hsource :
      dualLocalNorm invHess xbar0 (phiGrad xbar0) ≤ sourceBound)
    (hbudget : sourceBound / den ≤ tailBound) :
    ∀ N,
      dualLocalNorm invHess (xseq N) (phiGrad xbar0) ≤ tailBound := by
  have hsource_nonneg : 0 ≤ sourceBound :=
    (dualLocalNorm_nonneg invHess xbar0 (phiGrad xbar0)).trans hsource
  have hradius_nonneg : 0 ≤ radiusBound :=
    (localNorm_nonneg hess xbar0 (xseq (0 + 1) - xbar0)).trans
      (hradius_bound 0)
  have hden_le_one : den ≤ 1 := by
    have hMr_nonneg : 0 ≤ M * radiusBound :=
      mul_nonneg hsc.parameter_pos.le hradius_nonneg
    linarith
  have hsource_tail : sourceBound ≤ tailBound :=
    sourceBound_le_tailBound_of_div_budget hsource_nonneg hden_pos
      hden_le_one hbudget
  exact
    chewi1316_uniformTailBound_of_sourceRadius_successor_radiusBound_and_inverseIdentity
      (s := s) (hess := hess) (hessDeriv := hessDeriv)
      (invHess := invHess) (thirdMixed := thirdMixed) (phiGrad := phiGrad)
      (xbar0 := xbar0) (xseq := xseq) (M := M)
      (radiusBound := radiusBound) (sourceBound := sourceBound)
      (den := den) (tailBound := tailBound) hden_pos hs hxbar0 hx0
      hxseq_succ hsc hess_pos hdiff_ne hhess_cont hhess hmixed
      hradius_bound hM_radius_lt hden_le_radius hxseq_inv_nonneg
      hxseq_inv_local hxbar0_cauchy hsource hsource_tail hbudget

/--
Canonical-denominator version of the uniform-radius source-tail bridge.  The
denominator is exactly `1 - M * radiusBound`, so callers only need the global
radius bound, `M * radiusBound < 1`, and the final source budget.
-/
theorem chewi1316_uniformTailBound_of_sourceRadius_successor_radiusBound_canonicalDen_and_inverseIdentity
    {s : Set E} {hess : E -> E →L[ℝ] E}
    {hessDeriv : E -> E →L[ℝ] (E →L[ℝ] E)}
    {invHess : E -> E →L[ℝ] E}
    {thirdMixed : E -> E -> E -> ℝ} {phiGrad : E -> E}
    {xbar0 : E} {xseq : ℕ -> E}
    {M radiusBound sourceBound tailBound : ℝ}
    (hs : Convex ℝ s)
    (hxbar0 : xbar0 ∈ s)
    (hx0 : xseq 0 = xbar0)
    (hxseq_succ : ∀ N : ℕ, xseq (N + 1) ∈ s)
    (hsc : MixedThirdSelfConcordantOn s hess thirdMixed M)
    (hess_pos : ∀ ⦃z : E⦄, z ∈ s -> ∀ v : E, v ≠ 0 ->
      0 < inner ℝ v (hess z v))
    (hdiff_ne : ∀ N : ℕ, xseq (N + 1) - xbar0 ≠ 0)
    (hhess_cont : ContinuousOn hess s)
    (hhess : ∀ N t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        HasFDerivAt hess
          (hessDeriv (hessianSegmentPoint xbar0 (xseq (N + 1)) t))
          (hessianSegmentPoint xbar0 (xseq (N + 1)) t))
    (hmixed : ∀ N v t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        inner ℝ v
            ((hessDeriv (hessianSegmentPoint xbar0 (xseq (N + 1)) t)
              (xseq (N + 1) - xbar0)) v) =
          hessianSegmentMixedThirdPsiDeriv thirdMixed
            xbar0 (xseq (N + 1)) v t)
    (hradius_bound : ∀ N : ℕ,
      localNorm hess xbar0 (xseq (N + 1) - xbar0) ≤ radiusBound)
    (hM_radius_lt : M * radiusBound < 1)
    (hxseq_inv_nonneg : ∀ N v,
      0 ≤ inner ℝ v (invHess (xseq N) v))
    (hxseq_inv_local : ∀ N v,
      localNorm hess (xseq N) (invHess (xseq N) v) =
        dualLocalNorm invHess (xseq N) v)
    (hxbar0_cauchy : ∀ v w : E,
      inner ℝ v w ≤ dualLocalNorm invHess xbar0 v *
        localNorm hess xbar0 w)
    (hsource :
      dualLocalNorm invHess xbar0 (phiGrad xbar0) ≤ sourceBound)
    (hbudget : sourceBound / (1 - M * radiusBound) ≤ tailBound) :
    ∀ N,
      dualLocalNorm invHess (xseq N) (phiGrad xbar0) ≤ tailBound := by
  have hden_pos : 0 < 1 - M * radiusBound := by
    linarith
  exact
    chewi1316_uniformTailBound_of_sourceRadius_successor_radiusBound_budget_and_inverseIdentity
      (s := s) (hess := hess) (hessDeriv := hessDeriv)
      (invHess := invHess) (thirdMixed := thirdMixed) (phiGrad := phiGrad)
      (xbar0 := xbar0) (xseq := xseq) (M := M)
      (radiusBound := radiusBound) (sourceBound := sourceBound)
      (den := 1 - M * radiusBound) (tailBound := tailBound) hden_pos hs
      hxbar0 hx0 hxseq_succ hsc hess_pos hdiff_ne hhess_cont hhess
      hmixed hradius_bound hM_radius_lt le_rfl hxseq_inv_nonneg
      hxseq_inv_local hxbar0_cauchy hsource hbudget

/--
Zero-displacement-safe canonical-denominator source-tail bridge.  Successor
indices equal to the source point are discharged by the source tail; nonzero
successors use the source-radius mixed-third segment certificate.
-/
theorem chewi1316_uniformTailBound_of_sourceRadius_successor_radiusBound_canonicalDen_zeroSafe_and_inverseIdentity
    {s : Set E} {hess : E -> E →L[ℝ] E}
    {hessDeriv : E -> E →L[ℝ] (E →L[ℝ] E)}
    {invHess : E -> E →L[ℝ] E}
    {thirdMixed : E -> E -> E -> ℝ} {phiGrad : E -> E}
    {xbar0 : E} {xseq : ℕ -> E}
    {M radiusBound sourceBound tailBound : ℝ}
    (hs : Convex ℝ s)
    (hxbar0 : xbar0 ∈ s)
    (hx0 : xseq 0 = xbar0)
    (hxseq_succ : ∀ N : ℕ, xseq (N + 1) ∈ s)
    (hsc : MixedThirdSelfConcordantOn s hess thirdMixed M)
    (hess_pos : ∀ ⦃z : E⦄, z ∈ s -> ∀ v : E, v ≠ 0 ->
      0 < inner ℝ v (hess z v))
    (hhess_cont : ContinuousOn hess s)
    (hhess : ∀ N t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        HasFDerivAt hess
          (hessDeriv (hessianSegmentPoint xbar0 (xseq (N + 1)) t))
          (hessianSegmentPoint xbar0 (xseq (N + 1)) t))
    (hmixed : ∀ N v t,
      t ∈ interior (Set.Icc (0 : ℝ) 1) ->
        inner ℝ v
            ((hessDeriv (hessianSegmentPoint xbar0 (xseq (N + 1)) t)
              (xseq (N + 1) - xbar0)) v) =
          hessianSegmentMixedThirdPsiDeriv thirdMixed
            xbar0 (xseq (N + 1)) v t)
    (hradius_bound : ∀ N : ℕ,
      localNorm hess xbar0 (xseq (N + 1) - xbar0) ≤ radiusBound)
    (hM_radius_lt : M * radiusBound < 1)
    (hxseq_inv_nonneg : ∀ N v,
      0 ≤ inner ℝ v (invHess (xseq N) v))
    (hxseq_inv_local : ∀ N v,
      localNorm hess (xseq N) (invHess (xseq N) v) =
        dualLocalNorm invHess (xseq N) v)
    (hxbar0_cauchy : ∀ v w : E,
      inner ℝ v w ≤ dualLocalNorm invHess xbar0 v *
        localNorm hess xbar0 w)
    (hsource :
      dualLocalNorm invHess xbar0 (phiGrad xbar0) ≤ sourceBound)
    (hbudget : sourceBound / (1 - M * radiusBound) ≤ tailBound) :
    ∀ N,
      dualLocalNorm invHess (xseq N) (phiGrad xbar0) ≤ tailBound := by
  have hden_pos : 0 < 1 - M * radiusBound := by
    linarith
  have hsource_nonneg : 0 ≤ sourceBound :=
    (dualLocalNorm_nonneg invHess xbar0 (phiGrad xbar0)).trans hsource
  have hradius_nonneg : 0 ≤ radiusBound :=
    (localNorm_nonneg hess xbar0 (xseq (0 + 1) - xbar0)).trans
      (hradius_bound 0)
  have hden_le_one : 1 - M * radiusBound ≤ 1 := by
    have hMr_nonneg : 0 ≤ M * radiusBound :=
      mul_nonneg hsc.parameter_pos.le hradius_nonneg
    linarith
  have hsource_tail : sourceBound ≤ tailBound :=
    sourceBound_le_tailBound_of_div_budget hsource_nonneg hden_pos
      hden_le_one hbudget
  intro N
  cases N with
  | zero =>
      simpa [hx0] using hsource.trans hsource_tail
  | succ N =>
      by_cases hzero : xseq (N + 1) - xbar0 = 0
      · have hxy : xseq (N + 1) = xbar0 := sub_eq_zero.mp hzero
        simpa [Nat.succ_eq_add_one, hxy] using hsource.trans hsource_tail
      · have hmul_le :
            M * localNorm hess xbar0 (xseq (N + 1) - xbar0) ≤
              M * radiusBound :=
          mul_le_mul_of_nonneg_left (hradius_bound N) hsc.parameter_pos.le
        have hMr_lt :
            M * localNorm hess xbar0 (xseq (N + 1) - xbar0) < 1 :=
          hmul_le.trans_lt hM_radius_lt
        have hden_le :
            1 - M * radiusBound ≤
              1 - M * localNorm hess xbar0 (xseq (N + 1) - xbar0) := by
          nlinarith
        have hcert :
            HessianSegmentMixedThirdLocalNormCertificate hess thirdMixed
              xbar0 (xseq (N + 1)) M
                (localNorm hess xbar0 (xseq (N + 1) - xbar0)) :=
          HessianSegmentMixedThirdLocalNormCertificate.of_convex_mixedThirdSelfConcordantOn_of_hasFDerivAt_sourceRadius
            (s := s) (hess := hess) (hessDeriv := hessDeriv)
            (thirdMixed := thirdMixed) (x := xbar0) (y := xseq (N + 1))
            (M := M) hMr_lt hs hxbar0 (hxseq_succ N) hsc hess_pos hzero
            hhess_cont (hhess N) (hmixed N)
        have hMr_nonneg :
            0 ≤ M * localNorm hess xbar0 (xseq (N + 1) - xbar0) :=
          mul_nonneg hsc.parameter_pos.le
            (localNorm_nonneg hess xbar0 (xseq (N + 1) - xbar0))
        have htail :=
          chewi1316_sourceTailBound_of_hessianSegmentMixedThirdLocalNormCertificate_and_inverseIdentity
            (hess := hess) (invHess := invHess) (thirdMixed := thirdMixed)
            (phiGrad := phiGrad) (xbar0 := xbar0) (y := xseq (N + 1))
            (M := M)
            (r := localNorm hess xbar0 (xseq (N + 1) - xbar0))
            (sourceBound := sourceBound) (den := 1 - M * radiusBound)
            (tailBound := tailBound) hden_pos
            (fun v => hsc.hess_nonneg hxbar0 v)
            (fun v => hsc.hess_nonneg (hxseq_succ N) v)
            (hxseq_inv_nonneg (N + 1)) hcert hMr_nonneg hMr_lt hden_le
            (hxseq_inv_local (N + 1)) hxbar0_cauchy hsource hbudget
        simpa [Nat.succ_eq_add_one] using htail

/--
Global-derivative interface for the zero-displacement-safe canonical
source-tail bridge.  This packages the recurring step of deriving each
successor segment's Hessian derivative and mixed-third identity from a global
oracle on the convex domain.
-/
theorem chewi1316_uniformTailBound_of_sourceRadius_successor_radiusBound_canonicalDen_zeroSafe_globalDeriv_and_inverseIdentity
    {s : Set E} {hess : E -> E →L[ℝ] E}
    {hessDeriv : E -> E →L[ℝ] (E →L[ℝ] E)}
    {invHess : E -> E →L[ℝ] E}
    {thirdMixed : E -> E -> E -> ℝ} {phiGrad : E -> E}
    {xbar0 : E} {xseq : ℕ -> E}
    {M radiusBound sourceBound tailBound : ℝ}
    (hs : Convex ℝ s)
    (hxbar0 : xbar0 ∈ s)
    (hx0 : xseq 0 = xbar0)
    (hxseq_succ : ∀ N : ℕ, xseq (N + 1) ∈ s)
    (hsc : MixedThirdSelfConcordantOn s hess thirdMixed M)
    (hess_pos : ∀ ⦃z : E⦄, z ∈ s -> ∀ v : E, v ≠ 0 ->
      0 < inner ℝ v (hess z v))
    (hhess_cont : ContinuousOn hess s)
    (hhess_global : ∀ z, z ∈ s -> HasFDerivAt hess (hessDeriv z) z)
    (hmixed_global : ∀ z, z ∈ s -> ∀ a v : E,
      inner ℝ v ((hessDeriv z a) v) = thirdMixed z a v)
    (hradius_bound : ∀ N : ℕ,
      localNorm hess xbar0 (xseq (N + 1) - xbar0) ≤ radiusBound)
    (hM_radius_lt : M * radiusBound < 1)
    (hxseq_inv_nonneg : ∀ N v,
      0 ≤ inner ℝ v (invHess (xseq N) v))
    (hxseq_inv_local : ∀ N v,
      localNorm hess (xseq N) (invHess (xseq N) v) =
        dualLocalNorm invHess (xseq N) v)
    (hxbar0_cauchy : ∀ v w : E,
      inner ℝ v w ≤ dualLocalNorm invHess xbar0 v *
        localNorm hess xbar0 w)
    (hsource :
      dualLocalNorm invHess xbar0 (phiGrad xbar0) ≤ sourceBound)
    (hbudget : sourceBound / (1 - M * radiusBound) ≤ tailBound) :
    ∀ N,
      dualLocalNorm invHess (xseq N) (phiGrad xbar0) ≤ tailBound :=
  chewi1316_uniformTailBound_of_sourceRadius_successor_radiusBound_canonicalDen_zeroSafe_and_inverseIdentity
    (s := s) (hess := hess) (hessDeriv := hessDeriv)
    (invHess := invHess) (thirdMixed := thirdMixed) (phiGrad := phiGrad)
    (xbar0 := xbar0) (xseq := xseq) (M := M)
    (radiusBound := radiusBound) (sourceBound := sourceBound)
    (tailBound := tailBound) hs hxbar0 hx0 hxseq_succ hsc hess_pos
    hhess_cont
    (by
      intro N t ht
      exact hhess_global
        (hessianSegmentPoint xbar0 (xseq (N + 1)) t)
        (hessianSegmentPoint_mem_of_convex_interior hs hxbar0
          (hxseq_succ N) ht))
    (by
      intro N v t ht
      have hz :
          hessianSegmentPoint xbar0 (xseq (N + 1)) t ∈ s :=
        hessianSegmentPoint_mem_of_convex_interior hs hxbar0
          (hxseq_succ N) ht
      simpa [hessianSegmentMixedThirdPsiDeriv] using
        hmixed_global (hessianSegmentPoint xbar0 (xseq (N + 1)) t)
          hz (xseq (N + 1) - xbar0) v)
    hradius_bound hM_radius_lt hxseq_inv_nonneg hxseq_inv_local
    hxbar0_cauchy hsource hbudget

/--
Barrier-interface form of the zero-safe global-derivative source-tail bridge.
The self-concordance, inverse-Hessian nonnegativity, and source gradient bound
are read from `SelfConcordantBarrierOn`, leaving the caller with the concrete
successor membership, radius, and scalar budget obligations.
-/
theorem chewi1316_uniformTailBound_of_sourceRadius_successor_radiusBound_canonicalDen_zeroSafe_barrier_globalDeriv_and_inverseIdentity
    {s : Set E} {hess : E -> E →L[ℝ] E}
    {hessDeriv : E -> E →L[ℝ] (E →L[ℝ] E)}
    {invHess : E -> E →L[ℝ] E}
    {thirdMixed : E -> E -> E -> ℝ} {phiGrad : E -> E}
    {xbar0 : E} {xseq : ℕ -> E}
    {M nu radiusBound tailBound : ℝ}
    (hs : Convex ℝ s)
    (hxbar0 : xbar0 ∈ s)
    (hx0 : xseq 0 = xbar0)
    (hxseq_succ : ∀ N : ℕ, xseq (N + 1) ∈ s)
    (hbar : SelfConcordantBarrierOn s hess phiGrad invHess thirdMixed M nu)
    (hess_pos : ∀ ⦃z : E⦄, z ∈ s -> ∀ v : E, v ≠ 0 ->
      0 < inner ℝ v (hess z v))
    (hhess_cont : ContinuousOn hess s)
    (hhess_global : ∀ z, z ∈ s -> HasFDerivAt hess (hessDeriv z) z)
    (hmixed_global : ∀ z, z ∈ s -> ∀ a v : E,
      inner ℝ v ((hessDeriv z a) v) = thirdMixed z a v)
    (hradius_bound : ∀ N : ℕ,
      localNorm hess xbar0 (xseq (N + 1) - xbar0) ≤ radiusBound)
    (hM_radius_lt : M * radiusBound < 1)
    (hxseq_inv_local : ∀ N v,
      localNorm hess (xseq N) (invHess (xseq N) v) =
        dualLocalNorm invHess (xseq N) v)
    (hxbar0_cauchy : ∀ v w : E,
      inner ℝ v w ≤ dualLocalNorm invHess xbar0 v *
        localNorm hess xbar0 w)
    (hbudget : Real.sqrt nu / (1 - M * radiusBound) ≤ tailBound) :
    ∀ N,
      dualLocalNorm invHess (xseq N) (phiGrad xbar0) ≤ tailBound :=
  chewi1316_uniformTailBound_of_sourceRadius_successor_radiusBound_canonicalDen_zeroSafe_globalDeriv_and_inverseIdentity
    (s := s) (hess := hess) (hessDeriv := hessDeriv)
    (invHess := invHess) (thirdMixed := thirdMixed) (phiGrad := phiGrad)
    (xbar0 := xbar0) (xseq := xseq) (M := M)
    (radiusBound := radiusBound) (sourceBound := Real.sqrt nu)
    (tailBound := tailBound) hs hxbar0 hx0 hxseq_succ
    hbar.self_concordant hess_pos hhess_cont hhess_global hmixed_global
    hradius_bound hM_radius_lt
    (by
      intro N v
      cases N with
      | zero =>
          simpa [hx0] using hbar.invHess_nonneg hxbar0 v
      | succ N =>
          simpa [Nat.succ_eq_add_one] using
            hbar.invHess_nonneg (hxseq_succ N) v)
    hxseq_inv_local hxbar0_cauchy (hbar.gradient_bound hxbar0) hbudget

/--
Unit-parameter, radius-half specialization of the barrier source-tail bridge.
This is the common Chewi self-concordant-barrier shape: the denominator is
`1 - (1)*(1/2)`, so the remaining scalar source budget is `2 * sqrt(nu)`.
-/
theorem chewi1316_uniformTailBound_of_sourceRadius_successor_radiusHalf_zeroSafe_barrier_globalDeriv_and_inverseIdentity
    {s : Set E} {hess : E -> E →L[ℝ] E}
    {hessDeriv : E -> E →L[ℝ] (E →L[ℝ] E)}
    {invHess : E -> E →L[ℝ] E}
    {thirdMixed : E -> E -> E -> ℝ} {phiGrad : E -> E}
    {xbar0 : E} {xseq : ℕ -> E} {nu tailBound : ℝ}
    (hs : Convex ℝ s)
    (hxbar0 : xbar0 ∈ s)
    (hx0 : xseq 0 = xbar0)
    (hxseq_succ : ∀ N : ℕ, xseq (N + 1) ∈ s)
    (hbar : SelfConcordantBarrierOn s hess phiGrad invHess thirdMixed (1 : ℝ) nu)
    (hess_pos : ∀ ⦃z : E⦄, z ∈ s -> ∀ v : E, v ≠ 0 ->
      0 < inner ℝ v (hess z v))
    (hhess_cont : ContinuousOn hess s)
    (hhess_global : ∀ z, z ∈ s -> HasFDerivAt hess (hessDeriv z) z)
    (hmixed_global : ∀ z, z ∈ s -> ∀ a v : E,
      inner ℝ v ((hessDeriv z a) v) = thirdMixed z a v)
    (hradius_half : ∀ N : ℕ,
      localNorm hess xbar0 (xseq (N + 1) - xbar0) ≤ 1 / 2)
    (hxseq_inv_local : ∀ N v,
      localNorm hess (xseq N) (invHess (xseq N) v) =
        dualLocalNorm invHess (xseq N) v)
    (hxbar0_cauchy : ∀ v w : E,
      inner ℝ v w ≤ dualLocalNorm invHess xbar0 v *
        localNorm hess xbar0 w)
    (hbudget : 2 * Real.sqrt nu ≤ tailBound) :
    ∀ N,
      dualLocalNorm invHess (xseq N) (phiGrad xbar0) ≤ tailBound :=
  chewi1316_uniformTailBound_of_sourceRadius_successor_radiusBound_canonicalDen_zeroSafe_barrier_globalDeriv_and_inverseIdentity
    (s := s) (hess := hess) (hessDeriv := hessDeriv)
    (invHess := invHess) (thirdMixed := thirdMixed) (phiGrad := phiGrad)
