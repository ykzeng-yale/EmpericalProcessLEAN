    inner ℝ v (invHess y v) ≤
        inner ℝ v (invHess x v) / den ^ (2 : ℕ) := hsq
    _ = den⁻¹ ^ (2 : ℕ) * inner ℝ v (invHess x v) := by
      field_simp [hden_ne]

/--
Denominator-shaped version of
