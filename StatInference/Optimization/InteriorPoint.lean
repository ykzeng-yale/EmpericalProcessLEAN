        tailBound := by
    simpa using htailBase_le Nsucc
  have htail :
      |(1 - c0 / Real.sqrt nu) ^ Nsucc| *
          dualLocalNorm invHess (xseq Nsucc) (phiGrad xbar0) ≤
        1 / 16 := by
    have htail' :=
      chewi1316_preliminary_final_tail_le_sixteenth_of_factorSqrtCountTailBoundLogBound_nonneg
