    durrett2019_theorem_4_5_7_min_terminal_integrable_of_terminal_integrable
    {Ω : Type*} [MeasurableSpace Ω] {P : Measure Ω} [IsFiniteMeasure P]
    {Ainf : Ω -> ℝ} {C : ℝ}
    (hAinf_int : Integrable Ainf P) :
