/--
Durrett 2019, Theorem 4.5.1 increasing-process source support: for the
canonical Doob increasing process of the square submartingale, `X_0 = 0`
implies `E X_n^2 = E A_n`.
-/
theorem durrett2019_theorem_4_5_1_square_integral_eq_predictablePart_square_of_initial_zero
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] {‚ĄĪ : Filtration ‚Ąē mő©}
    [SigmaFiniteFiltration P ‚ĄĪ]
    {X : ‚Ąē -> ő© -> ‚ĄĚ} (hX : Martingale X ‚ĄĪ P)
    (hX_memLp_two : ‚ąÄ n, MemLp (X n) (2 : ‚ĄĚ‚Č•0‚ąě) P)
    (hX0 : X 0 =ŠĶź[P] 0) :
    ‚ąÄ n,
      (‚ąę ŌČ, X n ŌČ ^ 2 ‚ąāP) =
        ‚ąę ŌČ, predictablePart (fun k ŌČ => X k ŌČ ^ 2) ‚ĄĪ P n ŌČ ‚ąāP := by
  let Y : ‚Ąē -> ő© -> ‚ĄĚ := fun k ŌČ => X k ŌČ ^ 2
  have hY_int : ‚ąÄ n, Integrable (Y n) P := by
    intro n
    exact durrett2019_integrable_sq_of_memLp_two
      (P := P) (Y := X n) (hX_memLp_two n)
  have hY_adapted : StronglyAdapted ‚ĄĪ Y := by
    intro n
    exact (hX.stronglyMeasurable n).pow 2
  have hM :
      Martingale (martingalePart Y ‚ĄĪ P) ‚ĄĪ P :=
    martingale_martingalePart hY_adapted hY_int
  intro n
  have hM_int : Integrable (martingalePart Y ‚ĄĪ P n) P :=
    integrable_martingalePart hY_int n
  have hA_int : Integrable (predictablePart Y ‚ĄĪ P n) P := by
    rw [predictablePart]
    fun_prop
  have hM0 : martingalePart Y ‚ĄĪ P 0 =ŠĶź[P] 0 := by
    filter_upwards [hX0] with ŌČ hŌČ
    simp [Y, hŌČ]
  have hM_integral_zero :
      (‚ąę ŌČ, martingalePart Y ‚ĄĪ P n ŌČ ‚ąāP) = 0 := by
    calc
      (‚ąę ŌČ, martingalePart Y ‚ĄĪ P n ŌČ ‚ąāP)
          = ‚ąę ŌČ, martingalePart Y ‚ĄĪ P 0 ŌČ ‚ąāP :=
            durrett2019_martingale_integral_eq_initial
              (P := P) (‚ĄĪ := ‚ĄĪ) (M := martingalePart Y ‚ĄĪ P) hM n
      _ = 0 := integral_eq_zero_of_ae hM0
  have hdecomp :
      (fun ŌČ => martingalePart Y ‚ĄĪ P n ŌČ + predictablePart Y ‚ĄĪ P n ŌČ)
        =ŠĶź[P] Y n := by
    exact ae_of_all P fun ŌČ => by
      have h :=
        congrFun (congrFun (martingalePart_add_predictablePart ‚ĄĪ P Y) n) ŌČ
      simpa [Pi.add_apply] using h
  calc
    (‚ąę ŌČ, X n ŌČ ^ 2 ‚ąāP) = ‚ąę ŌČ, Y n ŌČ ‚ąāP := by rfl
    _ = ‚ąę ŌČ, martingalePart Y ‚ĄĪ P n ŌČ + predictablePart Y ‚ĄĪ P n ŌČ ‚ąāP :=
        (integral_congr_ae hdecomp.symm)
    _ = (‚ąę ŌČ, martingalePart Y ‚ĄĪ P n ŌČ ‚ąāP) +
        ‚ąę ŌČ, predictablePart Y ‚ĄĪ P n ŌČ ‚ąāP :=
        integral_add hM_int hA_int
    _ = ‚ąę ŌČ, predictablePart Y ‚ĄĪ P n ŌČ ‚ąāP := by
        rw [hM_integral_zero, zero_add]
    _ = ‚ąę ŌČ, predictablePart (fun k ŌČ => X k ŌČ ^ 2) ‚ĄĪ P n ŌČ ‚ąāP := by rfl

/--
Durrett 2019, Theorem 4.5.1 source support: for a square-integrable
martingale, the square process minus its canonical predictable part is the
martingale part of the square submartingale.
-/
theorem durrett2019_martingale_square_sub_predictablePart_martingale
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] {‚ĄĪ : Filtration ‚Ąē mő©}
    [SigmaFiniteFiltration P ‚ĄĪ]
    {X : ‚Ąē -> ő© -> ‚ĄĚ} (hX : Martingale X ‚ĄĪ P)
    (hX_memLp_two : ‚ąÄ n, MemLp (X n) (2 : ‚ĄĚ‚Č•0‚ąě) P) :
    Martingale
      (fun n ŌČ => X n ŌČ ^ 2 -
        predictablePart (fun k ŌČ => X k ŌČ ^ 2) ‚ĄĪ P n ŌČ) ‚ĄĪ P := by
  let Y : ‚Ąē -> ő© -> ‚ĄĚ := fun k ŌČ => X k ŌČ ^ 2
  have hY_int : ‚ąÄ n, Integrable (Y n) P := by
    intro n
    exact durrett2019_integrable_sq_of_memLp_two
      (P := P) (Y := X n) (hX_memLp_two n)
  have hY_adapted : StronglyAdapted ‚ĄĪ Y := by
    intro n
    exact (hX.stronglyMeasurable n).pow 2
  have hM : Martingale (martingalePart Y ‚ĄĪ P) ‚ĄĪ P :=
    martingale_martingalePart hY_adapted hY_int
  have hEq :
      (fun n ŌČ => X n ŌČ ^ 2 - predictablePart (fun k ŌČ => X k ŌČ ^ 2) ‚ĄĪ P n ŌČ) =
        martingalePart Y ‚ĄĪ P := by
    ext n ŌČ
    have hdecomp :=
      congrFun (congrFun (martingalePart_add_predictablePart ‚ĄĪ P Y) n) ŌČ
    have hdecomp' :
        martingalePart Y ‚ĄĪ P n ŌČ +
            predictablePart (fun k ŌČ => X k ŌČ ^ 2) ‚ĄĪ P n ŌČ =
          X n ŌČ ^ 2 := by
      simpa [Y] using hdecomp
    linarith
  simpa [hEq]
    using hM

