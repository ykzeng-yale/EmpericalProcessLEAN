        ((n : ℝ)⁻¹) ^ 2 * ((n : ℝ) * C) := by
          exact mul_le_mul_of_nonneg_left hsum (sq_nonneg _)
    _ = C / n := by
          field_simp [Nat.cast_ne_zero.mpr hn.ne']

