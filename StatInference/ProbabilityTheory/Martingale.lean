theorem durrett2019_isStronglyPredictable_stoppedProcess_of_predictable
    {ő© : Type*} [mő© : MeasurableSpace ő©] {‚ĄĪ : Filtration ‚Ąē mő©}
    {A : ‚Ąē -> ő© -> ‚ĄĚ} {N : ő© -> ‚Ąē‚ąě}
    (hA_predictable : IsStronglyPredictable ‚ĄĪ A) (hN : IsStoppingTime ‚ĄĪ N) :
    IsStronglyPredictable ‚ĄĪ (stoppedProcess A N) := by
  refine IsStronglyPredictable.of_measurable_add_one ?h0 ?hsucc
  ¬∑ have hA0 : StronglyMeasurable[‚ĄĪ 0] (A 0) :=
      hA_predictable.stronglyAdapted 0
    have hstop0 : stoppedProcess A N 0 = A 0 := by
      ext ŌČ
      exact
        stoppedProcess_eq_of_le
          (u := A) (ŌĄ := N) (i := 0) (ŌČ := ŌČ)
          (by cases N ŌČ <;> simp)
    simpa [hstop0] using hA0
  ¬∑ intro n
    have hLiveSet : MeasurableSet[‚ĄĪ n] {ŌČ : ő© | (n + 1 : ‚Ąē‚ąě) ‚Č§ N ŌČ} := by
      have hgt : MeasurableSet[‚ĄĪ n] {ŌČ : ő© | (n : ‚Ąē‚ąě) < N ŌČ} :=
        hN.measurableSet_gt n
      have hset :
          {ŌČ : ő© | (n + 1 : ‚Ąē‚ąě) ‚Č§ N ŌČ} =
            {ŌČ : ő© | (n : ‚Ąē‚ąě) < N ŌČ} := by
        ext ŌČ
        simpa [Nat.cast_add] using
          (ENat.add_one_le_iff (m := (n : ‚Ąē‚ąě)) (n := N ŌČ)
            (ENat.coe_ne_top n))
      simpa [hset] using hgt
    have hLive :
        StronglyMeasurable[‚ĄĪ n]
          (Set.indicator {ŌČ : ő© | (n + 1 : ‚Ąē‚ąě) ‚Č§ N ŌČ} (A (n + 1))) :=
      (hA_predictable.measurable_add_one n).indicator hLiveSet
