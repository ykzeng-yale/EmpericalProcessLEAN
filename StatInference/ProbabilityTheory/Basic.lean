theorem durrett2019_theorem_2_5_10_integral_base_truncated_sq_eq_abs_truncation_sq
    {Ω : Type u} [MeasurableSpace Ω] {P : Measure Ω}
    {X : Ω -> ℝ} (k : ℕ) :
