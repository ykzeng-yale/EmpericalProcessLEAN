/--
Durrett 2019, Theorem 4.5.3 conditional-variance pull-out support.

If `H` is known at time `k`, then a conditional square bound for `Y` can be
multiplied by `H^2` and integrated.  This is the reusable measure-theoretic
core behind the textbook estimate with `H = f(A_{k+1})^{-1}`.
-/
theorem durrett2019_theorem_4_5_3_integral_mul_sq_le_of_condExp_square_le
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P]
    {‚ĄĪ : Filtration ‚Ąē mő©} [SigmaFiniteFiltration P ‚ĄĪ]
    {H Y V : ő© -> ‚ĄĚ} {k : ‚Ąē}
    (hH_meas : StronglyMeasurable[‚ĄĪ k] H)
    (hHY_int : Integrable (fun ŌČ => H ŌČ ^ 2 * Y ŌČ ^ 2) P)
    (hY_sq_int : Integrable (fun ŌČ => Y ŌČ ^ 2) P)
    (hHV_int : Integrable (fun ŌČ => H ŌČ ^ 2 * V ŌČ) P)
    (hcond_le : P[(fun ŌČ => Y ŌČ ^ 2) | ‚ĄĪ k] ‚Č§ŠĶź[P] V) :
    (‚ąę ŌČ, H ŌČ ^ 2 * Y ŌČ ^ 2 ‚ąāP) ‚Č§
      ‚ąę ŌČ, H ŌČ ^ 2 * V ŌČ ‚ąāP := by
  have hpull :
      P[(fun ŌČ => H ŌČ ^ 2 * Y ŌČ ^ 2) | ‚ĄĪ k] =ŠĶź[P]
        fun ŌČ => H ŌČ ^ 2 * P[(fun ŌČ => Y ŌČ ^ 2) | ‚ĄĪ k] ŌČ := by
    exact
      condExp_mul_of_stronglyMeasurable_left (őľ := P) (m := ‚ĄĪ k)
        (hH_meas.pow 2) hHY_int hY_sq_int
  have hleft_int :
      Integrable
        (fun ŌČ => H ŌČ ^ 2 * P[(fun ŌČ => Y ŌČ ^ 2) | ‚ĄĪ k] ŌČ) P :=
    (integrable_condExp
      (őľ := P) (m := ‚ĄĪ k) (f := fun ŌČ => H ŌČ ^ 2 * Y ŌČ ^ 2)).congr hpull
  calc
    (‚ąę ŌČ, H ŌČ ^ 2 * Y ŌČ ^ 2 ‚ąāP)
        = ‚ąę ŌČ, P[(fun ŌČ => H ŌČ ^ 2 * Y ŌČ ^ 2) | ‚ĄĪ k] ŌČ ‚ąāP := by
          exact (integral_condExp (őľ := P) (m := ‚ĄĪ k) (‚ĄĪ.le k)).symm
    _ = ‚ąę ŌČ, H ŌČ ^ 2 * P[(fun ŌČ => Y ŌČ ^ 2) | ‚ĄĪ k] ŌČ ‚ąāP :=
        integral_congr_ae hpull
    _ ‚Č§ ‚ąę ŌČ, H ŌČ ^ 2 * V ŌČ ‚ąāP := by
        exact
          integral_mono_ae hleft_int hHV_int
            (hcond_le.mono fun ŌČ hŌČ =>
              mul_le_mul_of_nonneg_left hŌČ (sq_nonneg (H ŌČ)))

/--
Durrett 2019, Theorem 4.5.3 conditional-variance source comparison.

This instantiates the V208 pull-out core with the textbook reciprocal
normalizer `H_k = f(A_{k+1})^{-1}` and martingale increment
`Y_k = X_{k+1} - X_k`.
-/
theorem durrett2019_theorem_4_5_3_reciprocal_comp_integral_le_variance_increment_of_condExp_square_le
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P]
    {‚ĄĪ : Filtration ‚Ąē mő©} [SigmaFiniteFiltration P ‚ĄĪ]
    {A X : ‚Ąē -> ő© -> ‚ĄĚ} {f : ‚ĄĚ -> ‚ĄĚ} {k : ‚Ąē}
    (hA_predictable : IsStronglyPredictable ‚ĄĪ A)
    (hf_cont : Continuous f)
    (hscaled_int :
      Integrable
        (fun ŌČ =>
          ((f (A (k + 1) ŌČ))‚ĀĽ¬Ļ * (X (k + 1) ŌČ - X k ŌČ)) ^ 2) P)
    (hdiff_sq_int :
      Integrable (fun ŌČ => (X (k + 1) ŌČ - X k ŌČ) ^ 2) P)
    (hratio_int :
      Integrable
        (fun ŌČ => (A (k + 1) ŌČ - A k ŌČ) / (f (A (k + 1) ŌČ)) ^ 2) P)
    (hcond_le :
      P[(fun ŌČ => (X (k + 1) ŌČ - X k ŌČ) ^ 2) | ‚ĄĪ k] ‚Č§ŠĶź[P]
        fun ŌČ => A (k + 1) ŌČ - A k ŌČ) :
    (‚ąę ŌČ, ((f (A (k + 1) ŌČ))‚ĀĽ¬Ļ * (X (k + 1) ŌČ - X k ŌČ)) ^ 2 ‚ąāP) ‚Č§
      ‚ąę ŌČ, (A (k + 1) ŌČ - A k ŌČ) / (f (A (k + 1) ŌČ)) ^ 2 ‚ąāP := by
  let H : ő© -> ‚ĄĚ := fun ŌČ => (f (A (k + 1) ŌČ))‚ĀĽ¬Ļ
  let Y : ő© -> ‚ĄĚ := fun ŌČ => X (k + 1) ŌČ - X k ŌČ
  let V : ő© -> ‚ĄĚ := fun ŌČ => A (k + 1) ŌČ - A k ŌČ
  have hH_meas : StronglyMeasurable[‚ĄĪ k] H := by
    dsimp [H]
    exact
      (durrett2019_theorem_4_5_3_reciprocal_comp_predictable
        (‚ĄĪ := ‚ĄĪ) (A := A) (f := f) hA_predictable hf_cont).measurable_add_one k
  have hscaled_eq :
      (fun ŌČ => ((f (A (k + 1) ŌČ))‚ĀĽ¬Ļ * (X (k + 1) ŌČ - X k ŌČ)) ^ 2)
        =ŠĶź[P] fun ŌČ => H ŌČ ^ 2 * Y ŌČ ^ 2 := by
    refine ae_of_all P fun ŌČ => ?_
    simp [H, Y, mul_pow]
  have hratio_eq :
      (fun ŌČ => H ŌČ ^ 2 * V ŌČ)
        =ŠĶź[P] fun ŌČ =>
          (A (k + 1) ŌČ - A k ŌČ) / (f (A (k + 1) ŌČ)) ^ 2 := by
    refine ae_of_all P fun ŌČ => ?_
    simp [H, V, div_eq_mul_inv, mul_comm]
  have hHY_int : Integrable (fun ŌČ => H ŌČ ^ 2 * Y ŌČ ^ 2) P :=
    (integrable_congr hscaled_eq).mp hscaled_int
  have hHV_int : Integrable (fun ŌČ => H ŌČ ^ 2 * V ŌČ) P :=
    (integrable_congr hratio_eq).mpr hratio_int
  have hcore :
      (‚ąę ŌČ, H ŌČ ^ 2 * Y ŌČ ^ 2 ‚ąāP) ‚Č§ ‚ąę ŌČ, H ŌČ ^ 2 * V ŌČ ‚ąāP :=
    durrett2019_theorem_4_5_3_integral_mul_sq_le_of_condExp_square_le
      (P := P) (‚ĄĪ := ‚ĄĪ) (H := H) (Y := Y) (V := V) (k := k)
      hH_meas hHY_int hdiff_sq_int hHV_int hcond_le
  calc
    (‚ąę ŌČ, ((f (A (k + 1) ŌČ))‚ĀĽ¬Ļ * (X (k + 1) ŌČ - X k ŌČ)) ^ 2 ‚ąāP)
        = ‚ąę ŌČ, H ŌČ ^ 2 * Y ŌČ ^ 2 ‚ąāP := integral_congr_ae hscaled_eq
    _ ‚Č§ ‚ąę ŌČ, H ŌČ ^ 2 * V ŌČ ‚ąāP := hcore
    _ = ‚ąę ŌČ, (A (k + 1) ŌČ - A k ŌČ) / (f (A (k + 1) ŌČ)) ^ 2 ‚ąāP :=
        integral_congr_ae hratio_eq

/--
