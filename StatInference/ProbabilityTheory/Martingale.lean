    durrett2019_theorem_4_5_7_tail_cut_weighted_kernel_measurable_of_aemeasurable
    {ő© : Type*} [MeasurableSpace ő©] {P : Measure ő©} [SFinite P]
    {Ainf : ő© -> ‚ĄĚ}
    (hAinf_meas : AEMeasurable Ainf P) :
    Measurable (Function.uncurry fun a b : ‚ĄĚ =>
      P {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} /
        (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě)) := by
  have hmk :=
    durrett2019_theorem_4_5_7_tail_cut_weighted_kernel_measurable
      (P := P) (Ainf := hAinf_meas.mk Ainf) hAinf_meas.measurable_mk
  have hkernel_eq :
      (Function.uncurry fun a b : ‚ĄĚ =>
        P {ŌČ : ő© | b < Ainf ŌČ ‚ąß b < a ^ 2} /
          (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě)) =
        (Function.uncurry fun a b : ‚ĄĚ =>
          P {ŌČ : ő© | b < hAinf_meas.mk Ainf ŌČ ‚ąß b < a ^ 2} /
            (((Real.toNNReal a) ^ 2 : ‚ĄĚ‚Č•0) : ‚ĄĚ‚Č•0‚ąě)) := by
    funext p
