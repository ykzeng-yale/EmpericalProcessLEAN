  rw [integral_Ioi_rpow_of_lt (a := (-2 : ‚ĄĚ)) (c := c) (by norm_num) hc]
  congr 1
  rw [show (-2 : ‚ĄĚ) + 1 = -1 by norm_num]
  rw [Real.rpow_neg_one]
