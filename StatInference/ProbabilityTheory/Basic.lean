      ∀ m ∈ Finset.Icc 1 n, ∀ i ∈ Finset.Ico m n, Integrable (X i) P)
    (hzero :
      ∀ m ∈ Finset.Icc 1 n, ∀ i ∈ Finset.Ico m n, ∫ ω, X i ω ∂P = 0)
