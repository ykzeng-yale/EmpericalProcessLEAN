    (L : StrongDual ℝ E) :
    HasLaw (fun ω => L (S.Z ω))
      (gaussianReal 0 (S.covariance_limit.S_infty L L).toNNReal) Q := by
  let Y : Ω' -> ℝ := fun ω => L (S.Z ω)
  have hY_gaussian : HasGaussianLaw Y Q := S.gaussian_limit.map_fun L
  refine ⟨hY_gaussian.aemeasurable, ?_⟩
