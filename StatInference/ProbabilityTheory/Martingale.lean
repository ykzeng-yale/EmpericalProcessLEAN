  refine
    durrett2019_theorem_4_5_7_lintegral_le_lintegral_tail_bound_lt
      (P := P) (Y := durrett2019_runningAbsMax X n)
      (tailBound := fun a =>
        P {ŌČ : ő© | a ^ 2 < Ainf ŌČ} +
