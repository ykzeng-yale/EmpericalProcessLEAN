            (fun k => max (X k ω) 0)‖ₑ ^ p ∂P) ≠ ∞) :
    (∫⁻ ω,
        ‖(Finset.range (n + 1)).sup' Finset.nonempty_range_add_one
            (fun k => max (X k ω) 0)‖ₑ ^ p ∂P) ≤
      (ENNReal.ofReal (p / (p - 1)) *
        (∫⁻ ω, ‖max (X n ω) 0‖ₑ ^ p ∂P) ^ (1 / p)) ^ p := by
  let M : ℝ≥0∞ :=
    ∫⁻ ω,
      ‖(Finset.range (n + 1)).sup' Finset.nonempty_range_add_one
          (fun k => max (X k ω) 0)‖ₑ ^ p ∂P
