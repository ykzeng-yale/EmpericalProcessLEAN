        positivity
      have hconstant_pos : 0 < constant M eta :=
        lt_of_lt_of_le zero_lt_one (hconstant_ge_one M hM eta heta)
      have hsucc_pos : 0 < (((n + 1 : ℕ) : ℝ)) := by
        positivity
      have hpow_pos : 0 < (((n + 1 : ℕ) : ℝ) ^ degree M eta) :=
