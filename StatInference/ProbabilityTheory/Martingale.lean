        (‚ąę‚ĀĽ ŌČ, ‚ÄĖmax (X n ŌČ) 0‚ÄĖ‚āĎ ^ p ‚ąāP) ^ (1 / p)) ^ p := by
  let M : ‚ĄĚ‚Č•0‚ąě :=
