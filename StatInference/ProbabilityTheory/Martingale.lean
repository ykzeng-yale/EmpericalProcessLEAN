    ‚ąę‚ĀĽ x,
      (((durrett2019_theorem_4_3_8_cylinderLikelihood (Iseq n) q x) ^
            ((1 : ‚ĄĚ) / 2) +
          (durrett2019_theorem_4_3_8_cylinderLikelihood (Iseq m) q x) ^
