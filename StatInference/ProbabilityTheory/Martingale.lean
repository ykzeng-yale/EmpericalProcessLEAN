theorem
    durrett2019_theorem_4_5_7_runningAbsMax_lintegral_le_three_sqrt_lintegral_of_source_square_minus_martingale_monotone_terminal
    {ő© : Type*} [mő© : MeasurableSpace ő©]
    {P : Measure ő©} [IsFiniteMeasure P] [IsProbabilityMeasure P]
    {‚ĄĪ : Filtration ‚Ąē mő©} [SigmaFiniteFiltration P ‚ĄĪ]
    {X A : ‚Ąē -> ő© -> ‚ĄĚ} {Ainf : ő© -> ‚ĄĚ}
    (hX : Martingale X ‚ĄĪ P)
    (hA_predictable : IsStronglyPredictable ‚ĄĪ A)
    (hSquareMinus : Martingale (fun n ŌČ => X n ŌČ ^ 2 - A n ŌČ) ‚ĄĪ P)
    (hX_memLp_two : ‚ąÄ n, MemLp (X n) (2 : ‚ĄĚ‚Č•0‚ąě) P)
    (hA_int : ‚ąÄ n, Integrable (A n) P)
    (hAinf_int : Integrable Ainf P)
    (hX0 : X 0 =ŠĶź[P] 0)
    (hA0 : A 0 = 0)
    (hA_mono : ‚ąÄŠĶź ŌČ ‚ąāP, Monotone fun n => A n ŌČ)
    (hA_tendsto : ‚ąÄŠĶź ŌČ ‚ąāP, Tendsto (fun n => A n ŌČ) atTop (ūĚďĚ (Ainf ŌČ)))
